# Auto detect text files and perform LF normalization
* text=auto

# Force LF for all text files
*.cs text eol=lf
*.razor text eol=lf
*.json text eol=lf
*.md text eol=lf
*.ps1 text eol=crlf
*.config text eol=lf
*.csproj text eol=lf
*.css text eol=lf
*.js text eol=lf
*.html text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.dll binary
*.exe binary
