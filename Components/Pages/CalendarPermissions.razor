@page "/calendar-permissions"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "CalendarPermissions")]
@rendermode InteractiveServer
@inject IExchangeService Exchange
@inject AuditService Audit
@inject EmailService Email
@inject PermissionValidator Validator
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject ClientInfoService ClientInfo
@inject IJSRuntime JS
@inject IConfiguration Config
@inject ServiceNowService ServiceNow
@inject ILogger<ExchangeAdminWeb.Components.Pages.CalendarPermissions> Logger

<PageTitle>Calendar Permissions</PageTitle>

<div class="container-fluid">
    <div class="alert alert-info py-2 mb-3">
        <small>All permission changes are logged for audit purposes.@if (bool.Parse(Config["Email:NotifyUsersOnPermissionGrant"] ?? "false")){<text> Affected users will receive email notifications when permissions are granted or removed.</text>}</small>
    </div>
    <h1 class="mb-4">Calendar Permissions</h1>

    <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            <button class="nav-link @(tabIndex == 0 ? "active" : "")" @onclick="() => SetTab(0)">Set</button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(tabIndex == 1 ? "active" : "")" @onclick="() => SetTab(1)">Remove</button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(tabIndex == 2 ? "active" : "")" @onclick="() => SetTab(2)">Bulk Upload</button>
        </li>
    </ul>

    @if (tabIndex < 2)
    {
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold" for="targetMailbox">Target Mailbox</label>
                            <input id="targetMailbox" class="form-control" type="text"
                                   placeholder="mailbox@domain.com or SamAccountName"
                                   @bind="targetMailbox" @bind:event="oninput" />
                            <div class="form-text">SMTP, UPN, or SamAccountName accepted. Calendar folder auto-detected.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold" for="affectedUser">User</label>
                            <input id="affectedUser" class="form-control" type="text"
                                   placeholder="user@domain.com or SamAccountName"
                                   @bind="affectedUser" @bind:event="oninput" />
                            <div class="form-text">SMTP, UPN, or SamAccountName accepted</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold" for="ticketNumber">Ticket Number <span class="text-danger">*</span></label>
                            <input id="ticketNumber" class="form-control" type="text"
                                   placeholder="INC0001234 or REQ0005678"
                                   @bind="ticketNumber" @bind:event="oninput" />
                            <div class="form-text">Service request or incident ticket number</div>
                        </div>

                        @if (tabIndex == 0)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-semibold" for="accessLevel">Permission Level</label>
                                <select id="accessLevel" class="form-select" @bind="accessRight">
                                    <option value="@CalendarAccessRight.AvailabilityOnly">Availability Only (free/busy time)</option>
                                    <option value="@CalendarAccessRight.LimitedDetails">Limited Details (free/busy + subject &amp; location)</option>
                                    <option value="@CalendarAccessRight.Reviewer">Reviewer (read all details)</option>
                                    <option value="@CalendarAccessRight.Contributor">Contributor (create items)</option>
                                    <option value="@CalendarAccessRight.Author">Author (create &amp; edit own items)</option>
                                    <option value="@CalendarAccessRight.NonEditingAuthor">Non-Editing Author (create, read all)</option>
                                    <option value="@CalendarAccessRight.PublishingAuthor">Publishing Author (create, read, edit own)</option>
                                    <option value="@CalendarAccessRight.Editor">Editor (create &amp; edit all)</option>
                                    <option value="@CalendarAccessRight.PublishingEditor">Publishing Editor (create, read, edit all)</option>
                                    <option value="@CalendarAccessRight.Owner">Owner (full control)</option>
                                    <option value="@CalendarAccessRight.None">None (remove all access)</option>
                                </select>
                            </div>
                        }

                        <button class="btn btn-primary" @onclick="SubmitSingle" disabled="@(isLoading || !IsFormValid)">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            }
                            @(tabIndex == 0 ? "Set Permission" : "Remove Permission")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">Bulk @(bulkIsSet ? "Set" : "Remove") Calendar Permissions</h5>
                        <p class="text-muted">Upload a CSV file with the following columns:</p>
                        <ul class="small text-muted">
                            <li><code>Target</code> - Mailbox (SMTP, UPN, or SamAccountName). Calendar folder auto-detected.</li>
                            <li><code>User</code> - User to grant/revoke access (SMTP, UPN, or SamAccountName)</li>
                            @if (bulkIsSet)
                            {
                                <li><code>AccessRight</code> - Permission level (Owner, Editor, Reviewer, etc.)</li>
                            }
                        </ul>

                        <div class="mb-3 btn-group" role="group">
                            <input type="radio" class="btn-check" name="bulkAction" id="radioSet" checked="@bulkIsSet" @onchange="() => bulkIsSet = true" />
                            <label class="btn btn-outline-primary" for="radioSet">Set</label>
                            <input type="radio" class="btn-check" name="bulkAction" id="radioRemove" checked="@(!bulkIsSet)" @onchange="() => bulkIsSet = false" />
                            <label class="btn btn-outline-primary" for="radioRemove">Remove</label>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold" for="bulkTicket">Ticket Number (applies to all rows) <span class="text-danger">*</span></label>
                            <input id="bulkTicket" class="form-control" type="text"
                                   placeholder="INC0001234 or REQ0005678"
                                   @bind="bulkTicketNumber" @bind:event="oninput" />
                        </div>

                        <div class="mb-3">
                            <label for="csvFile" class="form-label fw-semibold">CSV File</label>
                            <InputFile id="csvFile" class="form-control" OnChange="HandleCsvUpload" accept=".csv" />
                        </div>

                        <button class="btn btn-primary" @onclick="ProcessBulk" disabled="@(isLoading || csvFile is null || string.IsNullOrWhiteSpace(bulkTicketNumber))">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                            }
                            Process CSV
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (onPremConfirmPending)
    {
        <div class="row mt-3">
            <div class="col-md-8">
                <div class="alert alert-warning" role="alert">
                    <strong>@onPremTarget</strong> is an on-premises mailbox. This will execute against the on-prem Exchange server.
                    <div class="mt-2">
                        <button class="btn btn-warning btn-sm me-2" @onclick="ConfirmOnPrem" disabled="@isLoading">
                            @if (isLoading) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Continue
                        </button>
                        <button class="btn btn-secondary btn-sm" @onclick="CancelOnPrem">Cancel</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (result is not null)
    {
        <div class="row mt-3">
            <div class="col-md-8">
                <div class="alert @(result.Success ? "alert-success" : "alert-danger") alert-dismissible" role="alert">
                    <strong>@(result.Success ? "Success" : "Error"):</strong> @result.Message
                    @if (!string.IsNullOrEmpty(result.Detail))
                    {
                        <div class="mt-1"><small>@result.Detail</small></div>
                    }
                    <button type="button" class="btn-close" @onclick="() => result = null" aria-label="Close"></button>
                </div>
            </div>
        </div>
    }

    @if (bulkResult is not null)
    {
        <div class="row mt-3">
            <div class="col-md-8">
                <div class="alert @(bulkResult.FailedCount == 0 ? "alert-success" : "alert-warning") alert-dismissible">
                    <h5 class="alert-heading">Bulk Operation Complete</h5>
                    <p><strong>@bulkResult.Summary</strong></p>
                    <div class="mb-2">
                        <button class="btn btn-sm btn-primary" @onclick="DownloadCsvReport">
                            Download Full Report (CSV)
                        </button>
                    </div>
                    @if (bulkResult.Errors.Any())
                    {
                        <hr />
                        <p class="mb-1"><strong>Errors:</strong></p>
                        <ul class="mb-0 small">
                            @foreach (var err in bulkResult.Errors.Take(20))
                            {
                                <li>@err</li>
                            }
                            @if (bulkResult.Errors.Count > 20)
                            {
                                <li class="text-muted">... and @(bulkResult.Errors.Count - 20) more</li>
                            }
                        </ul>
                    }
                    <button type="button" class="btn-close" @onclick="() => bulkResult = null" aria-label="Close"></button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private int tabIndex = 0;
    private string targetMailbox = string.Empty;
    private string affectedUser = string.Empty;
    private string ticketNumber = string.Empty;
    private CalendarAccessRight accessRight = CalendarAccessRight.Reviewer;
    private bool isLoading = false;
    private PermissionResult? result;
    private string currentUser = string.Empty;
    private string clientIpAddress = "Unknown";

    private bool bulkIsSet = true;
    private string bulkTicketNumber = string.Empty;
    private IBrowserFile? csvFile;
    private BulkOperationResult? bulkResult;

    private bool IsFormValid =>
        !string.IsNullOrWhiteSpace(targetMailbox) &&
        !string.IsNullOrWhiteSpace(affectedUser) &&
        !string.IsNullOrWhiteSpace(ticketNumber);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUser = user.Identity?.Name ?? "Unknown";

        // CRITICAL: Explicitly check authorization - [Authorize] attribute is not reliably enforced
        var authResult = await AuthorizationService.AuthorizeAsync(user, "CalendarPermissions");
        if (!authResult.Succeeded)
        {
            Navigation.NavigateTo("access-denied", forceLoad: true);
            return;
        }

        // Try scoped instance first, then fall back to cached value
        clientIpAddress = ClientInfo.IpAddress != "Unknown"
            ? ClientInfo.IpAddress
            : ClientInfo.GetIpForUser(currentUser);
    }

    private bool onPremConfirmPending;
    private string? onPremTarget;

    private void SetTab(int index)
    {
        tabIndex = index;
        result = null;
        bulkResult = null;
        onPremConfirmPending = false;
    }

    private async Task ConfirmOnPrem()
    {
        onPremConfirmPending = false;
        await ExecuteOnPrem();
    }

    private void CancelOnPrem()
    {
        onPremConfirmPending = false;
        onPremTarget = null;
    }

    private async Task SubmitSingle()
    {
        isLoading = true;
        result = null;

        var target = targetMailbox.Trim();
        var user = affectedUser.Trim();
        var ticket = ticketNumber.Trim();

        var ticketValidation = await ServiceNow.ValidateTicketAsync(ticket);
        if (!ticketValidation.IsValid)
        {
            result = PermissionResult.Fail($"Ticket validation failed: {ticketValidation.Message}");
            isLoading = false;
            return;
        }

        var validationError = await Validator.ValidateTargetMailboxAsync(target);
        if (validationError is not null)
        {
            result = PermissionResult.Fail(validationError);
            try
            {
                var action = tabIndex == 0 ? "SetCalendar_Denied" : "RemoveCalendar_Denied";
                Audit.LogCalendarPermission(
                    currentUser, clientIpAddress, action, target, user,
                    tabIndex == 0 ? accessRight.ToString() : "", false, ticket, errorDetail: validationError);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to write audit for protected-target denial on {Target}", target);
            }
            isLoading = false;
            return;
        }

        if (tabIndex == 0)
        {
            var selfGrantError = await Validator.ValidateSelfGrantAsync(currentUser, user);
            if (selfGrantError is not null)
            {
                // Log self-grant attempt to audit log
                var ipAddress = clientIpAddress;
                try
                {
                    Audit.LogCalendarPermission(
                        currentUser, ipAddress, "SetCalendar_SelfGrantAttempt", target, user,
                        accessRight.ToString(), false, ticket,
                        errorDetail: "Self-grant blocked: User attempted to grant permissions to themselves");
                }
                catch (Exception ex)
                {
                    result = PermissionResult.Fail($"Self-grant blocked, but audit logging failed: {ex.Message}");
                    isLoading = false;
                    return;
                }

                result = PermissionResult.Fail(selfGrantError);
                isLoading = false;
                return;
            }
        }

        try
        {
            var location = await Exchange.GetMailboxLocationAsync(target);
            if (location == "OnPrem")
            {
                var onPremAuth = await AuthorizationService.AuthorizeAsync(
                    (await AuthStateProvider.GetAuthenticationStateAsync()).User, "CalendarPermissionsOnPrem");
                if (!onPremAuth.Succeeded)
                {
                    result = PermissionResult.Fail($"{target} is an on-premises mailbox. Please escalate this ticket to the Exchange team.");
                    isLoading = false;
                    return;
                }

                onPremTarget = target;
                onPremConfirmPending = true;
                isLoading = false;
                return;
            }

            PermissionResult opResult;
            string action;
            string? level;

            if (tabIndex == 0)
            {
                opResult = await Exchange.SetCalendarPermissionAsync(target, user, accessRight);
                action = "SetCalendar";
                level = accessRight.ToString();
            }
            else
            {
                opResult = await Exchange.RemoveCalendarPermissionAsync(target, user);
                action = "RemoveCalendar";
                level = null;
            }

            var ipAddress = clientIpAddress;

            Audit.LogCalendarPermission(
                currentUser, ipAddress, action, target, user, level,
                opResult.Success, ticket,
                errorDetail: opResult.Success ? null : opResult.Message);

            // Send admin notification
            await Email.SendAdminNotificationAsync(
                currentUser, ipAddress, action, target, user,
                level ?? "Remove", opResult.Success, ticket,
                opResult.Success ? null : opResult.Message);

            // Send notifications to both the user being granted access and the calendar owner
            if (opResult.Success)
            {
                var isGrant = tabIndex == 0;
                var permType = isGrant ? $"Calendar {level}" : "Calendar Access";
                // Notify the user being granted/removed access
                await Email.SendUserNotificationAsync(user, $"{target} (Calendar)", currentUser, permType, isGrant);
                // Notify the calendar owner
                await Email.SendOwnerNotificationAsync(target, user, currentUser, permType, isGrant);
            }

            result = opResult;
        }
        catch (Exception ex)
        {
            result = PermissionResult.Fail($"Operation may have succeeded but audit logging failed: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void HandleCsvUpload(InputFileChangeEventArgs e)
    {
        csvFile = e.File;
        bulkResult = null;
    }

    private async Task ProcessBulk()
    {
        if (csvFile is null) return;

        isLoading = true;
        bulkResult = null;

        try
        {
            var ipAddress = clientIpAddress;
            var ticket = bulkTicketNumber.Trim();

            var ticketValidation = await ServiceNow.ValidateTicketAsync(ticket);
            if (!ticketValidation.IsValid)
            {
                result = PermissionResult.Fail($"Ticket validation failed: {ticketValidation.Message}");
                isLoading = false;
                return;
            }

            await using var stream = csvFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            bulkResult = await Exchange.ProcessCalendarPermissionsCsvAsync(stream, bulkIsSet, Validator, currentUser, Audit, ipAddress, ticket);

            var action = bulkIsSet ? "BulkSetCalendar" : "BulkRemoveCalendar";

            try
            {
                Audit.LogCalendarPermission(
                    currentUser, ipAddress, action, "Bulk", csvFile.Name, "Multiple",
                    bulkResult.FailedCount == 0, ticket,
                    errorDetail: bulkResult.FailedCount > 0 ? $"{bulkResult.FailedCount} failures" : null);
            }
            catch (Exception ex)
            {
                result = PermissionResult.Fail($"Bulk operations completed ({bulkResult.Summary}) but summary audit logging failed: {ex.Message}");
            }

            await Email.SendAdminNotificationAsync(
                currentUser, ipAddress, action, "Bulk Operation", csvFile.Name,
                $"{bulkResult.TotalRows} rows", bulkResult.FailedCount == 0, ticket,
                bulkResult.FailedCount > 0 ? $"{bulkResult.FailedCount} failures" : null);
        }
        catch (Exception ex)
        {
            result = PermissionResult.Fail(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ExecuteOnPrem()
    {
        isLoading = true;
        result = null;

        var target = targetMailbox.Trim();
        var user = affectedUser.Trim();
        var ticket = ticketNumber.Trim();

        try
        {
            PermissionResult opResult;
            string action;
            string? level;

            if (tabIndex == 0)
            {
                opResult = await Exchange.SetCalendarPermissionOnPremAsync(target, user, accessRight.ToString());
                action = "OnPrem_SetCalendar";
                level = accessRight.ToString();
            }
            else
            {
                opResult = await Exchange.RemoveCalendarPermissionOnPremAsync(target, user);
                action = "OnPrem_RemoveCalendar";
                level = null;
            }

            Audit.LogCalendarPermission(
                currentUser, clientIpAddress, action, target, user, level,
                opResult.Success, ticket, errorDetail: opResult.Success ? null : opResult.Message);

            await Email.SendAdminNotificationAsync(
                currentUser, clientIpAddress, action, target, user,
                level ?? "Remove", opResult.Success, ticket,
                opResult.Success ? null : opResult.Message);

            result = opResult;
        }
        catch (Exception ex)
        {
            result = PermissionResult.Fail(ex.Message);
        }
        finally
        {
            isLoading = false;
            onPremTarget = null;
        }
    }

    private async Task DownloadCsvReport()
    {
        if (bulkResult is null) return;

        var csvBytes = bulkResult.GenerateCsvReport();
        var base64 = Convert.ToBase64String(csvBytes);
        var timestamp = DateTime.Now.ToString("yyyyMMdd_HHmmss");
        var filename = $"calendar_permissions_report_{timestamp}.csv";

        await JS.InvokeVoidAsync("downloadFile", filename, "text/csv", base64);
    }
}
