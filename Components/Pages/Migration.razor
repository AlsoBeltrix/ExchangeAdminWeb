    private async Task HandleConfirmKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(pendingActionTicket))
            await ConfirmPendingAction();
    }

    private void CancelPendingAction()
    {
        pendingActionLabel = null;
        pendingActionTarget = null;
        pendingActionTicket = "";
        pendingActionCallback = null;
    }

    private async Task ConfirmPendingAction()
    {
        if (pendingActionCallback == null || string.IsNullOrWhiteSpace(pendingActionTicket)) return;

        var callback = pendingActionCallback;
        var ticket = pendingActionTicket.Trim();
        CancelPendingAction();
        await callback(ticket);
    }

    private async Task ExecuteBatchAction(Func<Task<PermissionResult>> action, string auditAction, string target, string ticket)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!(await AuthorizationService.AuthorizeAsync(authState.User, "MigrationManage")).Succeeded)
            return;

        actionInProgress = target;
        batchActionResult = null;

        try
        {
            var result = await action();
            batchActionResult = result;

            try
            {
                Audit.LogMigrationAction(currentUser, clientIpAddress, auditAction, target, result.Success, ticket, result.Success ? null : result.Message);
            }
            catch (Exception ex)
            {
                batchActionResult = new PermissionResult
                {
                    Success = result.Success,
                    Message = result.Message,
                    Detail = $"Audit logging failed: {ex.Message}"
                };
            }

            try
            {
                await Email.SendAdminNotificationAsync(
                    currentUser, clientIpAddress, $"Migration_{auditAction}", target, "N/A",
                    "Migration", result.Success, ticket, result.Success ? null : result.Message);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to send admin notification for Migration_{Action} on {Target}", auditAction, target);
            }

            if (result.Success)
            {
                var savedResult = batchActionResult;
                await LoadMigrationStatus();
                batchActionResult = batchActionResult ?? savedResult;
            }
        }
        catch (Exception ex)
        {
            batchActionResult = PermissionResult.Fail(ex.Message);
        }
        finally
        {
            actionInProgress = null;
        }
    }

    private async Task ExecuteUserAction(Func<Task<PermissionResult>> action, string auditAction, string target, string ticket)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!(await AuthorizationService.AuthorizeAsync(authState.User, "MigrationManage")).Succeeded)
            return;

        actionInProgress = target;
