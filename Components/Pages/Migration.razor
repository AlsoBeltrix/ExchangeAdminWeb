                                                                                &#x21bb;
                                                                            </button>
                                                                            @if (actionInProgress == e)
                                                                            {
                                                                                <span class="spinner-border spinner-border-sm ms-1"></span>
                                                                            }
                                                                        </td>
                                                                    </tr>
                                                                    @if (reportUser == user.EmailAddress && userReport != null)
