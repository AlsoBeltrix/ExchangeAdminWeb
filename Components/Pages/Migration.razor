    private void StageClearCompleted()
    {
        var count = migrationBatches?.Count(b => b.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase) || b.TotalCount == 0) ?? 0;
        StageBatchAction("Clear Completed", $"{count} batch(es)", ClearCompletedBatches);
    }

    private async Task ClearCompletedBatches(string ticket)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!(await AuthorizationService.AuthorizeAsync(authState.User, "MigrationManage")).Succeeded)
            return;

        if (migrationBatches == null) return;

        actionInProgress = "clearing";
        isLoadingStatus = true;
        batchActionResult = null;
        var removed = 0;
        var errors = new List<string>();

        try
        {
            var toRemove = migrationBatches
                .Where(b => b.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase) || b.TotalCount == 0)
                .ToList();

            foreach (var batch in toRemove)
            {
                var result = await Exchange.RemoveMigrationBatchAsync(batch.BatchName);
                if (result.Success)
                {
                    removed++;
                    try
                    {
                        Audit.LogMigrationAction(currentUser, clientIpAddress, "RemoveMigrationBatch", batch.BatchName, true, ticket);
                    }
                    catch (Exception ex)
                    {
                        errors.Add($"{batch.BatchName}: removed but audit logging failed: {ex.Message}");
                    }
                }
                else
                {
                    errors.Add($"{batch.BatchName}: {result.Message}");
                }
            }

            if (errors.Count == 0)
                batchActionResult = new PermissionResult { Success = true, Message = $"Removed {removed} completed/empty batch(es)." };
            else
                batchActionResult = PermissionResult.Fail($"Removed {removed}, failed {errors.Count}: {string.Join("; ", errors)}");

            try
            {
                await Email.SendAdminNotificationAsync(
                    currentUser, clientIpAddress, "Migration_ClearCompleted",
                    $"{removed} batch(es)", "N/A", "Migration",
                    errors.Count == 0, ticket, errors.Any() ? string.Join("; ", errors) : null);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to send admin notification for Migration_ClearCompleted");
            }

            var savedResult = batchActionResult;
            await LoadMigrationStatus();
            batchActionResult = batchActionResult ?? savedResult;
        }
        catch (Exception ex)
        {
            batchActionResult = PermissionResult.Fail(ex.Message);
        }
        finally
        {
            actionInProgress = null;
            isLoadingStatus = false;
        }
    }

    private async Task HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(searchQuery))
            await SearchUser();
    }

    private void ClearSearch()
    {
        searchQuery = "";
        highlightedUser = null;
        batchActionResult = null;
    }

    private async Task SearchUser()
    {
        if (string.IsNullOrWhiteSpace(searchQuery) || migrationBatches == null) return;

        var query = searchQuery.Trim();
        isSearching = true;
        highlightedUser = null;
        batchActionResult = null;

        try
        {
            var matchedBatch = migrationBatches.FirstOrDefault(b =>
                b.BatchName.Contains(query, StringComparison.OrdinalIgnoreCase));

            if (matchedBatch != null)
            {
                expandedBatch = matchedBatch.BatchName;
                loadingBatchUsers = matchedBatch.BatchName;
                batchUsers = null;
                StateHasChanged();

                batchUsers = await Exchange.GetMigrationBatchUsersAsync(matchedBatch.BatchName);
                loadingBatchUsers = null;
                return;
            }

            var searchResult = await Exchange.FindMigrationUserBatchAsync(query);

            if (searchResult.Error != null)
            {
                batchActionResult = PermissionResult.Fail($"Search failed: {searchResult.Error}");
                return;
            }

            if (searchResult.MatchCount == 0)
            {
                batchActionResult = PermissionResult.Fail($"No batch or user found matching \"{query}\".");
                return;
            }

            if (searchResult.MatchCount > 1)
            {
                batchActionResult = PermissionResult.Fail($"Multiple users ({searchResult.MatchCount}) match \"{query}\". Use a more specific search term.");
                return;
            }

            highlightedUser = searchResult.Email;
            expandedBatch = searchResult.BatchId;
            loadingBatchUsers = searchResult.BatchId;
            batchUsers = null;
            StateHasChanged();

            batchUsers = await Exchange.GetMigrationBatchUsersAsync(searchResult.BatchId!);
            loadingBatchUsers = null;
        }
        catch (Exception ex)
        {
            batchActionResult = PermissionResult.Fail($"Search failed: {ex.Message}");
        }
        finally
        {
            isSearching = false;
        }
    }

    private async Task LoadUserReport(string emailAddress)
    {
        if (reportUser == emailAddress)
        {
            reportUser = null;
            userReport = null;
            return;
        }

        loadingReport = emailAddress;
        reportUser = null;
        userReport = null;

        try
        {
            userReport = await Exchange.GetMigrationUserReportAsync(emailAddress);
            reportUser = emailAddress;
        }
        catch (Exception ex)
        {
            userReport = $"Error: {ex.Message}";
            reportUser = emailAddress;
        }
        finally
        {
            loadingReport = null;
        }
    }

    private void ToggleBatchSort(string column)
    {
        if (batchSortColumn == column)
            batchSortAsc = !batchSortAsc;
        else
        {
            batchSortColumn = column;
            batchSortAsc = column is "Name" or "Status" or "Direction";
        }
    }

    private MarkupString SortIndicator(string column)
    {
        if (batchSortColumn != column)
            return new MarkupString("<span class=\"text-muted opacity-25\">↕</span>");
        return new MarkupString(batchSortAsc ? "▲" : "▼");
    }

    private IEnumerable<MigrationBatchInfo> GetSortedBatches()
    {
        if (migrationBatches == null) return Enumerable.Empty<MigrationBatchInfo>();

        IOrderedEnumerable<MigrationBatchInfo> sorted = batchSortColumn switch
        {
            "Name" => batchSortAsc ? migrationBatches.OrderBy(b => b.BatchName) : migrationBatches.OrderByDescending(b => b.BatchName),
            "Status" => batchSortAsc ? migrationBatches.OrderBy(b => b.Status) : migrationBatches.OrderByDescending(b => b.Status),
            "Direction" => batchSortAsc ? migrationBatches.OrderBy(b => b.Direction) : migrationBatches.OrderByDescending(b => b.Direction),
            "Total" => batchSortAsc ? migrationBatches.OrderBy(b => b.TotalCount) : migrationBatches.OrderByDescending(b => b.TotalCount),
            "Synced" => batchSortAsc ? migrationBatches.OrderBy(b => b.SyncedCount) : migrationBatches.OrderByDescending(b => b.SyncedCount),
            "Failed" => batchSortAsc ? migrationBatches.OrderBy(b => b.FailedCount) : migrationBatches.OrderByDescending(b => b.FailedCount),
            _ => batchSortAsc ? migrationBatches.OrderBy(b => b.CreatedDateTime) : migrationBatches.OrderByDescending(b => b.CreatedDateTime),
        };

        return sorted;
    }

    private string GetStatusColor(string status)
    {
        return status.ToLowerInvariant() switch
        {
            "completed" => "success",
            "syncing" or "synced" => "primary",
            "stopped" or "stopping" => "warning",
            "failed" => "danger",
            "corrupted" => "danger",
            "needsapproval" => "warning",
            _ => "secondary"
        };
    }

    private string GetUserStatusColor(string status)
    {
        return status.ToLowerInvariant() switch
        {
            "completed" => "success",
            "synced" => "info",
            "syncing" => "primary",
            "failed" => "danger",
            "stopped" => "warning",
            "needsapproval" => "warning",
            "queued" => "secondary",
            _ => "secondary"
        };
    }

    private async Task DownloadSampleCsv()
    {
        var content = "EmailAddress\nuser@company.com\n";
        var base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(content));
        await JS.InvokeVoidAsync("downloadFile", "migration_check_sample.csv", "text/csv", base64);
    }
}
