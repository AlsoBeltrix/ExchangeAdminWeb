                                                                                        <strong>Report for @user.EmailAddress</strong>
                                                                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => { reportUser = null; userReport = null; }">Close</button>
                                                                                    </div>
                                                                                    <pre class="bg-light p-2 rounded" style="max-height: 400px; overflow-y: auto; font-size: 0.8rem; white-space: pre-wrap;">@userReport</pre>
                                                                                </div>
                                                                            </td>
                                                                        </tr>
                                                                    }
                                                                }
                                                            </tbody>
                                                        </table>
