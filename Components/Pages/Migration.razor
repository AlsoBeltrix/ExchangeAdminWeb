    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUser = user.Identity?.Name ?? "Unknown";

        var authResult = await AuthorizationService.AuthorizeAsync(user, "MigrationCheck");
        if (!authResult.Succeeded)
        {
            Navigation.NavigateTo("access-denied", forceLoad: true);
            return;
        }

        canCreate = (await AuthorizationService.AuthorizeAsync(user, "MigrationCreate")).Succeeded;
        canManage = (await AuthorizationService.AuthorizeAsync(user, "MigrationManage")).Succeeded;

