    private async Task CheckSingleEligibility()
    {
        if (string.IsNullOrWhiteSpace(singleEmail))
            return;

        isLoading = true;
        singleResult = null;
        singleCreateResult = null;

        try
        {
            singleResult = await Exchange.CheckMigrationEligibilityAsync(singleEmail.Trim(), singleMigrationDirection);

            var ipAddress = clientIpAddress;

            Audit.LogMigrationCheck(currentUser, ipAddress, singleEmail, singleResult.Status.ToString(),
                singleTicketNumber, string.Join("; ", singleResult.IneligibilityReasons));

            // Send admin notification
            await Email.SendAdminNotificationAsync(
                currentUser, ipAddress, $"CheckMigrationEligibility_{singleMigrationDirection}", singleEmail, "N/A",
                singleResult.Status.ToString(), singleResult.Status == MigrationStatus.Eligible, singleTicketNumber,
                singleResult.IneligibilityReasons.Any() ? string.Join("; ", singleResult.IneligibilityReasons) : null);
        }
        catch (Exception ex)
        {
            singleResult = new MigrationEligibilityResult
            {
                EmailAddress = singleEmail,
                Status = MigrationStatus.Ineligible
            };
            singleResult.IneligibilityReasons.Add($"Error: {ex.Message}");

            Audit.LogMigrationCheck(currentUser, clientIpAddress, singleEmail.Trim(),
                "Error", singleTicketNumber, ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateSingleMigrationBatch()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!(await AuthorizationService.AuthorizeAsync(authState.User, "MigrationCreate")).Succeeded)
            return;

        if (singleResult == null || singleResult.Status != MigrationStatus.Eligible || string.IsNullOrWhiteSpace(singleTicketNumber))
            return;

        isCreating = true;
        singleCreateResult = null;

        try
        {
            var finalBatchName = string.IsNullOrWhiteSpace(singleBatchName)
                ? singleResult.EmailAddress
                : singleBatchName.Trim();

            singleCreateResult = await Exchange.CreateMigrationBatchAsync(
                singleMigrationDirection, new List<string> { singleResult.EmailAddress }, finalBatchName, singleAutoStart, singleAutoComplete);

            var ipAddress = clientIpAddress;

            try
            {
                Audit.LogMigrationBatch(currentUser, ipAddress, finalBatchName, singleMigrationDirection.ToString(),
                    1, singleAutoStart, singleAutoComplete, singleTicketNumber, singleCreateResult.Success, singleCreateResult.Message);
            }
            catch (Exception ex)
            {
                singleCreateResult = new PermissionResult
                {
                    Success = singleCreateResult.Success,
                    Message = singleCreateResult.Message,
                    Detail = $"Audit logging failed: {ex.Message}"
                };
            }

            await Email.SendAdminNotificationAsync(
                currentUser, ipAddress, $"CreateMigrationBatch_{singleMigrationDirection}", finalBatchName,
                singleResult.EmailAddress, $"AutoStart:{singleAutoStart} AutoComplete:{singleAutoComplete}",
                singleCreateResult.Success, singleTicketNumber, singleCreateResult.Success ? null : singleCreateResult.Message);
        }
        catch (Exception ex)
        {
            singleCreateResult = PermissionResult.Fail(ex.Message);
        }
        finally
        {
            isCreating = false;
        }
    }

    private void HandleCsvUpload(InputFileChangeEventArgs e)
    {
        csvFile = e.File;
        bulkResult = null;
        createResult = null;
    }

    private async Task CheckBulkEligibility()
    {
        if (csvFile == null)
            return;

        isLoading = true;
        bulkResult = null;
        createResult = null;

        try
        {
            using var stream = csvFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var memoryStream = new MemoryStream();
            await stream.CopyToAsync(memoryStream);
            memoryStream.Position = 0;

            bulkResult = await Exchange.CheckBulkMigrationEligibilityAsync(memoryStream, migrationDirection);

            var ipAddress = clientIpAddress;

            Audit.LogMigrationAction(currentUser, ipAddress,
                $"BulkEligibilityCheck_{migrationDirection}", csvFile.Name, true, bulkTicketNumber,
                $"{bulkResult.EligibleUsers}/{bulkResult.TotalUsers} eligible");

            try
            {
                await Email.SendAdminNotificationAsync(
                    currentUser, ipAddress, $"BulkMigrationEligibilityCheck_{migrationDirection}", "Bulk Operation", csvFile.Name,
                    $"{bulkResult.EligibleUsers}/{bulkResult.TotalUsers} eligible", true, bulkTicketNumber, null);
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Failed to send admin notification for bulk eligibility check");
            }
        }
        catch (Exception ex)
        {
            bulkResult = new MigrationBatchResult
            {
                BatchName = "Error",
                Success = false,
                Message = ex.Message,
                Direction = migrationDirection
            };

            Audit.LogMigrationAction(currentUser, clientIpAddress,
                $"BulkEligibilityCheck_{migrationDirection}", csvFile?.Name ?? "Unknown", false, bulkTicketNumber, ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CreateMigrationBatch()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (!(await AuthorizationService.AuthorizeAsync(authState.User, "MigrationCreate")).Succeeded)
            return;

        if (bulkResult == null || bulkResult.EligibleUsers == 0 || string.IsNullOrWhiteSpace(bulkTicketNumber))
            return;

        isCreating = true;
        createResult = null;

        try
        {
            var eligibleEmails = bulkResult.EligibilityResults
                .Where(r => r.Status == MigrationStatus.Eligible)
                .Select(r => r.EmailAddress)
                .ToList();

            var finalBatchName = string.IsNullOrWhiteSpace(bulkBatchName)
                ? $"{DateTime.Now:yyyy-MM-dd}_{(migrationDirection == MigrationDirection.ToCloud ? "Move" : "MoveBack")}"
                : bulkBatchName.Trim();

            createResult = await Exchange.CreateMigrationBatchAsync(
                migrationDirection, eligibleEmails, finalBatchName, bulkAutoStart, bulkAutoComplete);

            var ipAddress = clientIpAddress;

            try
            {
                Audit.LogMigrationBatch(currentUser, ipAddress, finalBatchName, migrationDirection.ToString(),
                    eligibleEmails.Count, bulkAutoStart, bulkAutoComplete, bulkTicketNumber, createResult.Success, createResult.Message);
            }
            catch (Exception ex)
            {
                createResult = new PermissionResult
                {
                    Success = createResult.Success,
                    Message = createResult.Message,
                    Detail = $"Audit logging failed: {ex.Message}"
                };
            }

            await Email.SendAdminNotificationAsync(
                currentUser, ipAddress, $"CreateMigrationBatch_{migrationDirection}", finalBatchName,
                $"{eligibleEmails.Count} users", $"AutoStart:{bulkAutoStart} AutoComplete:{bulkAutoComplete}",
                createResult.Success, bulkTicketNumber, createResult.Success ? null : createResult.Message);
        }
        catch (Exception ex)
        {
            createResult = PermissionResult.Fail(ex.Message);
        }
        finally
        {
            isCreating = false;
        }
    }

