    private void CompleteBatch(string name) => StageBatchAction("Complete Batch", name, t => ExecuteBatchAction(() => Exchange.CompleteMigrationBatchAsync(name), "CompleteMigrationBatch", name, t));
    private void CompleteUser(string email) => StageUserAction("Complete User", email, t => ExecuteUserAction(() => Exchange.CompleteMigrationUserAsync(email), "CompleteMigrationUser", email, t));
