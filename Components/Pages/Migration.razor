@page "/migration"
@using ExchangeAdminWeb.Models
@using ExchangeAdminWeb.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "MigrationCheck")]
@inject IExchangeService Exchange
@inject AuditService Audit
@inject EmailService Email
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject ClientInfoService ClientInfo
@inject IJSRuntime JS
@inject ILogger<ExchangeAdminWeb.Components.Pages.Migration> Logger
@rendermode InteractiveServer

<PageTitle>Exchange Migration</PageTitle>

<div class="container-fluid mt-4">
    <div class="alert alert-info py-2 mb-3"><small>Migration actions are logged for audit purposes, including eligibility checks, batch creation, and status changes.</small></div>
    <h2>Exchange Migration</h2>
    <p class="text-muted">Check migration eligibility and create migration batches to/from Exchange Online</p>

    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <a class="nav-link @(tabIndex == 0 ? "active" : "")" @onclick="() => tabIndex = 0" href="javascript:void(0)">Single User Check</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(tabIndex == 1 ? "active" : "")" @onclick="() => tabIndex = 1" href="javascript:void(0)">Bulk CSV Check</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(tabIndex == 2 ? "active" : "")" @onclick="LoadMigrationStatus" href="javascript:void(0)">Migration Status</a>
        </li>
    </ul>

    @if (tabIndex == 0)
    {
        <!-- Single User Check -->
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Check Single User Migration Eligibility</h5>

                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label class="form-label">Email Address</label>
                        <input type="email" class="form-control" @bind="singleEmail" placeholder="user@example.com" disabled="@isLoading" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Migration Direction</label>
                        <select class="form-select" @bind="singleMigrationDirection" disabled="@isLoading">
                            <option value="@MigrationDirection.ToCloud">To Exchange Online</option>
                            <option value="@MigrationDirection.ToOnPrem">To On-Premises</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Ticket Number</label>
                        <input type="text" class="form-control" @bind="singleTicketNumber" placeholder="INC0000000" disabled="@isLoading" required />
                    </div>
                </div>

                <button class="btn btn-primary" @onclick="CheckSingleEligibility" disabled="@(string.IsNullOrWhiteSpace(singleEmail) || string.IsNullOrWhiteSpace(singleTicketNumber) || isLoading)">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    Check Eligibility
                </button>

                @if (singleResult != null)
                {
                    <div class="alert @(singleResult.Status == MigrationStatus.Eligible ? "alert-success" : "alert-danger") mt-3">
                        @if (singleResult.Status == MigrationStatus.Eligible)
                        {
                            <p class="mb-0"><strong>@singleResult.EmailAddress IS eligible to migrate @(singleMigrationDirection == MigrationDirection.ToCloud ? "to Exchange Online" : "to On-Premises"). :)</strong></p>
                        }
                        else
                        {
                            <p class="mb-0"><strong>@singleResult.EmailAddress IS NOT eligible to migrate @(singleMigrationDirection == MigrationDirection.ToCloud ? "to Exchange Online" : "to On-Premises")</strong></p>
                            @if (singleResult.IneligibilityReasons.Any())
                            {
                                <hr />
                                <strong>Reasons:</strong>
                                <ul class="mb-0">
                                    @foreach (var reason in singleResult.IneligibilityReasons)
                                    {
                                        <li>@reason</li>
                                    }
                                </ul>
                            }
                        }
                        @if (singleResult.MailboxSizeGB > 0 || singleResult.ArchiveSizeGB > 0)
                        {
                            <p class="mb-1">
                                <strong>Mailbox:</strong> @singleResult.MailboxSizeGB.ToString("F2") GB
                                @if (singleResult.ArchiveSizeGB > 0)
                                {
                                    <text> | <strong>Archive:</strong> @singleResult.ArchiveSizeGB.ToString("F2") GB</text>
                                }
                                | <strong>Total:</strong> @singleResult.TotalSizeGB.ToString("F2") GB
                            </p>
                        }
                        @if (singleResult.ExceedsQuota)
                        {
                            <p class="mb-0 text-warning"><strong>Mailbox + archive (@singleResult.TotalSizeGB.ToString("F2") GB) exceeds @singleResult.CloudQuotaGB GB cloud quota</strong></p>
                        }
                    </div>

                    @if (singleResult.Status == MigrationStatus.Eligible)
                    {
                        <div class="card mt-3 border-success">
                            <div class="card-body">
                                <h6>Create Migration Batch</h6>
                                <p class="text-muted">User is eligible to migrate @(singleMigrationDirection == MigrationDirection.ToCloud ? "to Exchange Online" : "to On-Premises")</p>

                                <div class="row g-3 mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Batch Name (optional)</label>
                                        <input type="text" class="form-control" @bind="singleBatchName" placeholder="@singleResult.EmailAddress" disabled="@isCreating" />
                                        <small class="text-muted">Leave empty to use email address as batch name</small>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Options</label>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" @bind="singleAutoStart" disabled="@isCreating" id="singleAutoStartCheck" />
                                            <label class="form-check-label" for="singleAutoStartCheck">Auto-start migration immediately</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" @bind="singleAutoComplete" disabled="@isCreating" id="singleAutoCompleteCheck" />
                                            <label class="form-check-label" for="singleAutoCompleteCheck">Auto-complete migration when synced</label>
                                        </div>
                                    </div>
                                </div>

                                @if (canCreate)
                                {
                                    <button class="btn btn-success" @onclick="CreateSingleMigrationBatch" disabled="@isCreating">
                                        @if (isCreating)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2"></span>
                                        }
                                        Create Migration Batch
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    @if (singleCreateResult != null)
                    {
                        <div class="alert @(singleCreateResult.Success ? "alert-success" : "alert-danger") mt-3">
                            <strong>@(singleCreateResult.Success ? "✓" : "✗") @singleCreateResult.Message</strong>
                            @if (!string.IsNullOrWhiteSpace(singleCreateResult.Detail))
                            {
                                <p class="mb-0 mt-2">@singleCreateResult.Detail</p>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    }
    else if (tabIndex == 1)
    {
        <!-- Bulk CSV Check -->
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Bulk Migration Eligibility Check</h5>
                <p class="text-muted">Upload a CSV file with EmailAddress column to check migration eligibility for multiple users.</p>

                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label class="form-label">CSV File (EmailAddress column required)</label>
                        <InputFile class="form-control" OnChange="HandleCsvUpload" disabled="@isLoading" accept=".csv" />
                        <button type="button" class="btn btn-outline-secondary btn-sm mt-1" @onclick="DownloadSampleCsv">Sample CSV</button>
                        <small class="text-muted d-block mt-1">Format: EmailAddress<br />user1@example.com<br />user2@example.com</small>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Migration Direction</label>
                        <select class="form-select" @bind="migrationDirection" disabled="@isLoading">
                            <option value="@MigrationDirection.ToCloud">To Exchange Online</option>
                            <option value="@MigrationDirection.ToOnPrem">To On-Premises</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Ticket Number</label>
                        <input type="text" class="form-control" @bind="bulkTicketNumber" placeholder="INC0000000" disabled="@isLoading" required />
                    </div>
                </div>

                <button class="btn btn-primary" @onclick="CheckBulkEligibility" disabled="@(csvFile == null || string.IsNullOrWhiteSpace(bulkTicketNumber) || isLoading)">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    Check All
                </button>

                @if (bulkResult != null)
                {
                    <div class="alert alert-info mt-3">
                        <h6>Eligibility Check Results</h6>
                        <p class="mb-0">
                            <strong>Total Users:</strong> @bulkResult.TotalUsers |
                            <strong>Eligible:</strong> <span class="text-success">@bulkResult.EligibleUsers</span> |
                            <strong>Ineligible:</strong> <span class="text-danger">@bulkResult.IneligibleUsers</span>
                        </p>
                    </div>

                    <div class="table-responsive mt-3">
                        <table class="table table-sm table-striped">
                            <thead>
                                <tr>
                                    <th>Email Address</th>
                                    <th>Status</th>
                                    <th>Reasons / Notes</th>
                                    <th>Size (GB)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in bulkResult.EligibilityResults)
                                {
                                    <tr class="@(item.Status == MigrationStatus.Eligible ? "table-success" : "table-danger")">
                                        <td>@item.EmailAddress</td>
                                        <td><strong>@item.Status</strong></td>
                                        <td>
                                            @if (item.IneligibilityReasons.Any())
                                            {
                                                <ul class="mb-0">
                                                    @foreach (var reason in item.IneligibilityReasons)
                                                    {
                                                        <li>@reason</li>
                                                    }
                                                </ul>
                                            }
                                            else
                                            {
                                                <span class="text-success">✓ Ready to migrate</span>
                                            }
                                        </td>
                                        <td>
                                            @if (item.ExceedsQuota)
                                            {
                                                <span class="text-warning">@item.TotalSizeGB.ToString("F2") GB (exceeds quota)</span>
                                            }
                                            else if (item.MailboxSizeGB > 0)
                                            {
                                                <span>@item.MailboxSizeGB.ToString("F2") GB</span>
                                                @if (item.ArchiveSizeGB > 0)
                                                {
                                                    <text> + @item.ArchiveSizeGB.ToString("F2") GB archive</text>
                                                }
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (bulkResult.EligibleUsers > 0)
                    {
                        <div class="card mt-3 border-success">
                            <div class="card-body">
                                <h6>Create Migration Batch</h6>
                                <p class="text-muted">@bulkResult.EligibleUsers user(s) eligible to migrate @(migrationDirection == MigrationDirection.ToCloud ? "to Exchange Online" : "to On-Premises")</p>

                                <div class="row g-3 mb-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Batch Name (optional)</label>
                                        <input type="text" class="form-control" @bind="bulkBatchName" placeholder="@($"{DateTime.Now:yyyy-MM-dd}_{(migrationDirection == MigrationDirection.ToCloud ? "Move" : "MoveBack")}")" disabled="@isCreating" />
                                        <small class="text-muted">Leave empty to use date and direction (e.g., @($"{DateTime.Now:yyyy-MM-dd}_{(migrationDirection == MigrationDirection.ToCloud ? "Move" : "MoveBack")}"))</small>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Options</label>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" @bind="bulkAutoStart" disabled="@isCreating" id="bulkAutoStartCheck" />
                                            <label class="form-check-label" for="bulkAutoStartCheck">Auto-start migration immediately</label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" @bind="bulkAutoComplete" disabled="@isCreating" id="bulkAutoCompleteCheck" />
                                            <label class="form-check-label" for="bulkAutoCompleteCheck">Auto-complete migration when synced</label>
                                        </div>
                                    </div>
                                </div>

                                @if (canCreate)
                                {
                                    <button class="btn btn-success" @onclick="CreateMigrationBatch" disabled="@isCreating">
                                        @if (isCreating)
                                        {
                                            <span class="spinner-border spinner-border-sm me-2"></span>
                                        }
                                        Create Migration Batch
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    @if (createResult != null)
                    {
                        <div class="alert @(createResult.Success ? "alert-success" : "alert-danger") mt-3">
                            <strong>@(createResult.Success ? "✓" : "✗") @createResult.Message</strong>
                            @if (!string.IsNullOrWhiteSpace(createResult.Detail))
                            {
                                <p class="mb-0 mt-2">@createResult.Detail</p>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    }
    else if (tabIndex == 2)
    {
        <!-- Migration Status -->
        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="card-title mb-0">Migration Batches</h5>
                    <div class="d-flex align-items-center gap-2">
                        <div class="input-group input-group-sm" style="width: 280px;">
                            <input type="text" class="form-control" placeholder="Search batch or user email..."
                                   @bind="searchQuery" @bind:event="oninput"
                                   @onkeydown="HandleSearchKeyDown" />
                            @if (!string.IsNullOrWhiteSpace(searchQuery))
                            {
                                <button class="btn btn-outline-secondary" type="button" @onclick="ClearSearch" title="Clear">
                                    &times;
                                </button>
                            }
                            <button class="btn btn-outline-primary" type="button" @onclick="SearchUser"
                                    disabled="@(isSearching || string.IsNullOrWhiteSpace(searchQuery))">
                                @if (isSearching)
                                {
                                    <span class="spinner-border spinner-border-sm"></span>
                                }
                                else
                                {
                                    <span>Find</span>
                                }
                            </button>
                        </div>
                    </div>
                    <div>
                        @if (canManage && migrationBatches?.Any(b => b.Status.Equals("Completed", StringComparison.OrdinalIgnoreCase)
                            || (b.TotalCount == 0)) == true)
                        {
                            <button class="btn btn-sm btn-outline-secondary me-2" disabled="@(actionInProgress != null || pendingActionLabel != null)"
                                    @onclick="StageClearCompleted">
                                Clear Completed
                            </button>
                        }
                        <button class="btn btn-sm btn-primary" @onclick="LoadMigrationStatus" disabled="@isLoadingStatus">
                            @if (isLoadingStatus)
                            {
                                <span class="spinner-border spinner-border-sm me-2"></span>
                            }
                            Refresh
                        </button>
                    </div>
                </div>

                @if (batchActionResult != null)
                {
                    <div class="alert alert-@(batchActionResult.Success ? "success" : "danger") alert-dismissible fade show">
                        @batchActionResult.Message
                        @if (!string.IsNullOrEmpty(batchActionResult.Detail))
                        {
                            <div class="mt-1"><small>@batchActionResult.Detail</small></div>
                        }
                        <button type="button" class="btn-close" @onclick="() => batchActionResult = null"></button>
                    </div>
                }

                @if (pendingActionLabel != null)
                {
                    <div class="alert alert-warning d-flex align-items-center gap-2 mb-3">
                        <strong>@pendingActionLabel</strong> <span class="text-muted">@pendingActionTarget</span>
                        <div class="input-group input-group-sm" style="width: 220px;">
                            <input type="text" class="form-control" placeholder="Ticket # (required)"
                                   @bind="pendingActionTicket" @bind:event="oninput"
                                   @onkeydown="HandleConfirmKeyDown" />
                        </div>
                        <button class="btn btn-sm btn-primary" @onclick="ConfirmPendingAction"
                                disabled="@(string.IsNullOrWhiteSpace(pendingActionTicket) || actionInProgress != null)">
                            @if (actionInProgress != null)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                            }
                            else
                            {
                                <span>Confirm</span>
                            }
                        </button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="CancelPendingAction"
                                disabled="@(actionInProgress != null)">Cancel</button>
                    </div>
                }

                @if (isLoadingStatus)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="mt-2 text-muted">@(actionInProgress == "clearing" ? "Removing completed batches and reloading..." : "Loading migration batches...")</p>
                    </div>
                }
                else if (!batchesLoaded)
                {
                    <div class="text-center py-5">
                        <button class="btn btn-primary" @onclick="LoadMigrationStatus">
                            Load Migration Batches
                        </button>
                    </div>
                }
                else if ((migrationBatches == null || !migrationBatches.Any()) && batchActionResult == null)
                {
                    <div class="alert alert-info">
                        <strong>No migration batches found</strong>
                        <p class="mb-0 mt-2">There are currently no migration batches. Create one using the Single User Check or Bulk CSV Check tabs.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th role="button" @onclick='() => ToggleBatchSort("Name")'>Batch Name @SortIndicator("Name")</th>
                                    <th role="button" @onclick='() => ToggleBatchSort("Status")'>Status @SortIndicator("Status")</th>
                                    <th role="button" @onclick='() => ToggleBatchSort("Direction")'>Direction @SortIndicator("Direction")</th>
                                    <th role="button" @onclick='() => ToggleBatchSort("Created")'>Created @SortIndicator("Created")</th>
                                    <th role="button" class="text-center" @onclick='() => ToggleBatchSort("Total")'>Total @SortIndicator("Total")</th>
                                    <th role="button" class="text-center" @onclick='() => ToggleBatchSort("Synced")'>Synced @SortIndicator("Synced")</th>
                                    <th role="button" class="text-center" @onclick='() => ToggleBatchSort("Failed")'>Failed @SortIndicator("Failed")</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var batch in GetSortedBatches())
                                {
                                    <tr class="@(expandedBatch == batch.BatchName && highlightedUser == null ? "table-info" : "")">
                                        <td>
                                            <strong>@batch.BatchName</strong>
                                        </td>
                                        <td>
                                            <span class="badge bg-@GetStatusColor(batch.Status)">@batch.Status</span>
                                        </td>
                                        <td>
                                            <span class="badge bg-secondary">@batch.Direction</span>
                                        </td>
                                        <td>
                                            <small>@batch.CreatedDateTime.ToLocalTime().ToString("MMM dd, HH:mm")</small>
                                        </td>
                                        <td class="text-center">@batch.TotalCount</td>
                                        <td class="text-center"><span class="text-success fw-bold">@batch.SyncedCount</span></td>
                                        <td class="text-center">
                                            @if (batch.FailedCount > 0)
                                            {
                                                <span class="text-danger fw-bold">@batch.FailedCount</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">0</span>
                                            }
                                        </td>
                                        <td class="text-end text-nowrap">
                                            @if (canManage && batch.Status.Equals("Synced", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <button class="btn btn-sm btn-success me-1" disabled="@(actionInProgress != null || pendingActionLabel != null)"
                                                        @onclick="() => CompleteBatch(batch.BatchName)">
                                                    Complete
                                                </button>
                                            }
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => ToggleBatchDetails(batch.BatchName)">
                                                @if (expandedBatch == batch.BatchName && batchUsers != null)
                                                {
                                                    <span>Hide</span>
                                                }
                                                else if (loadingBatchUsers == batch.BatchName)
                                                {
                                                    <span class="spinner-border spinner-border-sm"></span>
                                                }
                                                else
                                                {
                                                    <span>Details</span>
                                                }
                                            </button>
                                            @if (expandedBatch == batch.BatchName && batchUsers != null)
                                            {
                                                <button class="btn btn-sm btn-outline-secondary ms-1" title="Refresh batch users"
                                                        disabled="@(loadingBatchUsers != null)"
                                                        @onclick="() => RefreshBatchUsers(batch.BatchName)">
                                                    @if (loadingBatchUsers == batch.BatchName)
                                                    {
                                                        <span class="spinner-border spinner-border-sm"></span>
                                                    }
                                                    else
                                                    {
                                                        <span>&#x21bb;</span>
                                                    }
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                    @if (expandedBatch == batch.BatchName && batchUsers != null)
                                    {
                                        <tr>
                                            <td colspan="8" class="p-0">
                                                <div class="bg-light p-3 border-top">
                                                    <div class="row mb-3">
                                                        <div class="col-md-12">
                                                            <small class="text-muted d-block">
                                                                <strong>Created:</strong> @batch.CreatedDateTime.ToLocalTime().ToString("MMM dd, yyyy HH:mm")
                                                                @if (batch.StartDateTime.HasValue)
                                                                {
                                                                    <span class="ms-3"><strong>Started:</strong> @batch.StartDateTime.Value.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</span>
                                                                }
                                                                @if (batch.CompletedDateTime.HasValue)
                                                                {
                                                                    <span class="ms-3"><strong>Completed:</strong> @batch.CompletedDateTime.Value.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</span>
                                                                }
                                                            </small>
                                                        </div>
                                                    </div>
                                                    @if (batchUsers.Any())
                                                    {
                                                        <table class="table table-sm table-bordered bg-white mb-0">
                                                            <thead class="table-light">
                                                                <tr>
                                                                    <th>Email</th>
                                                                    <th>Status</th>
                                                                    <th>Synced</th>
                                                                    <th>Last Sync</th>
                                                                    <th>Error</th>
                                                                    <th></th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var user in batchUsers)
                                                                {
                                                                    <tr class="@(highlightedUser != null && user.EmailAddress.Contains(highlightedUser, StringComparison.OrdinalIgnoreCase) ? "table-warning" : "")">
                                                                        <td>@user.EmailAddress</td>
                                                                        <td><span class="badge bg-@GetUserStatusColor(user.Status)">@user.Status</span></td>
                                                                        <td>@user.ItemsSynced.ToString("N0")</td>
                                                                        <td><small>@(user.LastSyncDateTime?.ToLocalTime().ToString("MMM dd HH:mm") ?? "-")</small></td>
                                                                        <td>
                                                                            @if (!string.IsNullOrEmpty(user.ErrorSummary))
                                                                            {
                                                                                <small class="text-danger">@user.ErrorSummary</small>
                                                                            }
                                                                            else
                                                                            {
                                                                                <small class="text-muted">-</small>
                                                                            }
                                                                        </td>
                                                                        <td class="text-end text-nowrap">
                                                                            @{ var s = user.Status; var e = user.EmailAddress; }
                                                                            @if (canManage)
                                                                            {
                                                                                @if (s.Equals("Synced", StringComparison.OrdinalIgnoreCase))
                                                                                {
                                                                                    <button class="btn btn-sm btn-success me-1" disabled="@(actionInProgress != null || pendingActionLabel != null)"
                                                                                            @onclick="() => CompleteUser(e)">Complete</button>
                                                                                }
                                                                                @if (s.Equals("NeedsApproval", StringComparison.OrdinalIgnoreCase))
                                                                                {
                                                                                    <button class="btn btn-sm btn-warning me-1" disabled="@(actionInProgress != null || pendingActionLabel != null)"
                                                                                            @onclick="() => ApproveUser(e)">Approve</button>
                                                                                }
                                                                                @if (s.Equals("Syncing", StringComparison.OrdinalIgnoreCase))
                                                                                {
                                                                                    <button class="btn btn-sm btn-outline-warning me-1" disabled="@(actionInProgress != null || pendingActionLabel != null)"
                                                                                            @onclick="() => PauseUser(e)">Pause</button>
                                                                                }
                                                                                @if (s.Equals("Stopped", StringComparison.OrdinalIgnoreCase)
                                                                                    || s.Equals("Failed", StringComparison.OrdinalIgnoreCase))
                                                                                {
                                                                                    <button class="btn btn-sm btn-primary me-1" disabled="@(actionInProgress != null || pendingActionLabel != null)"
                                                                                            @onclick="() => ResumeUser(e)">Resume</button>
                                                                                }
                                                                                @if (s.Equals("Completed", StringComparison.OrdinalIgnoreCase))
                                                                                {
                                                                                    <button class="btn btn-sm btn-outline-secondary me-1" disabled="@(actionInProgress != null || pendingActionLabel != null)"
