@page "/group-management"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "GroupManagement")]
@rendermode InteractiveServer
@inject GroupManagementService GroupService
@inject AuditService Audit
@inject EmailService Email
@inject ServiceNowService ServiceNow
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject ClientInfoService ClientInfo
@inject ILogger<GroupManagement> Logger

<PageTitle>Group Management</PageTitle>

@if (!authChecked)
{
    <div class="container-fluid">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    </div>
    return;
}

<div class="container-fluid">
    <h1 class="mb-4">Group Management<ModuleVersion /></h1>

    <div class="row mb-3">
        <div class="col-md-6">
            <div class="input-group">
                <input type="text" class="form-control" placeholder="Search groups by name or email..."
                       value="@searchTerm"
                       @oninput="(e) => searchTerm = e.Value?.ToString() ?? string.Empty"
                       @onkeydown="HandleSearchKey" disabled="@isLoading" />
                <button class="btn btn-primary" @onclick="Search" disabled="@(isLoading || string.IsNullOrWhiteSpace(searchTerm))">
                    @if (isLoading && selectedGroup == null) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Search
                </button>
            </div>
        </div>
    </div>

    @if (searchResults.Count > 0)
    {
        <div class="row mb-3">
            <div class="col-md-8">
                <table class="table table-sm table-hover">
                    <thead><tr><th>Name</th><th>Email</th><th>Type</th><th></th></tr></thead>
                    <tbody>
                        @foreach (var group in searchResults)
                        {
                            var g = group;
                            <tr>
                                <td>@g.Name</td>
                                <td><small>@g.Email</small></td>
                                <td><span class="badge bg-light text-dark border">@g.GroupType</span></td>
                                <td><button class="btn btn-outline-primary btn-sm" @onclick="() => SelectGroup(g)">Manage</button></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @if (selectedGroup != null)
    {
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <strong>@selectedGroup.Name</strong>
                    <small class="text-muted ms-2">@selectedGroup.Email</small>
                </div>
                <button class="btn btn-outline-secondary btn-sm" @onclick="() => { selectedGroup = null; memberList = null; }">Close</button>
            </div>
            <div class="card-body">
                @if (!canManageOnPrem)
                {
                    <div class="alert alert-warning mb-3">
                        You do not have permission to modify on-premises AD groups. Contact the Exchange team.
                    </div>
                }

                @if (memberList == null)
                {
                    <button class="btn btn-primary btn-sm" @onclick="LoadMembers" disabled="@isLoading">
                        @if (isLoading) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Load Members
                    </button>
                }
                else if (memberList.Error != null)
                {
                    <div class="alert alert-danger">@memberList.Error</div>
                }
                else
                {
                    <p class="text-muted mb-2"><small>@memberList.Members.Count member(s)</small></p>

                    @if (canManageOnPrem)
                    {
                        <div class="row g-2 mb-3">
                            <div class="col-auto">
                                <input type="text" class="form-control form-control-sm" placeholder="Ticket #" @bind="ticketNumber" @bind:event="oninput" disabled="@isLoading" style="width: 140px;" />
                            </div>
                            <div class="col">
                                <div class="input-group input-group-sm">
                                    <div class="flex-grow-1">
                                        <RecipientAutocomplete @bind-Value="newMember"
                                                               Placeholder="user@domain.com"
                                                               Disabled="@isLoading" />
                                    </div>
                                    <button class="btn btn-success" @onclick="AddMember" disabled="@(isLoading || string.IsNullOrWhiteSpace(newMember) || string.IsNullOrWhiteSpace(ticketNumber))">Add</button>
                                </div>
                            </div>
                        </div>
                    }

                    @if (opResult != null)
                    {
                        <div class="alert @(opResult.Success ? "alert-success" : "alert-danger") alert-dismissible py-2">
                            <small>@opResult.Message</small>
                            <button type="button" class="btn-close btn-close-sm" @onclick="() => opResult = null"></button>
                        </div>
                    }

                    <div style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-sm">
                            <thead><tr><th>Name</th><th>Email</th><th></th></tr></thead>
                            <tbody>
                                @foreach (var m in memberList.Members)
                                {
                                    var member = m;
                                    <tr>
                                        <td>@member.DisplayName</td>
                                        <td><small>@member.Email</small></td>
                                        <td>
                                            @if (canManageOnPrem)
                                            {
                                                <button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveMember(member.Email)" disabled="@(isLoading || string.IsNullOrWhiteSpace(ticketNumber))">Remove</button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private string currentUser = "";
    private string clientIpAddress = "Unknown";
    private bool authChecked;
    private bool isLoading;
    private bool canManageOnPrem;
    private string searchTerm = "";
    private string newMember = "";
    private string ticketNumber = "";
    private List<GroupInfo> searchResults = new();
    private GroupInfo? selectedGroup;
    private GroupMemberList? memberList;
    private PermissionResult? opResult;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUser = user.Identity?.Name ?? "Unknown";

        var authResult = await AuthorizationService.AuthorizeAsync(user, "GroupManagement");
        if (!authResult.Succeeded)
        {
            Navigation.NavigateTo("access-denied", forceLoad: true);
            return;
        }

        var onPremAuth = await AuthorizationService.AuthorizeAsync(user, "GroupManagementOnPrem");
        canManageOnPrem = onPremAuth.Succeeded;

        clientIpAddress = ClientInfo.IpAddress != "Unknown"
            ? ClientInfo.IpAddress
            : ClientInfo.GetIpForUser(currentUser);
        authChecked = true;
    }

    private async Task HandleSearchKey(KeyboardEventArgs e)
    {
        // Await (never discard) so Blazor re-renders when the search completes;
        // a discarded task left results invisible until the next UI event.
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(searchTerm))
            await Search();
    }

    private async Task Search()
    {
        isLoading = true;
        selectedGroup = null;
        memberList = null;
        opResult = null;
        await Task.Yield();

        try
        {
            searchResults = await GroupService.SearchGroupsAsync(searchTerm.Trim());
        }
        catch (Exception ex)
        {
            opResult = PermissionResult.Fail(ex.Message);
        }
        finally { isLoading = false; }
    }

    private void SelectGroup(GroupInfo group)
    {
        selectedGroup = group;
        memberList = null;
        opResult = null;
        newMember = "";
    }

    private async Task LoadMembers()
    {
        isLoading = true;
        await Task.Yield();
        try
        {
            memberList = await GroupService.GetMembersAsync(selectedGroup!.Identity, selectedGroup.SamAccountName);
        }
        catch (Exception ex)
        {
            memberList = new GroupMemberList { GroupName = selectedGroup!.Name, Error = ex.Message };
        }
        finally { isLoading = false; }
    }

    private async Task AddMember()
    {
        isLoading = true;
        opResult = null;
        await Task.Yield();
        try
        {
            var ticket = ticketNumber.Trim();
            var ticketValidation = await ServiceNow.ValidateTicketAsync(ticket);
            if (!ticketValidation.IsValid)
            {
                opResult = PermissionResult.Fail($"Ticket validation failed: {ticketValidation.Message}");
                try { Audit.LogModuleAction(currentUser, clientIpAddress, "GroupManagement_AddMember", "GroupManagement", selectedGroup!.Name, false, ticket, $"Ticket validation failed: {ticketValidation.Message}", new Dictionary<string, object?> { ["member"] = newMember.Trim() }); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for GroupManagement_AddMember ticket denial"); }
                return;
            }

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var authCheck = await AuthorizationService.AuthorizeAsync(authState.User, "GroupManagementOnPrem");
            if (!authCheck.Succeeded)
            {
                opResult = PermissionResult.Fail("Authorization denied.");
                try { Audit.LogModuleAction(currentUser, clientIpAddress, "GroupManagement_AddMember", "GroupManagement", selectedGroup!.Name, false, ticket, "Authorization denied", new Dictionary<string, object?> { ["member"] = newMember.Trim() }); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for GroupManagement_AddMember auth denial"); }
                return;
            }

            // Protected-principal enforcement lives in GroupManagementService.AddMemberAsync
            // (CheckProtectedAsync): it fails closed on Unavailable/Ambiguous resolution and
            // covers non-'@' identities the old page gate missed. The page no longer
            // pre-checks — that duplicated gate produced unaudited failed mutation attempts
            // (2026-06-17 review). The single audited path below records every denial.
            opResult = await GroupService.AddMemberAsync(selectedGroup!.Identity, newMember.Trim(), selectedGroup.SamAccountName);

            try { Audit.LogModuleAction(currentUser, clientIpAddress, "GroupManagement_AddMember", "GroupManagement", selectedGroup.Name, opResult.Success, ticket, opResult.Success ? null : opResult.Message, new Dictionary<string, object?> { ["member"] = newMember.Trim() }); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for GroupManagement_AddMember"); }
            try { await Email.SendAdminNotificationAsync(currentUser, clientIpAddress, "GroupManagement_AddMember", opResult.Success, ticket, new Dictionary<string, string> { ["Group"] = selectedGroup.Name, ["Member Added"] = newMember.Trim() }, opResult.Success ? null : opResult.Message); } catch { }

            if (opResult.Success)
            {
                newMember = "";
                memberList = await GroupService.GetMembersAsync(selectedGroup.Identity, selectedGroup.SamAccountName);
            }
        }
        catch (Exception ex)
        {
            opResult = PermissionResult.Fail(ex.Message);
            try { Audit.LogModuleAction(currentUser, clientIpAddress, "GroupManagement_AddMember", "GroupManagement", selectedGroup!.Name, false, ticketNumber.Trim(), ex.Message, new Dictionary<string, object?> { ["member"] = newMember.Trim() }); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for GroupManagement_AddMember"); }
            try { await Email.SendAdminNotificationAsync(currentUser, clientIpAddress, "GroupManagement_AddMember", false, ticketNumber.Trim(), new Dictionary<string, string> { ["Group"] = selectedGroup!.Name, ["Member"] = newMember.Trim() }, ex.Message); } catch { }
        }
        finally { isLoading = false; }
    }

    private async Task RemoveMember(string member)
    {
        isLoading = true;
        opResult = null;
        await Task.Yield();
        try
        {
            var ticket = ticketNumber.Trim();
            var ticketValidation = await ServiceNow.ValidateTicketAsync(ticket);
            if (!ticketValidation.IsValid)
            {
                opResult = PermissionResult.Fail($"Ticket validation failed: {ticketValidation.Message}");
                try { Audit.LogModuleAction(currentUser, clientIpAddress, "GroupManagement_RemoveMember", "GroupManagement", selectedGroup!.Name, false, ticket, $"Ticket validation failed: {ticketValidation.Message}", new Dictionary<string, object?> { ["member"] = member }); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for GroupManagement_RemoveMember ticket denial"); }
                return;
            }

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var authCheck = await AuthorizationService.AuthorizeAsync(authState.User, "GroupManagementOnPrem");
            if (!authCheck.Succeeded)
            {
                opResult = PermissionResult.Fail("Authorization denied.");
                try { Audit.LogModuleAction(currentUser, clientIpAddress, "GroupManagement_RemoveMember", "GroupManagement", selectedGroup!.Name, false, ticket, "Authorization denied", new Dictionary<string, object?> { ["member"] = member }); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for GroupManagement_RemoveMember auth denial"); }
                return;
            }

            // Protected-principal enforcement lives in GroupManagementService.RemoveMemberAsync
            // (CheckProtectedAsync): it fails closed on Unavailable/Ambiguous resolution and
            // covers non-'@' identities the old page gate missed. The page no longer
            // pre-checks — that duplicated gate produced unaudited failed mutation attempts
            // (2026-06-17 review). The single audited path below records every denial.
            opResult = await GroupService.RemoveMemberAsync(selectedGroup!.Identity, member, selectedGroup.SamAccountName);

            try { Audit.LogModuleAction(currentUser, clientIpAddress, "GroupManagement_RemoveMember", "GroupManagement", selectedGroup.Name, opResult.Success, ticket, opResult.Success ? null : opResult.Message, new Dictionary<string, object?> { ["member"] = member }); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for GroupManagement_RemoveMember"); }
            try { await Email.SendAdminNotificationAsync(currentUser, clientIpAddress, "GroupManagement_RemoveMember", opResult.Success, ticket, new Dictionary<string, string> { ["Group"] = selectedGroup.Name, ["Member Removed"] = member }, opResult.Success ? null : opResult.Message); } catch { }

            if (opResult.Success)
                memberList = await GroupService.GetMembersAsync(selectedGroup.Identity, selectedGroup.SamAccountName);
        }
        catch (Exception ex)
        {
            opResult = PermissionResult.Fail(ex.Message);
            try { Audit.LogModuleAction(currentUser, clientIpAddress, "GroupManagement_RemoveMember", "GroupManagement", selectedGroup!.Name, false, ticketNumber.Trim(), ex.Message, new Dictionary<string, object?> { ["member"] = member }); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for GroupManagement_RemoveMember"); }
            try { await Email.SendAdminNotificationAsync(currentUser, clientIpAddress, "GroupManagement_RemoveMember", false, ticketNumber.Trim(), new Dictionary<string, string> { ["Group"] = selectedGroup!.Name, ["Member"] = member }, ex.Message); } catch { }
        }
        finally { isLoading = false; }
    }
}
