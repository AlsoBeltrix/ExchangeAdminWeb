@page "/admin-settings"
@using Microsoft.AspNetCore.Authorization
@using ExchangeAdminWeb.Modules
@attribute [Authorize(Policy = "AdminSettings")]
@rendermode InteractiveServer
@inject AuditService Audit
@inject ExtendedLogService ExtendedLog
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject ClientInfoService ClientInfo
@inject ILogger<AdminSettings> Logger
@inject ModuleCatalog Catalog
@inject ModuleEnablementService Enablement

<PageTitle>Admin Settings</PageTitle>

@if (!authChecked)
{
    <div class="container-fluid">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Checking authorization...</span>
            </div>
        </div>
    </div>
    return;
}

<div class="container-fluid">
    <h1 class="mb-4">Admin Settings</h1>

    <div class="alert alert-info mb-4">
        <strong>Enable or disable modules.</strong>
        Per-module section access and configuration are managed on each module's config page (see sidebar links).
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert @(statusIsError ? "alert-danger" : "alert-success") alert-dismissible fade show">
            @statusMessage
            <button type="button" class="btn-close" @onclick="() => statusMessage = null"></button>
        </div>
    }

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Module Enablement</strong>
            <button class="btn btn-primary btn-sm" @onclick="SaveEnablement" disabled="@saving">Save Enablement</button>
        </div>
        <div class="card-body">
            <div class="row g-2">
                @foreach (var module in Catalog.GetOrdered())
                {
                    var moduleId = module.Id;
                    <div class="col-md-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="enable-@moduleId"
                                   checked="@moduleEnablement[moduleId]"
                                   disabled="@module.IsSystemModule"
                                   @onchange="(e) => moduleEnablement[moduleId] = (bool)(e.Value ?? false)" />
                            <label class="form-check-label" for="enable-@moduleId">
                                @module.DisplayName
                                @if (module.IsSystemModule) { <span class="text-muted">(system)</span> }
                            </label>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Extended Logging</strong>
            <button class="btn btn-primary btn-sm" @onclick="SaveLogLevel" disabled="@saving">Save</button>
        </div>
        <div class="card-body">
            <p class="text-muted mb-3"><small>Controls the detail level of extended diagnostic logs. Admin audit logging (event log) is always active regardless of this setting. Extended logs are written to a separate file and viewable from the Event Log page.</small></p>
            <div class="row align-items-center">
                <div class="col-auto">
                    <label class="form-label mb-0 fw-semibold">Log Level</label>
                </div>
                <div class="col-auto">
                    <select class="form-select form-select-sm" style="width: 150px;" @bind="selectedLogLevel">
                        <option value="None">None</option>
                        <option value="Error">Error</option>
                        <option value="Warning">Warning</option>
                        <option value="Information">Info</option>
                        <option value="Debug">Debug</option>
                    </select>
                </div>
                <div class="col-auto">
                    <small class="text-muted">Current: @ExtendedLog.CurrentLevel</small>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string currentUser = string.Empty;
    private bool authChecked;
    private bool saving;
    private string? statusMessage;
    private bool statusIsError;

    private Dictionary<string, bool> moduleEnablement = new();
    private string selectedLogLevel = "None";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUser = user.Identity?.Name ?? "Unknown";

        var authResult = await AuthorizationService.AuthorizeAsync(user, "AdminSettings");
        if (!authResult.Succeeded)
        {
            Navigation.NavigateTo("access-denied", forceLoad: true);
            return;
        }

        moduleEnablement = Enablement.GetAllEnablement();
        selectedLogLevel = ExtendedLog.CurrentLevel;
        authChecked = true;
    }

    private async Task SaveEnablement()
    {
        saving = true;
        statusMessage = null;
        await Task.Yield();

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var authResult = await AuthorizationService.AuthorizeAsync(authState.User, "AdminSettings");
            if (!authResult.Succeeded)
            {
                statusMessage = "Authorization check failed.";
                statusIsError = true;
                return;
            }

            var previous = Enablement.GetAllEnablement();
            Enablement.SaveEnablement(moduleEnablement);

            var ip = ClientInfo.GetIpForUser(currentUser);
            foreach (var module in Catalog.GetAll().Where(m => !m.IsSystemModule))
            {
                var prev = previous.GetValueOrDefault(module.Id, module.EnabledByDefault);
                var curr = moduleEnablement.GetValueOrDefault(module.Id, module.EnabledByDefault);
                if (prev != curr)
                {
                    try
                    {
                        Audit.LogSettingsChange(currentUser, ip, $"Module:{module.Id}",
                            prev ? new[] { "Enabled" } : Array.Empty<string>(),
                            curr ? new[] { "Enabled" } : Array.Empty<string>());
                    }
                    catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for enablement change"); }
                }
            }

            statusMessage = "Module enablement saved. Refreshing...";
            statusIsError = false;
            await Task.Delay(500);
            Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
        }
        catch (Exception ex)
        {
            statusMessage = $"Failed to save: {ex.Message}";
            statusIsError = true;
        }
        finally
        {
            saving = false;
        }
    }

    private async Task SaveLogLevel()
    {
        saving = true;
        statusMessage = null;
        await Task.Yield();

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var authResult = await AuthorizationService.AuthorizeAsync(authState.User, "AdminSettings");
            if (!authResult.Succeeded)
            {
                statusMessage = "Authorization check failed.";
                statusIsError = true;
                return;
            }

            var previousLevel = ExtendedLog.CurrentLevel;
            ExtendedLog.SetLevel(selectedLogLevel);

            var ip = ClientInfo.GetIpForUser(currentUser);
            try { Audit.LogSettingsChange(currentUser, ip, "ExtendedLogLevel", new[] { previousLevel }, new[] { selectedLogLevel }); }
            catch { }

            statusMessage = $"Extended log level set to {ExtendedLog.CurrentLevel}.";
            statusIsError = false;
        }
        catch (Exception ex)
        {
            statusMessage = $"Failed to save log level: {ex.Message}";
            statusIsError = true;
        }
        finally
        {
            saving = false;
        }
    }
}
