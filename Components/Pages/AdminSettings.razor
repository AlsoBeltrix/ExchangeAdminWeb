@page "/admin-settings"
@using Microsoft.AspNetCore.Authorization
@using ExchangeAdminWeb.Modules
@attribute [Authorize(Policy = "AdminSettings")]
@rendermode InteractiveServer
@inject AuditService Audit
@inject ExtendedLogService ExtendedLog
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject ClientInfoService ClientInfo
@inject ILogger<AdminSettings> Logger
@inject ModuleCatalog Catalog
@inject ModuleEnablementService Enablement
@inject ProtectedPrincipalService ProtectedPrincipalService
@inject ModuleConfigService ModuleConfigSvc

<PageTitle>Admin Settings</PageTitle>

@if (!authChecked)
{
    <div class="container-fluid">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Checking authorization...</span>
            </div>
        </div>
    </div>
    return;
}

<div class="container-fluid">
    <h1 class="mb-4">Admin Settings</h1>

    <div class="alert alert-info mb-4">
        <strong>Enable or disable modules.</strong>
        Per-module section access and configuration are managed on each module's config page (see sidebar links).
    </div>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert @(statusIsError ? "alert-danger" : "alert-success") alert-dismissible fade show">
            @statusMessage
            <button type="button" class="btn-close" @onclick="() => statusMessage = null"></button>
        </div>
    }

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Module Enablement</strong>
            <button class="btn btn-primary btn-sm" @onclick="SaveEnablement" disabled="@(saving || enablementStoreCorrupt)">Save Enablement</button>
        </div>
        <div class="card-body">
            @if (enablementStoreCorrupt)
            {
                <div class="alert alert-danger mb-0">
                    <strong>Module enablement store is corrupt.</strong>
                    config\modules-enabled.json exists but cannot be read, so the real enablement
                    state cannot be shown and saving is disabled — saving now would overwrite the
                    stored state with the all-disabled fallback. Fix or restore the file (deploy
                    backups: ConfigBackups\config.&lt;timestamp&gt;.bak), then reload this page.
                </div>
            }
            else
            {
            <div class="row g-2">
                @foreach (var module in Catalog.GetOrdered().Where(m => !m.IsConfigOnly))
                {
                    var moduleId = module.Id;
                    var parentDisabled = module.DependsOn != null && !Enablement.IsModuleEnabled(module.DependsOn);
                    var parentModule = module.DependsOn != null ? Catalog.GetById(module.DependsOn) : null;
                    <div class="col-md-3">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="enable-@moduleId"
                                   checked="@moduleEnablement[moduleId]"
                                   disabled="@module.IsSystemModule"
                                   @onchange="(e) => moduleEnablement[moduleId] = (bool)(e.Value ?? false)" />
                            <label class="form-check-label" for="enable-@moduleId">
                                @module.DisplayName
                                @if (module.IsSystemModule) { <span class="text-muted">(system)</span> }
                                @if (parentDisabled && parentModule != null)
                                {
                                    <span class="text-muted">(requires @parentModule.DisplayName)</span>
                                }
                            </label>
                        </div>
                    </div>
                }
            </div>
            }
        </div>
    </div>

    <!-- Protected Principals -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Protected Principals</strong>
            <button class="btn btn-primary btn-sm" @onclick="SaveProtectedPrincipals" disabled="@saving">Save Protected Principals</button>
        </div>
        <div class="card-body">
            <p class="text-muted mb-3"><small>Users, groups, OUs, and patterns listed here are blocked from modification across all modules. Changes take effect immediately.</small></p>

            @if (ppLoadError != null)
            {
                <div class="alert alert-danger py-2">@ppLoadError</div>
            }

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Protected Users</label>
                    <small class="text-muted d-block mb-1">UPN, email, sAMAccountName, or DOMAIN\username</small>
                    <div style="max-height: 150px; overflow-y: auto;" class="border rounded p-2 mb-2">
                        @if (ppUsers.Count > 0)
                        {
                            @foreach (var u in ppUsers.ToList())
                            {
                                var captured = u;
                                <div class="d-flex justify-content-between align-items-center py-1">
                                    <small>@captured</small>
                                    <button class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="() => ppUsers.Remove(captured)">×</button>
                                </div>
                            }
                        }
                        else { <small class="text-muted fst-italic">None</small> }
                    </div>
                    <div class="input-group input-group-sm">
                        <ADIdentityAutocomplete ObjectKind="User" ReturnValueKind="UPN" @bind-Value="ppNewUser" Placeholder="user@contoso.com" />
                        <button class="btn btn-outline-success" @onclick="AddPpUser" disabled="@string.IsNullOrWhiteSpace(ppNewUser)">Add</button>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Protected Groups</label>
                    <small class="text-muted d-block mb-1">DN, DOMAIN\GroupName, or CN — transitive membership</small>
                    <div style="max-height: 150px; overflow-y: auto;" class="border rounded p-2 mb-2">
                        @if (ppGroups.Count > 0)
                        {
                            @foreach (var g in ppGroups.ToList())
                            {
                                var captured = g;
                                <div class="d-flex justify-content-between align-items-center py-1">
                                    <small>@captured</small>
                                    <button class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="() => ppGroups.Remove(captured)">×</button>
                                </div>
                            }
                        }
                        else { <small class="text-muted fst-italic">None</small> }
                    </div>
                    <div class="input-group input-group-sm">
                        <ADIdentityAutocomplete ObjectKind="Group" ReturnValueKind="DN" @bind-Value="ppNewGroup" Placeholder="Search AD groups..." />
                        <button class="btn btn-outline-success" @onclick="AddPpGroup" disabled="@string.IsNullOrWhiteSpace(ppNewGroup)">Add</button>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Protected OUs</label>
                    <small class="text-muted d-block mb-1">Distinguished Name — all objects beneath are protected</small>
                    <div style="max-height: 150px; overflow-y: auto;" class="border rounded p-2 mb-2">
                        @if (ppOus.Count > 0)
                        {
                            @foreach (var o in ppOus.ToList())
                            {
                                var captured = o;
                                <div class="d-flex justify-content-between align-items-center py-1">
                                    <small>@captured</small>
                                    <button class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="() => ppOus.Remove(captured)">×</button>
                                </div>
                            }
                        }
                        else { <small class="text-muted fst-italic">None</small> }
                    </div>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" @bind="ppNewOu" @bind:event="oninput" @onkeydown="OnPpOuKey" placeholder="OU=Tier0,DC=ad,DC=contoso,DC=com" />
                        <button class="btn btn-outline-success" @onclick="AddPpOu" disabled="@string.IsNullOrWhiteSpace(ppNewOu)">Add</button>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">sAMAccountName Patterns</label>
                    <small class="text-muted d-block mb-1">Wildcard patterns (e.g. adm-*, svc-*)</small>
                    <div style="max-height: 150px; overflow-y: auto;" class="border rounded p-2 mb-2">
                        @if (ppPatterns.Count > 0)
                        {
                            @foreach (var p in ppPatterns.ToList())
                            {
                                var captured = p;
                                <div class="d-flex justify-content-between align-items-center py-1">
                                    <small>@captured</small>
                                    <button class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="() => ppPatterns.Remove(captured)">×</button>
                                </div>
                            }
                        }
                        else { <small class="text-muted fst-italic">None</small> }
                    </div>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" @bind="ppNewPattern" @bind:event="oninput" @onkeydown="OnPpPatternKey" placeholder="adm-*" />
                        <button class="btn btn-outline-success" @onclick="AddPpPattern" disabled="@string.IsNullOrWhiteSpace(ppNewPattern)">Add</button>
                    </div>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Directory Read Credential (Delinea Secret ID)</label>
                    <input type="text" class="form-control form-control-sm" @bind="ppDirectoryReadSecretId" @bind:event="oninput" placeholder="Required when groups or OUs are configured" />
                    <small class="text-muted">Read-only AD credential for group membership and OU checks.</small>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Extended Logging</strong>
            <button class="btn btn-primary btn-sm" @onclick="SaveLogLevel" disabled="@saving">Save</button>
        </div>
        <div class="card-body">
            <p class="text-muted mb-3"><small>Controls the detail level of extended diagnostic logs. Admin audit logging (event log) is always active regardless of this setting. Extended logs are written to a separate file and viewable from the Event Log page.</small></p>
            <div class="row align-items-center">
                <div class="col-auto">
                    <label class="form-label mb-0 fw-semibold">Log Level</label>
                </div>
                <div class="col-auto">
                    <select class="form-select form-select-sm" style="width: 150px;" @bind="selectedLogLevel">
                        <option value="None">None</option>
                        <option value="Error">Error</option>
                        <option value="Warning">Warning</option>
                        <option value="Information">Info</option>
                        <option value="Debug">Debug</option>
                    </select>
                </div>
                <div class="col-auto">
                    <small class="text-muted">Current: @ExtendedLog.CurrentLevel</small>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string currentUser = string.Empty;
    private bool authChecked;
    private bool saving;
    private string? statusMessage;
    private bool statusIsError;

    private Dictionary<string, bool> moduleEnablement = new();
    private bool enablementStoreCorrupt;
    private string selectedLogLevel = "None";

    private List<string> ppUsers = new();
    private List<string> ppGroups = new();
    private List<string> ppOus = new();
    private List<string> ppPatterns = new();
    private string ppNewUser = "", ppNewGroup = "", ppNewOu = "", ppNewPattern = "";
    private string ppDirectoryReadSecretId = "";
    private string? ppLoadError;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUser = user.Identity?.Name ?? "Unknown";

        var authResult = await AuthorizationService.AuthorizeAsync(user, "AdminSettings");
        if (!authResult.Succeeded)
        {
            Navigation.NavigateTo("access-denied", forceLoad: true);
            return;
        }

        enablementStoreCorrupt = Enablement.IsStoreCorrupt();
        moduleEnablement = Enablement.GetAllEnablement();
        selectedLogLevel = ExtendedLog.CurrentLevel;
        LoadProtectedPrincipals();
        authChecked = true;
    }

    private async Task SaveEnablement()
    {
        saving = true;
        statusMessage = null;
        await Task.Yield();

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var authResult = await AuthorizationService.AuthorizeAsync(authState.User, "AdminSettings");
            if (!authResult.Succeeded)
            {
                statusMessage = "Authorization check failed.";
                statusIsError = true;
                return;
            }

            if (Enablement.IsStoreCorrupt())
            {
                enablementStoreCorrupt = true;
                statusMessage = "Refusing to save: the enablement store is corrupt and saving would overwrite it with fallback state. Fix or restore config\\modules-enabled.json first.";
                statusIsError = true;
                return;
            }

            var previous = Enablement.GetAllEnablement();
            Enablement.SaveEnablement(moduleEnablement);

            var ip = ClientInfo.GetIpForUser(currentUser);
            foreach (var module in Catalog.GetAll().Where(m => !m.IsSystemModule))
            {
                var prev = previous.GetValueOrDefault(module.Id, module.EnabledByDefault);
                var curr = moduleEnablement.GetValueOrDefault(module.Id, module.EnabledByDefault);
                if (prev != curr)
                {
                    try
                    {
                        Audit.LogSettingsChange(currentUser, ip, $"Module:{module.Id}",
                            prev ? new[] { "Enabled" } : Array.Empty<string>(),
                            curr ? new[] { "Enabled" } : Array.Empty<string>());
                    }
                    catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for enablement change"); }
                }
            }

            statusMessage = "Module enablement saved. Refreshing...";
            statusIsError = false;
            await Task.Delay(500);
            Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
        }
        catch (Exception ex)
        {
            statusMessage = $"Failed to save: {ex.Message}";
            statusIsError = true;
        }
        finally
        {
            saving = false;
        }
    }

    private async Task SaveLogLevel()
    {
        saving = true;
        statusMessage = null;
        await Task.Yield();

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var authResult = await AuthorizationService.AuthorizeAsync(authState.User, "AdminSettings");
            if (!authResult.Succeeded)
            {
                statusMessage = "Authorization check failed.";
                statusIsError = true;
                return;
            }

            var previousLevel = ExtendedLog.CurrentLevel;
            ExtendedLog.SetLevel(selectedLogLevel);

            var ip = ClientInfo.GetIpForUser(currentUser);
            try { Audit.LogSettingsChange(currentUser, ip, "ExtendedLogLevel", new[] { previousLevel }, new[] { selectedLogLevel }); }
            catch { }

            statusMessage = $"Extended log level set to {ExtendedLog.CurrentLevel}.";
            statusIsError = false;
        }
        catch (Exception ex)
        {
            statusMessage = $"Failed to save log level: {ex.Message}";
            statusIsError = true;
        }
        finally
        {
            saving = false;
        }
    }

    private void LoadProtectedPrincipals()
    {
        var (cfg, _, error) = ProtectedPrincipalService.LoadEffectiveConfig();
        if (error != null) { ppLoadError = error; return; }
        if (cfg != null)
        {
            ppUsers = cfg.Users.ToList();
            ppGroups = cfg.Groups.ToList();
            ppOus = cfg.OrganizationalUnits.ToList();
            ppPatterns = cfg.SamAccountNamePatterns.ToList();
        }
        ppDirectoryReadSecretId = ProtectedPrincipalService.GetDirectoryReadSecretId()?.ToString() ?? "";
    }

    private void OnPpUserKey(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e) { if (e.Key == "Enter") AddPpUser(); }
    private void OnPpGroupKey(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e) { if (e.Key == "Enter") AddPpGroup(); }
    private void OnPpOuKey(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e) { if (e.Key == "Enter") AddPpOu(); }
    private void OnPpPatternKey(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e) { if (e.Key == "Enter") AddPpPattern(); }

    private void AddPpUser() { var v = ppNewUser.Trim(); if (!string.IsNullOrWhiteSpace(v) && !ppUsers.Contains(v, StringComparer.OrdinalIgnoreCase)) ppUsers.Add(v); ppNewUser = ""; }
    private void AddPpGroup() { var v = ppNewGroup.Trim(); if (!string.IsNullOrWhiteSpace(v) && !ppGroups.Contains(v, StringComparer.OrdinalIgnoreCase)) ppGroups.Add(v); ppNewGroup = ""; }
    private void AddPpOu() { var v = ppNewOu.Trim(); if (!string.IsNullOrWhiteSpace(v) && !ppOus.Contains(v, StringComparer.OrdinalIgnoreCase)) ppOus.Add(v); ppNewOu = ""; }
    private void AddPpPattern() { var v = ppNewPattern.Trim(); if (!string.IsNullOrWhiteSpace(v) && !ppPatterns.Contains(v, StringComparer.OrdinalIgnoreCase)) ppPatterns.Add(v); ppNewPattern = ""; }

    private async Task SaveProtectedPrincipals()
    {
        saving = true;
        statusMessage = null;
        await Task.Yield();

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var authResult = await AuthorizationService.AuthorizeAsync(authState.User, "AdminSettings");
            if (!authResult.Succeeded) { statusMessage = "Authorization check failed."; statusIsError = true; return; }

            var newConfig = new ProtectedPrincipalConfig
            {
                Users = ppUsers.Where(s => !string.IsNullOrWhiteSpace(s)).ToArray(),
                Groups = ppGroups.Where(s => !string.IsNullOrWhiteSpace(s)).ToArray(),
                OrganizationalUnits = ppOus.Where(s => !string.IsNullOrWhiteSpace(s)).ToArray(),
                SamAccountNamePatterns = ppPatterns.Where(s => !string.IsNullOrWhiteSpace(s)).ToArray()
            };

            ProtectedPrincipalService.SaveConfig(newConfig);
            ProtectedPrincipalService.SaveDirectoryReadSecretId(ppDirectoryReadSecretId.Trim());

            try
            {
                var ip = ClientInfo.GetIpForUser(currentUser);
                Audit.LogSettingsChange(currentUser, ip, "ProtectedPrincipals",
                    Array.Empty<string>(),
                    new[] { $"Users:{newConfig.Users.Length},Groups:{newConfig.Groups.Length},OUs:{newConfig.OrganizationalUnits.Length},Patterns:{newConfig.SamAccountNamePatterns.Length}" });
            }
            catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for protected principals change"); }

            statusMessage = "Protected principals saved. Changes are effective immediately.";
            statusIsError = false;
            ppLoadError = null;
        }
        catch (Exception ex)
        {
            statusMessage = $"Failed to save: {ex.Message}";
            statusIsError = true;
        }
        finally { saving = false; }
    }
}
