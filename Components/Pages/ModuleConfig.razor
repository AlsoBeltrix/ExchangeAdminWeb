@page "/module-config/{ModuleId}"
@using Microsoft.AspNetCore.Authorization
@using ExchangeAdminWeb.Modules
@attribute [Authorize]
@rendermode InteractiveServer
@inject ModuleConfigService ModuleConfigSvc
@inject ModuleAdminService ModuleAdmin
@inject ModuleEnablementService Enablement
@inject SectionAccessService SectionAccess
@inject ModuleCatalog Catalog
@inject AuditService Audit
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject ClientInfoService ClientInfo
@inject ADAttributeEditorService AttrEditorService
@inject ADOrganizationalUnitService OUService
@inject ILogger<ModuleConfig> Logger

<PageTitle>Module Config — @(module?.DisplayName ?? ModuleId)</PageTitle>

@if (!authChecked)
{
    <div class="container-fluid">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Checking authorization...</span>
            </div>
        </div>
    </div>
    return;
}

@if (module == null)
{
    <div class="container-fluid">
        <div class="alert alert-danger">Module not found: @ModuleId</div>
    </div>
    return;
}

<div class="container-fluid">
    <h1 class="mb-4">@module.DisplayName <small class="text-muted fs-6">v@(module.Version)</small></h1>
    <p class="text-muted mb-4">@module.Description</p>

    @if (!string.IsNullOrEmpty(statusMessage))
    {
        <div class="alert @(statusIsError ? "alert-danger" : "alert-success") alert-dismissible fade show">
            @statusMessage
            <button type="button" class="btn-close" @onclick="() => statusMessage = null"></button>
        </div>
    }

    @if (!module.IsSystemModule)
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Module Status</strong>
                @if (isGlobalAdmin)
                {
                    <button class="btn btn-primary btn-sm" @onclick="SaveModuleEnablementAsync" disabled="@saving">Save Status</button>
                }
            </div>
            <div class="card-body">
                <div class="form-check form-switch mb-2">
                    <input class="form-check-input" type="checkbox" id="module-enabled"
                           checked="@moduleEnabled"
                           disabled="@(!isGlobalAdmin || saving)"
                           @onchange="(e) => moduleEnabled = (bool)(e.Value ?? false)" />
                    <label class="form-check-label fw-semibold" for="module-enabled">
                        @(moduleEnabled ? "Enabled" : "Disabled")
                    </label>
                </div>
                @{
                    var effectiveEnabled = Enablement.IsModuleEnabled(module.Id);
                    var parentModule = module.DependsOn != null ? Catalog.GetById(module.DependsOn) : null;
                }
                @if (moduleEnabled && !effectiveEnabled && parentModule != null)
                {
                    <div class="alert alert-warning py-2 mb-2">
                        <small>Enabled but inactive -- @parentModule.DisplayName is disabled.</small>
                    </div>
                }
                <small class="text-muted">
                    Disabled modules are hidden from the sidebar and denied by authorization, even when section access and configuration are set.
                    @if (!isGlobalAdmin)
                    {
                        <span> Only global admins can change module status.</span>
                    }
                </small>
            </div>
        </div>
    }

    @* Section Access *@
    @if (isGlobalAdmin)
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Section Access</strong>
                <button class="btn btn-primary btn-sm" @onclick="SaveSectionAccessAsync" disabled="@saving">Save Access</button>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3"><small>AD groups allowed to use this module. If empty, access is denied for fail-closed modules or inherits base groups.</small></p>
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th style="width: 200px;">Permission</th>
                            <th>Allowed Groups</th>
                            <th style="width: 280px;">Add Group</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var alias in policyAliases)
                        {
                            var capturedAlias = alias;
                            <tr>
                                <td><strong>@capturedAlias</strong></td>
                                <td>
                                    @if (accessState.TryGetValue(capturedAlias, out var groups) && groups.Count > 0)
                                    {
                                        @foreach (var group in groups.ToList())
                                        {
                                            var cg = group;
                                            <span class="badge bg-secondary me-1 mb-1" style="font-size: 0.8em;">
                                                @cg
                                                <span role="button" class="ms-1 text-danger" style="cursor:pointer; font-weight:bold;"
                                                      @onclick="() => RemoveAccessGroup(capturedAlias, cg)">&times;</span>
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">No groups configured</span>
                                    }
                                </td>
                                <td>
                                    <div class="input-group input-group-sm">
                                        <ADIdentityAutocomplete ObjectKind="Group" ReturnValueKind="SAM" @bind-Value="accessInputs[capturedAlias]" Placeholder="Search AD groups..." />
                                        <button class="btn btn-outline-success" type="button"
                                                @onclick="() => AddAccessGroup(capturedAlias)">Add</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @* Module Configuration *@
    @if (module.ConfigFields.Count > 0)
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Configuration</strong>
                <button class="btn btn-primary btn-sm" @onclick="SaveConfigAsync" disabled="@saving">Save Configuration</button>
            </div>
            <div class="card-body">
                @if (!ModuleConfigSvc.IsModuleConfigured(module.Id))
                {
                    <div class="alert alert-warning py-2 mb-3">
                        <small>This module has required fields that are not yet configured.</small>
                    </div>
                }
                @if (module.ConfigFields.Any(f => f.Key.Contains("DelineaSecretId")))
                {
                    <div class="alert alert-secondary py-2 mb-3">
                        <small><strong>Delinea Secret Server:</strong> Enter the Secret ID for this module's credentials. For Graph modules, use the "ADI - Azure App Registration" template (fields: Tenant ID, Application ID, Client Secret). For AD modules, use a template with Username, Password, and Domain fields.</small>
                    </div>
                }
                <div class="row g-3">
                    @foreach (var field in module.ConfigFields)
                    {
                        var capturedKey = field.Key;
                        <div class="col-md-6">
                            <label class="form-label">
                                @field.Label
                                @if (field.Required) { <span class="text-danger">*</span> }
                            </label>
                            @if (capturedKey == "DefaultSearchBase" && module.Id == "ADAttributeEditor")
                            {
                                <div class="input-group">
                                    <input type="text"
                                           class="form-control"
                                           placeholder="@field.Description"
                                           value="@GetConfigValue(field.Key, field.DefaultValue)"
                                           @oninput="(e) => SetConfigValue(capturedKey, e.Value?.ToString() ?? string.Empty)" />
                                    @if (ouBrowseAvailable)
                                    {
                                        <button class="btn btn-outline-secondary" type="button"
                                                @onclick="ToggleOUBrowser" disabled="@ouLoading">
                                            @if (ouLoading)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                            }
                                            @(showOUBrowser ? "Close" : "Browse OUs")
                                        </button>
                                    }
                                </div>
                                @if (!string.IsNullOrEmpty(field.Description) && !field.IsSecret)
                                {
                                    <div class="form-text">@field.Description</div>
                                }

                                @if (showOUBrowser)
                                {
                                    <div class="card mt-2 border-secondary">
                                        <div class="card-header py-2 d-flex justify-content-between align-items-center">
                                            <small class="fw-semibold">Select Organizational Units</small>
                                            <div>
                                                <button class="btn btn-sm btn-outline-secondary me-1" @onclick="RefreshOUs" disabled="@ouLoading">
                                                    Refresh
                                                </button>
                                                <button class="btn btn-sm btn-primary" @onclick="ApplySelectedOUs">
                                                    Apply Selected
                                                </button>
                                            </div>
                                        </div>
                                        <div class="card-body p-2">
                                            @if (ouFilteredEntries.Count == 0)
                                            {
                                                <p class="text-muted fst-italic mb-0">No organizational units found.</p>
                                            }
                                            else
                                            {
                                                <div class="mb-2">
                                                    <input type="text" class="form-control form-control-sm"
                                                           placeholder="Filter OUs..."
                                                           value="@ouFilterText"
                                                           @oninput="OnOUFilterChanged" />
                                                </div>
                                                <div style="max-height: 350px; overflow-y: auto; font-size: 0.875em;">
                                                    @foreach (var ou in ouFilteredEntries)
                                                    {
                                                        var capturedDn = ou.DistinguishedName;
                                                        var isChecked = ouSelectedDNs.Contains(capturedDn);
                                                        var indent = Math.Max(0, ou.Depth - ouMinDepth);
                                                        <div class="form-check py-0" style="padding-left: @(1.5 + indent * 1.25)rem;">
                                                            <input class="form-check-input" type="checkbox" id="ou-@capturedDn.GetHashCode()"
                                                                   checked="@isChecked"
                                                                   @onchange="(e) => ToggleOU(capturedDn, (bool)(e.Value ?? false))" />
                                                            <label class="form-check-label" for="ou-@capturedDn.GetHashCode()"
                                                                   title="@capturedDn">
                                                                @ou.Name
                                                                <small class="text-muted ms-1">@capturedDn</small>
                                                            </label>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                            else if (field.FieldType == ConfigFieldType.AdGroup)
                            {
                                <ADGroupAutocomplete Value="@GetConfigValue(field.Key, field.DefaultValue)"
                                                     ValueChanged="(v) => SetConfigValue(capturedKey, v)"
                                                     Placeholder="@field.Description"
                                                     Disabled="@saving" />
                                @if (!string.IsNullOrEmpty(field.Description) && !field.IsSecret)
                                {
                                    <div class="form-text">@field.Description</div>
                                }
                            }
                            else
                            {
                                <input type="text"
                                       class="form-control"
                                       placeholder="@field.Description"
                                       value="@GetConfigValue(field.Key, field.DefaultValue)"
                                       @oninput="(e) => SetConfigValue(capturedKey, e.Value?.ToString() ?? string.Empty)" />
                                @if (!string.IsNullOrEmpty(field.Description) && !field.IsSecret)
                                {
                                    <div class="form-text">@field.Description</div>
                                }
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @* AD Attribute Editor — Editable Attributes *@
    @if (module.Id == "ADAttributeEditor")
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Editable Attributes</strong>
                <div>
                    <button class="btn btn-outline-primary btn-sm me-1" @onclick="AddAttribute" disabled="@saving">Add Attribute</button>
                    <button class="btn btn-primary btn-sm" @onclick="SaveAllowlistAsync" disabled="@(saving || allowlistAttributes.Count == 0)">Save Allowlist</button>
                </div>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3"><small>Configure which AD attributes users can edit. Attributes on the hard denylist (security-sensitive attributes like userAccountControl, memberOf, etc.) are automatically blocked.</small></p>

                @if (allowlistError != null)
                {
                    <div class="alert alert-danger py-2">@allowlistError</div>
                }
                @if (allowlistSaved)
                {
                    <div class="alert alert-success py-2 alert-dismissible">
                        Allowlist saved successfully.
                        <button type="button" class="btn-close" @onclick="() => allowlistSaved = false"></button>
                    </div>
                }

                @if (allowlistAttributes.Count == 0)
                {
                    <p class="text-muted fst-italic">No editable attributes configured. Users will see an empty editor.</p>
                }
                else
                {
                    <div style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-sm mb-0">
                            <thead>
                                <tr>
                                    <th>LDAP Name</th>
                                    <th>Label</th>
                                    <th style="width: 100px;">Type</th>
                                    <th style="width: 80px;">Required</th>
                                    <th style="width: 90px;">Allow Clear</th>
                                    <th style="width: 80px;">Max Len</th>
                                    <th style="width: 60px;">Level</th>
                                    <th style="width: 50px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var i = 0; i < allowlistAttributes.Count; i++)
                                {
                                    var idx = i;
                                    var attr = allowlistAttributes[idx];
                                    <tr>
                                        <td><input type="text" class="form-control form-control-sm" value="@attr.Name" @onchange="e => UpdateAttrName(idx, e)" placeholder="extensionAttribute1" /></td>
                                        <td><input type="text" class="form-control form-control-sm" value="@attr.Label" @onchange="e => UpdateAttrLabel(idx, e)" placeholder="Display Label" /></td>
                                        <td>
                                            <select class="form-select form-select-sm" value="@attr.Type" @onchange="e => UpdateAttrType(idx, e)">
                                                <option value="String">String</option>
                                                <option value="Choice">Choice</option>
                                            </select>
                                        </td>
                                        <td class="text-center"><input type="checkbox" class="form-check-input" checked="@attr.Required" @onchange="e => UpdateAttrRequired(idx, e)" /></td>
                                        <td class="text-center"><input type="checkbox" class="form-check-input" checked="@attr.AllowClear" @onchange="e => UpdateAttrAllowClear(idx, e)" /></td>
                                        <td><input type="number" class="form-control form-control-sm" value="@attr.MaxLength" @onchange="e => UpdateAttrMaxLength(idx, e)" placeholder="—" /></td>
                                        <td>
                                            <select class="form-select form-select-sm" value="@attr.Level" @onchange="e => UpdateAttrLevel(idx, e)">
                                                <option value="1">1</option>
                                                <option value="2">2</option>
                                                <option value="3">3</option>
                                            </select>
                                        </td>
                                        <td><button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveAttribute(idx)">×</button></td>
                                    </tr>
                                    @if (attr.Type == "Choice")
                                    {
                                        <tr>
                                            <td colspan="7" class="ps-4 pt-0">
                                                <small class="text-muted">Choices (comma-separated):</small>
                                                <input type="text" class="form-control form-control-sm" value="@string.Join(", ", attr.Choices ?? [])" @onchange="e => UpdateAttrChoices(idx, e)" placeholder="Option1, Option2, Option3" />
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    }

    @* Module Admins (global admin only) *@
    @if (isGlobalAdmin)
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <strong>Module Admins</strong>
                <button class="btn btn-primary btn-sm" @onclick="SaveModuleAdminsAsync" disabled="@saving">Save Admins</button>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3"><small>AD groups that can manage this module's configuration without global admin access.</small></p>

                @if (moduleAdminGroups.Count > 0)
                {
                    <div class="mb-3">
                        @foreach (var group in moduleAdminGroups.ToList())
                        {
                            var capturedGroup = group;
                            <span class="badge bg-secondary me-1 mb-1" style="font-size: 0.85em;">
                                @capturedGroup
                                <span role="button" class="ms-1 text-danger" style="cursor:pointer; font-weight:bold;"
                                      @onclick="() => RemoveModuleAdmin(capturedGroup)">&times;</span>
                            </span>
                        }
                    </div>
                }
                else
                {
                    <p class="text-muted fst-italic mb-3">No module admins assigned.</p>
                }

                <div class="input-group" style="max-width: 400px;">
                    <ADIdentityAutocomplete ObjectKind="Group" ReturnValueKind="SAM" @bind-Value="newAdminGroup" Placeholder="Search AD groups..." />
                    <button class="btn btn-outline-success" type="button" @onclick="AddModuleAdmin">Add</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string ModuleId { get; set; } = "";

    private string currentUser = string.Empty;
    private bool authChecked;
    private bool isGlobalAdmin;
    private bool saving;
    private string? statusMessage;
    private bool statusIsError;

    private AdminModuleDescriptor? module;
    private Dictionary<string, string> currentConfigState = new();
    private List<string> moduleAdminGroups = new();
    private string newAdminGroup = string.Empty;

    private List<string> policyAliases = new();
    private Dictionary<string, List<string>> accessState = new();
    private Dictionary<string, string> accessInputs = new();

    private string? loadedModuleId;
    private bool moduleEnabled;

    protected override async Task OnParametersSetAsync()
    {
        if (ModuleId == loadedModuleId) return;
        loadedModuleId = ModuleId;

        authChecked = false;
        statusMessage = null;

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUser = user.Identity?.Name ?? "Unknown";

        module = Catalog.GetById(ModuleId);
        if (module == null || module.IsSystemModule)
        {
            authChecked = true;
            module = null;
            return;
        }

        // Config-only modules have their own dedicated page
        if (module.IsConfigOnly)
        {
            Navigation.NavigateTo(module.Route, replace: true);
            return;
        }

        var adminResult = await AuthorizationService.AuthorizeAsync(user, "AdminSettings");
        isGlobalAdmin = adminResult.Succeeded;

        if (!isGlobalAdmin && !ModuleAdmin.IsModuleAdmin(ModuleId, user))
        {
            Navigation.NavigateTo("access-denied", forceLoad: true);
            return;
        }

        LoadState();
        authChecked = true;
    }

    private void LoadState()
    {
        if (module == null) return;

        currentConfigState = ModuleConfigSvc.GetModuleConfig(module.Id);
        moduleEnabled = Enablement.IsModuleRawEnabled(module.Id);
        moduleAdminGroups = ModuleAdmin.GetModuleAdmins(module.Id).ToList();

        policyAliases = new List<string> { module.MainPermission.PolicyAlias };
        foreach (var gp in module.GranularPermissions)
            policyAliases.Add(gp.PolicyAlias);

        accessState = new();
        accessInputs = new();
        foreach (var alias in policyAliases)
        {
            accessState[alias] = new List<string>(SectionAccess.GetGroupsForSection(alias));
            accessInputs[alias] = string.Empty;
        }

        if (module.Id == "ADAttributeEditor")
        {
            LoadAllowlist();
            InitOUBrowser();
        }
    }

    private string GetConfigValue(string key, string defaultValue) =>
        currentConfigState.TryGetValue(key, out var val) ? val : defaultValue;

    private void SetConfigValue(string key, string value) =>
        currentConfigState[key] = value;

    private async Task SaveConfigAsync()
    {
        if (module == null) return;
        saving = true;
        statusMessage = null;
        await Task.Yield();

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var adminResult = await AuthorizationService.AuthorizeAsync(user, "AdminSettings");
            if (!adminResult.Succeeded && !ModuleAdmin.IsModuleAdmin(module.Id, user))
            {
                statusMessage = "You are not authorized to configure this module.";
                statusIsError = true;
                return;
            }

            var previous = ModuleConfigSvc.GetModuleConfig(module.Id);
            ModuleConfigSvc.SaveModuleConfig(module.Id, currentConfigState);

            var allKeys = previous.Keys.Union(currentConfigState.Keys, StringComparer.OrdinalIgnoreCase).ToList();
            var changed = allKeys.Where(k => (previous.GetValueOrDefault(k, "") ?? "") != (currentConfigState.GetValueOrDefault(k, "") ?? "")).ToList();

            if (changed.Count > 0)
            {
                try
                {
                    var ip = ClientInfo.GetIpForUser(currentUser);
                    var prevKeys = changed.Select(k => $"{k}={MaskIfSecret(k, previous.GetValueOrDefault(k) ?? "")}").ToArray();
                    var newKeys = changed.Select(k => $"{k}={MaskIfSecret(k, currentConfigState.GetValueOrDefault(k) ?? "")}").ToArray();
                    Audit.LogSettingsChange(currentUser, ip, $"ModuleConfig:{module.Id}", prevKeys, newKeys);
                }
                catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for module config change"); }
            }

            statusMessage = "Configuration saved.";
            statusIsError = false;
        }
        catch (Exception ex)
        {
            statusMessage = $"Failed to save: {ex.Message}";
            statusIsError = true;
        }
        finally { saving = false; }
    }

    private async Task SaveModuleEnablementAsync()
    {
        if (module == null) return;
        saving = true;
        statusMessage = null;
        await Task.Yield();

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var authResult = await AuthorizationService.AuthorizeAsync(authState.User, "AdminSettings");
            if (!authResult.Succeeded)
            {
                statusMessage = "Only global admins can change module status.";
                statusIsError = true;
                return;
            }

            var enablement = Enablement.GetAllEnablement();
            var previous = enablement.GetValueOrDefault(module.Id, module.EnabledByDefault);
            enablement[module.Id] = moduleEnabled;
            Enablement.SaveEnablement(enablement);

            if (previous != moduleEnabled)
            {
                try
                {
                    var ip = ClientInfo.GetIpForUser(currentUser);
                    Audit.LogSettingsChange(currentUser, ip, $"Module:{module.Id}",
                        previous ? new[] { "Enabled" } : Array.Empty<string>(),
                        moduleEnabled ? new[] { "Enabled" } : Array.Empty<string>());
                }
                catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for module status change"); }
            }

            statusMessage = "Module status saved. Refreshing...";
            statusIsError = false;
            await Task.Delay(500);
            Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
        }
        catch (Exception ex)
        {
            statusMessage = $"Failed to save module status: {ex.Message}";
            statusIsError = true;
        }
        finally
        {
            saving = false;
        }
    }

    private async Task SaveSectionAccessAsync()
    {
        if (module == null) return;
        saving = true;
        statusMessage = null;
        await Task.Yield();

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var authResult = await AuthorizationService.AuthorizeAsync(authState.User, "AdminSettings");
            if (!authResult.Succeeded)
            {
                statusMessage = "Only global admins can change section access.";
                statusIsError = true;
                return;
            }

            var allAccess = SectionAccess.GetSectionAccess();

            if (allAccess.Count == 0)
            {
                foreach (var alias in Catalog.GetConfigurablePolicyAliases())
                {
                    if (!allAccess.ContainsKey(alias))
                        allAccess[alias] = SectionAccess.GetGroupsForSection(alias);
                }
            }

            var previousGroups = new Dictionary<string, string[]>();
            foreach (var alias in policyAliases)
            {
                previousGroups[alias] = allAccess.TryGetValue(alias, out var prev) ? prev : Array.Empty<string>();
                allAccess[alias] = accessState[alias].ToArray();
            }
            SectionAccess.SaveSectionAccess(allAccess);

            var ip = ClientInfo.GetIpForUser(currentUser);
            foreach (var alias in policyAliases)
            {
                var prev = previousGroups[alias];
                var curr = accessState[alias].ToArray();
                if (!prev.SequenceEqual(curr, StringComparer.OrdinalIgnoreCase))
                {
                    try { Audit.LogSettingsChange(currentUser, ip, alias, prev, curr); }
                    catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for section access change"); }
                }
            }

            statusMessage = "Section access saved.";
            statusIsError = false;
        }
        catch (Exception ex)
        {
            statusMessage = $"Failed to save: {ex.Message}";
            statusIsError = true;
        }
        finally { saving = false; }
    }

    private async Task SaveModuleAdminsAsync()
    {
        if (module == null) return;
        saving = true;
        statusMessage = null;
        await Task.Yield();

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var authResult = await AuthorizationService.AuthorizeAsync(authState.User, "AdminSettings");
            if (!authResult.Succeeded)
            {
                statusMessage = "Only global admins can assign module admins.";
                statusIsError = true;
                return;
            }

            var previous = ModuleAdmin.GetModuleAdmins(module.Id);
            ModuleAdmin.SetModuleAdmins(module.Id, moduleAdminGroups.ToArray());

            try
            {
                var ip = ClientInfo.GetIpForUser(currentUser);
                Audit.LogSettingsChange(currentUser, ip, $"ModuleAdmins:{module.Id}", previous, moduleAdminGroups.ToArray());
            }
            catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for module admin change"); }

            statusMessage = "Module admins saved.";
            statusIsError = false;
        }
        catch (Exception ex)
        {
            statusMessage = $"Failed to save: {ex.Message}";
            statusIsError = true;
        }
        finally { saving = false; }
    }

    private string MaskIfSecret(string key, string value)
    {
        if (string.IsNullOrEmpty(value)) return "(empty)";
        var field = module?.ConfigFields.FirstOrDefault(f => f.Key == key);
        if (field?.IsSecret == true) return "***";
        return value;
    }

    private void AddAccessGroup(string alias)
    {
        var input = accessInputs[alias]?.Trim();
        if (string.IsNullOrWhiteSpace(input)) return;
        if (!accessState[alias].Contains(input, StringComparer.OrdinalIgnoreCase))
            accessState[alias].Add(input);
        accessInputs[alias] = string.Empty;
    }

    private void RemoveAccessGroup(string alias, string group) => accessState[alias].Remove(group);

    private void HandleAccessKeyDown(KeyboardEventArgs e, string alias)
    {
        if (e.Key == "Enter") AddAccessGroup(alias);
    }

    private void AddModuleAdmin()
    {
        var input = newAdminGroup?.Trim();
        if (string.IsNullOrWhiteSpace(input)) return;
        if (!moduleAdminGroups.Contains(input, StringComparer.OrdinalIgnoreCase))
            moduleAdminGroups.Add(input);
        newAdminGroup = string.Empty;
    }

    private void RemoveModuleAdmin(string group) => moduleAdminGroups.Remove(group);

    private void HandleAdminKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddModuleAdmin();
    }

    // --- AD Attribute Editor Allowlist ---

    private List<AllowlistRow> allowlistAttributes = new();
    private string? allowlistError;
    private bool allowlistSaved;

    private void LoadAllowlist()
    {
        var list = AttrEditorService.GetAllowlist();
        if (list == null)
        {
            allowlistError = "Allowlist config is corrupt. Fix or delete config/ad-editable-attributes.json.";
            allowlistAttributes = new();
            return;
        }

        allowlistAttributes = list.Select(a => new AllowlistRow
        {
            Name = a.Name, Label = a.Label, Type = a.Type,
            Choices = a.Choices, Required = a.Required, AllowClear = a.AllowClear,
            MaxLength = a.MaxLength, Pattern = a.Pattern, Level = a.Level
        }).ToList();
        allowlistError = null;
    }

    private void AddAttribute()
    {
        allowlistAttributes.Add(new AllowlistRow
        {
            Name = "", Label = "", Type = "String",
            Required = false, AllowClear = true
        });
    }

    private void RemoveAttribute(int index)
    {
        if (index >= 0 && index < allowlistAttributes.Count)
            allowlistAttributes.RemoveAt(index);
    }

    private void UpdateAttrName(int idx, ChangeEventArgs e) => allowlistAttributes[idx].Name = e.Value?.ToString() ?? "";
    private void UpdateAttrLabel(int idx, ChangeEventArgs e) => allowlistAttributes[idx].Label = e.Value?.ToString() ?? "";
    private void UpdateAttrType(int idx, ChangeEventArgs e) => allowlistAttributes[idx].Type = e.Value?.ToString() ?? "String";
    private void UpdateAttrRequired(int idx, ChangeEventArgs e) => allowlistAttributes[idx].Required = bool.TryParse(e.Value?.ToString(), out var v) && v;
    private void UpdateAttrAllowClear(int idx, ChangeEventArgs e) => allowlistAttributes[idx].AllowClear = bool.TryParse(e.Value?.ToString(), out var v) && v;
    private void UpdateAttrMaxLength(int idx, ChangeEventArgs e)
    {
        allowlistAttributes[idx].MaxLength = int.TryParse(e.Value?.ToString(), out var v) && v > 0 ? v : null;
    }
    private void UpdateAttrChoices(int idx, ChangeEventArgs e)
    {
        var raw = e.Value?.ToString() ?? "";
        var parsed = raw.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
        allowlistAttributes[idx].Choices = parsed.Length > 0 ? parsed : null;
    }

    private async Task SaveAllowlistAsync()
    {
        saving = true;
        allowlistError = null;
        allowlistSaved = false;
        await Task.Yield();

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var adminResult = await AuthorizationService.AuthorizeAsync(user, "AdminSettings");
            if (!adminResult.Succeeded && !ModuleAdmin.IsModuleAdmin(module!.Id, user))
            {
                allowlistError = "You are not authorized to save the attribute allowlist.";
                return;
            }

            var valid = allowlistAttributes
                .Where(a => !string.IsNullOrWhiteSpace(a.Name) && !string.IsNullOrWhiteSpace(a.Label))
                .Select(a => new EditableAttribute(a.Name.Trim(), a.Label.Trim(), a.Type, a.Choices, a.Required, a.AllowClear, a.MaxLength, a.Pattern, a.Level))
                .ToList();

            var denied = valid.Where(a => ADAttributeEditorService.IsDenylisted(a.Name)).ToList();
            if (denied.Count > 0)
            {
                allowlistError = $"Cannot save: {string.Join(", ", denied.Select(d => d.Name))} are on the hard denylist.";
                return;
            }

            AttrEditorService.SaveAllowlist(valid);
            allowlistSaved = true;

            try
            {
                var ip = ClientInfo.GetIpForUser(currentUser);
                Audit.LogSettingsChange(currentUser, ip, "ADAttributeEditor:Allowlist",
                    Array.Empty<string>(),
                    valid.Select(a => a.Name).ToArray());
            }
            catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for allowlist save"); }
        }
        catch (Exception ex)
        {
            allowlistError = $"Failed to save: {ex.Message}";
            Logger.LogError(ex, "Allowlist save failed");
        }
        finally { saving = false; }
    }

    private void UpdateAttrLevel(int idx, ChangeEventArgs e)
    {
        allowlistAttributes[idx].Level = int.TryParse(e.Value?.ToString(), out var v) && v >= 1 && v <= 3 ? v : 1;
    }

    private sealed class AllowlistRow
    {
        public string Name { get; set; } = "";
        public string Label { get; set; } = "";
        public string Type { get; set; } = "String";
        public string[]? Choices { get; set; }
        public bool Required { get; set; }
        public bool AllowClear { get; set; }
        public int? MaxLength { get; set; }
        public string? Pattern { get; set; }
        public int Level { get; set; } = 1;
    }

    // --- OU Browser/Picker ---

    private bool ouBrowseAvailable;
    private bool showOUBrowser;
    private bool ouLoading;
    private List<OUEntry> ouAllEntries = new();
    private List<OUEntry> ouFilteredEntries = new();
    private HashSet<string> ouSelectedDNs = new(StringComparer.OrdinalIgnoreCase);
    private string ouFilterText = string.Empty;
    private int ouMinDepth;

    private void InitOUBrowser()
    {
        // Probe availability without blocking — just check the cached flag.
        // The actual enumeration happens when the user clicks "Browse OUs".
        ouBrowseAvailable = true;
        showOUBrowser = false;
        ouLoading = false;
        ouFilterText = string.Empty;
        ouAllEntries = new();
        ouFilteredEntries = new();
        ouSelectedDNs = new(StringComparer.OrdinalIgnoreCase);
    }

    private async Task ToggleOUBrowser()
    {
        if (showOUBrowser)
        {
            showOUBrowser = false;
            return;
        }

        // Load OUs when opening the browser for the first time
        if (ouAllEntries.Count == 0)
        {
            await LoadOUsAsync();
            if (!ouBrowseAvailable) return;
        }

        // Pre-select OUs already in the config value
        SyncSelectedFromConfig();
        showOUBrowser = true;
    }

    private async Task LoadOUsAsync()
    {
        ouLoading = true;
        await Task.Yield();

        try
        {
            ouAllEntries = await Task.Run(() => OUService.GetOrganizationalUnits());
            ouBrowseAvailable = OUService.IsAvailable;

            if (!ouBrowseAvailable)
            {
                ouAllEntries = new();
                ouFilteredEntries = new();
                return;
            }

            ouMinDepth = ouAllEntries.Count > 0 ? ouAllEntries.Min(e => e.Depth) : 0;
            ApplyOUFilter();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "OU browser load failed");
            ouBrowseAvailable = false;
        }
        finally
        {
            ouLoading = false;
        }
    }

    private async Task RefreshOUs()
    {
        OUService.InvalidateCache();
        ouAllEntries = new();
        await LoadOUsAsync();
        if (ouBrowseAvailable)
        {
            SyncSelectedFromConfig();
        }
    }

    private void SyncSelectedFromConfig()
    {
        ouSelectedDNs.Clear();
        var currentValue = GetConfigValue("DefaultSearchBase", "");
        if (!string.IsNullOrWhiteSpace(currentValue))
        {
            var dns = currentValue.Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
            foreach (var dn in dns)
                ouSelectedDNs.Add(dn);
        }
    }

    private void ToggleOU(string dn, bool isChecked)
    {
        if (isChecked)
            ouSelectedDNs.Add(dn);
        else
            ouSelectedDNs.Remove(dn);
    }

    private void ApplySelectedOUs()
    {
        var value = string.Join(";", ouSelectedDNs.OrderBy(d => d, StringComparer.OrdinalIgnoreCase));
        SetConfigValue("DefaultSearchBase", value);
        showOUBrowser = false;
    }

    private void OnOUFilterChanged(ChangeEventArgs e)
    {
        ouFilterText = e.Value?.ToString() ?? string.Empty;
        ApplyOUFilter();
    }

    private void ApplyOUFilter()
    {
        if (string.IsNullOrWhiteSpace(ouFilterText))
        {
            ouFilteredEntries = ouAllEntries;
        }
        else
        {
            ouFilteredEntries = ouAllEntries
                .Where(ou => ou.Name.Contains(ouFilterText, StringComparison.OrdinalIgnoreCase)
                          || ou.DistinguishedName.Contains(ouFilterText, StringComparison.OrdinalIgnoreCase))
                .ToList();
        }
    }
}
