    private async Task HandleTypeCsvUpload(InputFileChangeEventArgs e)
    {
        typePreview = new();
        typeResults = new();
        typeApplied = false;
        typeCsvData = new();
        result = null;
        isLoading = true;
        await Task.Yield();

        try
        {
            List<TypeCsvParseResult> parsed;
            await using (var stream = e.File.OpenReadStream(maxAllowedSize: 16 * 1024 * 1024))
            {
                parsed = await ConferenceRoomService.ParseTypeCsvAsync(stream);
            }

            // Keep typeCsvData and typePreview index-aligned (ApplyTypeCsv pairs
            // them by index). Every parse result produces exactly one entry in
            // each list, so skipped/invalid rows are visible and flow through
            // Apply as per-row failures.
            foreach (var pr in parsed)
            {
                if (pr.Skipped)
                {
                    typeCsvData.Add(new TypeCsvRow { Email = "(row " + pr.RowIndex + ")" });
                    typePreview.Add(new RoomTypePreviewRow
                    {
                        RowIndex = pr.RowIndex,
                        Email = "(row " + pr.RowIndex + ")",
                        RoomResolved = false,
                        ResolveError = pr.SkipReason + " | Columns found: " + string.Join(", ", pr.AvailableColumns)
                    });
                    StateHasChanged();
                    continue;
                }

                var row = pr.Row!;
                typeCsvData.Add(row);

                if (!Enum.TryParse<RoomType>(row.Type, true, out var roomType))
                {
                    typePreview.Add(new RoomTypePreviewRow
                    {
                        RowIndex = pr.RowIndex, Email = row.Email, RoomResolved = false,
                        ResolveError = $"Invalid room type: '{row.Type}'. Valid: Standard, Video, Restricted, Exception, CEO, Executive"
                    });
                    StateHasChanged();
                    continue;
                }

                if (string.IsNullOrWhiteSpace(row.TimeZone))
                {
                    typePreview.Add(new RoomTypePreviewRow
                    {
                        RowIndex = pr.RowIndex, Email = row.Email, RoomResolved = false,
                        ResolveError = "Missing TimeZone field"
                    });
                    StateHasChanged();
                    continue;
                }

                string displayName = "";
                bool resolved = false;
                string? resolveError = null;
                try
                {
                    var info = await RoomService.GetRoomInfoAsync(row.Email);
                    if (info != null) { resolved = true; displayName = info.DisplayName; }
                    else resolveError = "Room not found";
                }
                catch (Exception ex) { resolveError = ex.Message; }

                var preview = RoomService.BuildTypePreview(
                    row.Email, displayName, roomType, row.TimeZone,
                    row.Site, row.Arbiter, row.RemoveExistingPermissions);
                preview.RowIndex = pr.RowIndex;
                preview.RoomResolved = resolved;
                preview.ResolveError = resolveError;

                typePreview.Add(preview);
                StateHasChanged();
            }

            if (typePreview.Count == 0)
                result = new RoomOperationResult { Success = false, Message = "0 rooms parsed. Check that your CSV has a header row with an identity column (Identity, PrimarySmtpAddress, EmailAddress, Mail, or Email)." };
        }
        catch (Exception ex)
        {
            result = new RoomOperationResult { Success = false, Message = $"Failed to parse CSV: {ex.Message}" };
        }
        finally { isLoading = false; }
    }

