    private async Task SetupSingleRoom()
    {
        isLoading = true;
        result = null;
        await Task.Yield();

        var email = roomEmail.Trim();
        var ticket = ticketNumber.Trim();

        try
        {
            var ticketValidation = await ServiceNow.ValidateTicketAsync(ticket);
            if (!ticketValidation.IsValid)
            {
                result = new RoomOperationResult { Email = email, Success = false, Message = $"Ticket validation failed: {ticketValidation.Message}" };
                AuditFinderAction(email, false, ticket, $"Ticket validation failed: {ticketValidation.Message}");
                return;
            }

            if (!await ReauthorizeAsync()) return;

            // Capture old values
            Dictionary<string, object?>? oldValues = null;
            try
            {
                var existing = await RoomService.GetRoomInfoAsync(email);
                if (existing != null)
                    oldValues = new() { ["city"] = existing.City, ["building"] = existing.Building, ["capacity"] = existing.Capacity, ["floor"] = existing.Floor, ["timezone"] = existing.TimeZone };
            }
            catch { }

            using var op = OpTrace.BeginOperation("ConferenceRooms", "SetMetadata", currentUser, clientIpAddress, email, ticket);

            result = await RoomService.SetRoomMetadataAndListAsync(
                email, city.Trim(), building.Trim(), capacity,
                floor.Trim(), floorLabel.Trim(), displayDevice.Trim(), videoDevice.Trim(),
                countryOrRegion.Trim(), state.Trim(), timezone.Trim());

            op.Complete(result.Success, result.Message);

            var newValues = new Dictionary<string, object?>
            {
                ["city"] = city, ["building"] = building, ["capacity"] = capacity,
                ["floor"] = floor, ["floorLabel"] = floorLabel, ["timezone"] = timezone,
                ["countryOrRegion"] = countryOrRegion, ["state"] = state
            };
            AuditFinderAction(email, result.Success, ticket, result.Success ? null : result.Message, oldValues, newValues);
            await NotifyRoomAdminAsync("ConferenceRooms_SetMetadata", email, result.Success, ticket, result.Message);
        }
        catch (Exception ex)
        {
            result = new RoomOperationResult { Email = email, Success = false, Message = ex.Message };
            AuditFinderAction(email, false, ticket, ex.Message);
            await NotifyRoomAdminAsync("ConferenceRooms_SetMetadata", email, false, ticket, ex.Message);
        }
        finally { isLoading = false; }
    }

    // =========================================================================
    // ROOM FINDER — CSV Upload + Preview + Apply
    // =========================================================================

    private async Task HandleFinderCsvUpload(InputFileChangeEventArgs e)
    {
        finderPreview = new();
        finderApplied = false;
        finderCsvData = new();
        result = null;
        isLoading = true;
        await Task.Yield();

        try
        {
            List<FinderCsvParseResult> parsed;
            await using (var stream = e.File.OpenReadStream(maxAllowedSize: 16 * 1024 * 1024))
            {
                parsed = await ConferenceRoomService.ParseFinderCsvAsync(stream);
            }

            // Keep finderCsvData and finderPreview index-aligned (ApplyFinderCsv
            // pairs them by index). Skipped rows get a placeholder data row plus a
            // non-resolved preview row so they're visible and flow through Apply
            // as per-row failures rather than vanishing.
            foreach (var pr in parsed)
            {
                if (pr.Skipped)
                {
                    finderCsvData.Add(new FinderCsvRow { Email = "(row " + pr.RowIndex + ")" });
                    finderPreview.Add(new RoomFinderPreviewRow
                    {
                        RowIndex = pr.RowIndex,
                        Email = "(row " + pr.RowIndex + ")",
                        RoomResolved = false,
                        ResolveError = pr.SkipReason + " | Columns found: " + string.Join(", ", pr.AvailableColumns)
                    });
                    StateHasChanged();
                    continue;
                }

                var row = pr.Row!;
                finderCsvData.Add(row);

                var preview = new RoomFinderPreviewRow
                {
                    RowIndex = pr.RowIndex,
                    Email = row.Email,
                    City = row.City,
                    CountryOrRegion = row.CountryOrRegion,
                    State = row.State,
                    Building = row.Building,
                    Capacity = row.Capacity,
                    Floor = row.Floor,
                    FloorLabel = row.FloorLabel,
                    DisplayDeviceName = row.DisplayDeviceName,
                    VideoDeviceName = row.VideoDeviceName,
                    TimeZone = row.TimeZone
                };

                try
                {
                    var info = await RoomService.GetRoomInfoAsync(row.Email);
                    if (info != null)
                    {
                        preview.RoomResolved = true;
                        preview.DisplayName = info.DisplayName;
                    }
                    else
                    {
                        preview.RoomResolved = false;
                        preview.ResolveError = "Room not found";
                    }
                }
                catch (Exception ex)
                {
                    preview.RoomResolved = false;
                    preview.ResolveError = ex.Message;
                }

                // The room list IS the building (Room Finder groups it under the room's
                // City metadata). Resolve/name the list from Building, not City.
                if (!string.IsNullOrWhiteSpace(row.Building) && preview.RoomResolved)
                {
                    try
                    {
                        var (listName, listExists, isLegacy, strayCityList) = await RoomService.ResolveRoomListAsync(row.Building, row.City);
                        preview.RoomListName = listName ?? ConferenceRoomService.BuildRoomListName(row.Building);
                        preview.RoomListExists = listExists;
                        preview.IsLegacyRoomList = isLegacy;
                        preview.StrayCityRoomListName = strayCityList;
                        if (isLegacy)
                            preview.Warnings.Add($"Using legacy room list '{listName}'. New naming would be '{ConferenceRoomService.BuildRoomListName(row.Building)}'.");
                        if (!string.IsNullOrWhiteSpace(strayCityList))
                            preview.Warnings.Add($"A city-named list '{strayCityList}' also exists. This room will be added to '{preview.RoomListName}' (the building list). Review the stray list manually.");
                    }
                    catch { preview.RoomListName = ConferenceRoomService.BuildRoomListName(row.Building); }
                }

                if (string.IsNullOrWhiteSpace(row.Building))
                    preview.Warnings.Add("Missing Building — will not be added to a room list.");
                if (string.IsNullOrWhiteSpace(row.TimeZone))
                    preview.Warnings.Add("Missing TimeZone — timezone will not be set.");

                finderPreview.Add(preview);
                StateHasChanged();
            }

            if (finderPreview.Count == 0)
                result = new RoomOperationResult { Success = false, Message = "0 rooms parsed. Check that your CSV has a header row with an identity column (PrimarySmtpAddress, Identity, EmailAddress, Mail, or Email)." };
        }
        catch (Exception ex)
        {
            result = new RoomOperationResult { Success = false, Message = $"Failed to parse CSV: {ex.Message}" };
        }
        finally { isLoading = false; }
    }

    // Submits the parsed Finder CSV as a DURABLE server-side job and returns immediately. The batch
    // then runs off this browser connection (survives closing the tab); progress streams back via the
    // jobs panel. Only resolvable rows are submitted; unresolved rows are reported up front. Ticket
    // validation and authorization are done here on the circuit (submission-time gate); the runner
    // re-checks the captured auth snapshot and the protected-principal gate per row.
    private async Task ApplyFinderCsv()
    {
        isLoading = true;
        isCsvProcessing = true;
        result = null;
        await Task.Yield();

        try
        {
            var ticket = csvFinderTicket.Trim();
            var ticketValidation = await ServiceNow.ValidateTicketAsync(ticket);
            if (!ticketValidation.IsValid)
            {
                result = new RoomOperationResult { Success = false, Message = $"Ticket validation failed: {ticketValidation.Message}" };
                AuditFinderAction("(bulk)", false, ticket, $"Ticket validation failed: {ticketValidation.Message}");
                return;
            }
            if (!await ReauthorizeAsync()) return;

            // Submit only rows that resolved in the preview (same guard the old inline loop applied).
            var rows = finderCsvData
                .Where((_, i) => i < finderPreview.Count && finderPreview[i].RoomResolved)
                .ToList();
            var skipped = finderCsvData.Count - rows.Count;

            if (rows.Count == 0)
            {
                result = new RoomOperationResult { Success = false, Message = "No resolvable rooms to submit." };
                return;
            }

            var jobId = EnqueueConferenceRoomJob(
                ExchangeAdminWeb.Services.Jobs.ConferenceRoomJobPayload.FinderJobType,
                new ExchangeAdminWeb.Services.Jobs.ConferenceRoomJobPayload
                {
                    Kind = ExchangeAdminWeb.Services.Jobs.ConferenceRoomJobPayload.FinderJobType,
                    FinderRows = rows
                },
                ticket);

            finderApplied = true;
            var skipNote = skipped > 0 ? $" ({skipped} unresolved row(s) were not submitted.)" : "";
            result = new RoomOperationResult
            {
                Success = true,
                Message = $"Submitted {rows.Count} room(s) as a background job. It will keep running if you close this tab — watch progress below.{skipNote}"
            };
            RefreshJobs();
        }
        catch (Exception ex)
        {
            result = new RoomOperationResult { Success = false, Message = ex.Message };
            AuditFinderAction("(bulk)", false, csvFinderTicket.Trim(), ex.Message);
        }
        finally { isLoading = false; isCsvProcessing = false; }
    }

