    private async Task<bool> ReauthorizeAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var authCheck = await AuthorizationService.AuthorizeAsync(authState.User, "ConferenceRooms");
        if (!authCheck.Succeeded)
        {
            result = new RoomOperationResult { Success = false, Message = "Authorization denied." };
            return false;
        }
        return true;
    }

    private async Task<RoomOperationResult?> CheckProtectedPrincipalAsync(string identity, string ticket, string action)
    {
        try
        {
            var (resolved, status) = await ProtectedPrincipalService.ResolveWithStatusAsync(identity);
            if (status is ProtectedPrincipalService.ResolutionStatus.Unavailable or ProtectedPrincipalService.ResolutionStatus.Ambiguous)
            {
                var reason = status == ProtectedPrincipalService.ResolutionStatus.Ambiguous
                    ? "Identity is ambiguous — matches multiple AD users."
                    : "Protection check unavailable.";
                AuditTypeAction(identity, false, ticket, $"{reason} — blocked");
                return new RoomOperationResult { Email = identity, Success = false, Message = reason };
            }
            if (resolved != null)
            {
                var check = await ProtectedPrincipalService.CheckAsync(resolved);
                if (check.CheckFailed)
                {
                    AuditTypeAction(identity, false, ticket, $"Protection check failed: {check.Reason}");
                    return new RoomOperationResult { Email = identity, Success = false, Message = $"Protection check failed: {check.Reason}" };
                }
                if (check.IsProtected)
                {
                    AuditTypeAction(identity, false, ticket, $"Protected principal — matched rules: {string.Join(", ", check.MatchedRules)}");
                    return new RoomOperationResult { Email = identity, Success = false, Message = "This is a protected principal. Operation not permitted." };
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "Protected principal check failed for {Identity} — blocking as precaution", identity);
            AuditTypeAction(identity, false, ticket, $"Protection check exception: {ex.Message}");
            return new RoomOperationResult { Email = identity, Success = false, Message = $"Protection check error: {ex.Message}" };
        }
        return null;
    }

    private void AuditFinderAction(string target, bool success, string ticket, string? error = null,
        Dictionary<string, object?>? oldValues = null, Dictionary<string, object?>? newValues = null)
    {
        try { Audit.LogConferenceRoomAction(currentUser, clientIpAddress, "ConferenceRooms_SetMetadata", target, success, ticket, errorDetail: error, oldValues: oldValues, newValues: newValues); }
        catch (Exception ex) { Logger.LogError(ex, "Audit failed"); }
    }

    private void AuditTypeAction(string target, bool success, string ticket, string? error = null,
        Dictionary<string, object?>? oldValues = null, Dictionary<string, object?>? newValues = null)
    {
        try { Audit.LogConferenceRoomAction(currentUser, clientIpAddress, "ConferenceRooms_SetType", target, success, ticket, errorDetail: error, oldValues: oldValues, newValues: newValues); }
        catch (Exception ex) { Logger.LogError(ex, "Audit failed"); }
    }

