@page "/conference-rooms"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "ConferenceRooms")]
@rendermode InteractiveServer
@inject ConferenceRoomService RoomService
@inject AuditService Audit
@inject ServiceNowService ServiceNow
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject ClientInfoService ClientInfo
@inject IJSRuntime JS
@inject ILogger<ConferenceRooms> Logger
@using CsvHelper
@using CsvHelper.Configuration
@using System.Globalization

<PageTitle>Conference Rooms</PageTitle>

@if (!authChecked)
{
    <div class="container-fluid">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Checking authorization...</span>
            </div>
        </div>
    </div>
    return;
}

<div class="container-fluid">
    <h1 class="mb-4">Conference Rooms</h1>

    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <button class="nav-link @(activeTab == "setup" ? "active" : "")" @onclick='() => activeTab = "setup"'>Room Setup</button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "type" ? "active" : "")" @onclick='() => activeTab = "type"'>Room Type</button>
        </li>
    </ul>

    @if (activeTab == "setup")
    {
        <div class="row">
            <div class="col-md-6">
                <div class="card mb-3">
                    <div class="card-header"><strong>Single Room Setup</strong></div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Room Email</label>
                            <input type="email" class="form-control" @bind="roomEmail" placeholder="room@company.com" disabled="@isLoading" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">City</label>
                            <input type="text" class="form-control" @bind="city" placeholder="City" disabled="@isLoading" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Building</label>
                            <input type="text" class="form-control" @bind="building" placeholder="Building name" disabled="@isLoading" />
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Capacity</label>
                                <input type="number" class="form-control" @bind="capacity" min="1" disabled="@isLoading" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Floor</label>
                                <input type="text" class="form-control" @bind="floor" placeholder="Floor" disabled="@isLoading" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Time Zone</label>
                            <TimezonePicker @bind-Value="timezone" Disabled="@isLoading" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Ticket Number</label>
                            <input type="text" class="form-control" @bind="ticketNumber" @bind:event="oninput" placeholder="INC/REQ number" disabled="@isLoading" />
                        </div>
                        <button class="btn btn-primary" @onclick="SetupSingleRoom"
                                disabled="@(isLoading || string.IsNullOrWhiteSpace(roomEmail) || string.IsNullOrWhiteSpace(ticketNumber))">
                            @if (isLoading && !isCsvProcessing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Setup Room
                        </button>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card">
                    <div class="card-header"><strong>CSV Bulk Upload</strong></div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Ticket Number</label>
                            <input type="text" class="form-control" @bind="csvTicketNumber" @bind:event="oninput" placeholder="INC/REQ number" disabled="@isLoading" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">CSV File</label>
                            <InputFile OnChange="HandleCsvUpload" accept=".csv" disabled="@isLoading" />
                            <button type="button" class="btn btn-outline-secondary btn-sm mt-1" @onclick="DownloadSampleCsv">Sample CSV</button>
                        </div>
                        @if (csvRows.Count > 0)
                        {
                            <p class="text-info">@csvRows.Count room(s) parsed from CSV.</p>
                            <button class="btn btn-primary" @onclick="ProcessCsvRooms"
                                    disabled="@(isLoading || string.IsNullOrWhiteSpace(csvTicketNumber))">
                                @if (isCsvProcessing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Process All
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (csvResults.Count > 0)
        {
            <div class="row mt-3">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header"><strong>Bulk Results</strong></div>
                        <div class="card-body p-0">
                            <table class="table table-sm mb-0">
                                <thead><tr><th>Room</th><th>Status</th><th>Message</th></tr></thead>
                                <tbody>
                                    @foreach (var r in csvResults)
                                    {
                                        <tr class="@(r.Success ? "" : "table-danger")">
                                            <td>@r.Email</td>
                                            <td>@(r.Success ? "OK" : "FAILED")</td>
                                            <td><small>@r.Message</small></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    @if (activeTab == "type")
    {
        <div class="row">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header"><strong>Set Room Type</strong></div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Room Email</label>
                            <input type="email" class="form-control" @bind="typeRoomEmail" placeholder="room@company.com" disabled="@isLoading" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Room Type</label>
                            <select class="form-select" @bind="selectedRoomType" disabled="@isLoading">
                                <option value="">-- Select --</option>
                                <option value="Standard">Standard (auto-accept, no conflicts)</option>
                                <option value="Workspace">Workspace (auto-accept, allows conflicts)</option>
                                <option value="Restricted">Restricted (auto-accept, approval required)</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Time Zone</label>
                            <TimezonePicker @bind-Value="typeTimezone" Disabled="@isLoading" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Ticket Number</label>
                            <input type="text" class="form-control" @bind="typeTicketNumber" @bind:event="oninput" placeholder="INC/REQ number" disabled="@isLoading" />
                        </div>
                        <button class="btn btn-primary" @onclick="SetRoomType"
                                disabled="@(isLoading || string.IsNullOrWhiteSpace(typeRoomEmail) || string.IsNullOrWhiteSpace(selectedRoomType) || string.IsNullOrWhiteSpace(typeTicketNumber))">
                            @if (isLoading) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Set Type
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (result != null)
    {
        <div class="row mt-3">
            <div class="col-md-6">
                <div class="alert @(result.Success ? "alert-success" : "alert-danger") alert-dismissible">
                    @result.Message
                    @if (!string.IsNullOrWhiteSpace(result.Detail))
                    {
                        <br /><small>@result.Detail</small>
                    }
                    <button type="button" class="btn-close" @onclick="() => result = null"></button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private string currentUser = "";
    private string clientIpAddress = "Unknown";
    private bool authChecked;
    private bool isLoading;
    private bool isCsvProcessing;
    private string activeTab = "setup";

    // Single room setup fields
    private string roomEmail = "";
    private string city = "";
    private string building = "";
    private int capacity = 1;
    private string floor = "";
    private string timezone = "";
    private string ticketNumber = "";

    // CSV fields
    private string csvTicketNumber = "";
    private List<CsvRoomRow> csvRows = new();
    private List<CsvRoomResult> csvResults = new();

    // Room Type fields
    private string typeRoomEmail = "";
    private string selectedRoomType = "";
    private string typeTimezone = "";
    private string typeTicketNumber = "";

    private PermissionResult? result;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUser = user.Identity?.Name ?? "Unknown";

        var authResult = await AuthorizationService.AuthorizeAsync(user, "ConferenceRooms");
        if (!authResult.Succeeded)
        {
            Navigation.NavigateTo("access-denied", forceLoad: true);
            return;
        }

        clientIpAddress = ClientInfo.IpAddress != "Unknown"
            ? ClientInfo.IpAddress
            : ClientInfo.GetIpForUser(currentUser);
        authChecked = true;
    }

    private async Task SetupSingleRoom()
    {
        isLoading = true;
        result = null;
        await Task.Yield();

        var email = roomEmail.Trim();
        var ticket = ticketNumber.Trim();
        var newCity = city.Trim();
        var newBuilding = building.Trim();
        var newFloor = floor.Trim();
        var newTimezone = timezone.Trim();

        try
        {
            var ticketValidation = await ServiceNow.ValidateTicketAsync(ticket);
            if (!ticketValidation.IsValid)
            {
                result = PermissionResult.Fail($"Ticket validation failed: {ticketValidation.Message}");
                try { Audit.LogConferenceRoomAction(currentUser, clientIpAddress, "ConferenceRooms_SetMetadata", email, false, ticket, errorDetail: $"Ticket validation failed: {ticketValidation.Message}"); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed"); }
                return;
            }

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var authCheck = await AuthorizationService.AuthorizeAsync(authState.User, "ConferenceRooms");
            if (!authCheck.Succeeded)
            {
                result = PermissionResult.Fail("Authorization denied.");
                try { Audit.LogConferenceRoomAction(currentUser, clientIpAddress, "ConferenceRooms_SetMetadata", email, false, ticket, errorDetail: "Authorization denied"); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed"); }
                return;
            }

            // Capture old values before mutation (best-effort)
            Dictionary<string, object?>? oldValues = null;
            try
            {
                var existing = await RoomService.GetRoomInfoAsync(email);
                if (existing != null)
                {
                    oldValues = new Dictionary<string, object?>
                    {
                        ["city"] = existing.City,
                        ["building"] = existing.Building,
                        ["capacity"] = existing.Capacity,
                        ["floor"] = existing.Floor,
                        ["timezone"] = existing.TimeZone
                    };
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Could not retrieve existing room info for {Room} before metadata update", email);
            }

            var newValues = new Dictionary<string, object?>
            {
                ["city"] = newCity,
                ["building"] = newBuilding,
                ["capacity"] = capacity,
                ["floor"] = newFloor,
                ["timezone"] = newTimezone
            };

            result = await RoomService.SetRoomMetadataAsync(email, newCity, newBuilding, capacity, newFloor, newTimezone);

            try { Audit.LogConferenceRoomAction(currentUser, clientIpAddress, "ConferenceRooms_SetMetadata", email, result.Success, ticket, errorDetail: result.Success ? null : result.Message, oldValues: oldValues, newValues: newValues); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for ConferenceRooms_SetMetadata"); }

            if (result.Success)
            {
                var addResult = await RoomService.AddToRoomListAsync(email, newCity);
                try { Audit.LogConferenceRoomAction(currentUser, clientIpAddress, "ConferenceRooms_AddToRoomList", email, addResult.Success, ticket, errorDetail: addResult.Success ? null : addResult.Message, newValues: new Dictionary<string, object?> { ["roomList"] = $"RoomList-{newCity}" }); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for ConferenceRooms_AddToRoomList"); }

                if (!addResult.Success)
                    result = PermissionResult.Fail($"Metadata set but failed to add to room list: {addResult.Message}");
            }
        }
        catch (Exception ex)
        {
            result = PermissionResult.Fail(ex.Message);
            try { Audit.LogConferenceRoomAction(currentUser, clientIpAddress, "ConferenceRooms_SetMetadata", email, false, ticket, errorDetail: ex.Message); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed"); }
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleCsvUpload(InputFileChangeEventArgs e)
    {
        csvRows = new();
        csvResults = new();
        result = null;

        try
        {
            await using var stream = e.File.OpenReadStream(maxAllowedSize: 16 * 1024 * 1024);
            using var reader = new System.IO.StreamReader(stream);
            var csvConfig = new CsvConfiguration(CultureInfo.InvariantCulture)
            {
                HeaderValidated = null,
                MissingFieldFound = null
            };
            using var csv = new CsvReader(reader, csvConfig);
            await csv.ReadAsync();
            csv.ReadHeader();

            while (await csv.ReadAsync())
            {
                var email = csv.GetField("PrimarySmtpAddress")?.Trim();
                if (string.IsNullOrWhiteSpace(email) || !email.Contains('@')) continue;

                csvRows.Add(new CsvRoomRow
                {
                    PrimarySmtpAddress = email,
                    City = csv.GetField("City")?.Trim() ?? "",
                    TimeZone = csv.GetField("TimeZone")?.Trim() ?? "",
                    Building = csv.GetField("Building")?.Trim() ?? "",
                    Capacity = int.TryParse(csv.GetField("Capacity")?.Trim(), out var c) ? c : 1,
                    Floor = csv.GetField("Floor")?.Trim() ?? ""
                });
            }
        }
        catch (Exception ex)
        {
            result = PermissionResult.Fail($"Failed to parse CSV: {ex.Message}");
        }
    }

    private async Task ProcessCsvRooms()
    {
        isLoading = true;
        isCsvProcessing = true;
        csvResults = new();
        await Task.Yield();

        try
        {
            var ticket = csvTicketNumber.Trim();
            var ticketValidation = await ServiceNow.ValidateTicketAsync(ticket);
            if (!ticketValidation.IsValid)
            {
                result = PermissionResult.Fail($"Ticket validation failed: {ticketValidation.Message}");
                try { Audit.LogConferenceRoomAction(currentUser, clientIpAddress, "ConferenceRooms_SetMetadata", "(bulk)", false, ticket, errorDetail: $"Ticket validation failed: {ticketValidation.Message}"); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed"); }
                return;
            }

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var authCheck = await AuthorizationService.AuthorizeAsync(authState.User, "ConferenceRooms");
            if (!authCheck.Succeeded)
            {
                result = PermissionResult.Fail("Authorization denied.");
                try { Audit.LogConferenceRoomAction(currentUser, clientIpAddress, "ConferenceRooms_SetMetadata", "(bulk)", false, ticket, errorDetail: "Authorization denied"); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed"); }
                return;
            }

            foreach (var row in csvRows)
            {
                try
                {
                    // Capture old values before mutation (best-effort)
                    Dictionary<string, object?>? oldValues = null;
                    try
                    {
                        var existing = await RoomService.GetRoomInfoAsync(row.PrimarySmtpAddress);
                        if (existing != null)
                        {
                            oldValues = new Dictionary<string, object?>
                            {
                                ["city"] = existing.City,
                                ["building"] = existing.Building,
                                ["capacity"] = existing.Capacity,
                                ["floor"] = existing.Floor,
                                ["timezone"] = existing.TimeZone
                            };
                        }
                    }
                    catch (Exception ex)
                    {
                        Logger.LogWarning(ex, "Could not retrieve existing room info for {Room} before bulk metadata update", row.PrimarySmtpAddress);
                    }

                    var newValues = new Dictionary<string, object?>
                    {
                        ["city"] = row.City,
                        ["building"] = row.Building,
                        ["capacity"] = row.Capacity,
                        ["floor"] = row.Floor,
                        ["timezone"] = row.TimeZone
                    };

                    var r = await RoomService.SetRoomMetadataAsync(row.PrimarySmtpAddress, row.City, row.Building, row.Capacity, row.Floor, row.TimeZone);

                    try { Audit.LogConferenceRoomAction(currentUser, clientIpAddress, "ConferenceRooms_SetMetadata", row.PrimarySmtpAddress, r.Success, ticket, errorDetail: r.Success ? null : r.Message, oldValues: oldValues, newValues: newValues); } catch (Exception auditEx) { Logger.LogError(auditEx, "Bulk audit failed for {Room}", row.PrimarySmtpAddress); }

                    if (r.Success && !string.IsNullOrWhiteSpace(row.City))
                    {
                        var addResult = await RoomService.AddToRoomListAsync(row.PrimarySmtpAddress, row.City);
                        try { Audit.LogConferenceRoomAction(currentUser, clientIpAddress, "ConferenceRooms_AddToRoomList", row.PrimarySmtpAddress, addResult.Success, ticket, errorDetail: addResult.Success ? null : addResult.Message, newValues: new Dictionary<string, object?> { ["roomList"] = $"RoomList-{row.City}" }); } catch (Exception auditEx) { Logger.LogError(auditEx, "Bulk audit failed for {Room}", row.PrimarySmtpAddress); }

                        if (!addResult.Success)
                            r = PermissionResult.Fail($"Metadata set but room list failed: {addResult.Message}");
                    }

                    csvResults.Add(new CsvRoomResult { Email = row.PrimarySmtpAddress, Success = r.Success, Message = r.Message });
                }
                catch (Exception ex)
                {
                    csvResults.Add(new CsvRoomResult { Email = row.PrimarySmtpAddress, Success = false, Message = ex.Message });
                    try { Audit.LogConferenceRoomAction(currentUser, clientIpAddress, "ConferenceRooms_SetMetadata", row.PrimarySmtpAddress, false, ticket, errorDetail: ex.Message); } catch (Exception auditEx) { Logger.LogError(auditEx, "Bulk audit failed for {Room}", row.PrimarySmtpAddress); }
                }

                StateHasChanged();
            }

            var successCount = csvResults.Count(r => r.Success);
            result = successCount == csvResults.Count
                ? PermissionResult.Ok($"All {successCount} rooms configured successfully.")
                : PermissionResult.Fail($"{successCount}/{csvResults.Count} rooms succeeded. See table for details.");
        }
        catch (Exception ex)
        {
            result = PermissionResult.Fail(ex.Message);
        }
        finally
        {
            isLoading = false;
            isCsvProcessing = false;
        }
    }

    private async Task SetRoomType()
    {
        isLoading = true;
        result = null;
        await Task.Yield();

        var email = typeRoomEmail.Trim();
        var ticket = typeTicketNumber.Trim();
        var newTimezone = typeTimezone.Trim();

        try
        {
            var ticketValidation = await ServiceNow.ValidateTicketAsync(ticket);
            if (!ticketValidation.IsValid)
            {
                result = PermissionResult.Fail($"Ticket validation failed: {ticketValidation.Message}");
                try { Audit.LogConferenceRoomAction(currentUser, clientIpAddress, "ConferenceRooms_SetType", email, false, ticket, errorDetail: $"Ticket validation failed: {ticketValidation.Message}"); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed"); }
                return;
            }

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var authCheck = await AuthorizationService.AuthorizeAsync(authState.User, "ConferenceRooms");
            if (!authCheck.Succeeded)
            {
                result = PermissionResult.Fail("Authorization denied.");
                try { Audit.LogConferenceRoomAction(currentUser, clientIpAddress, "ConferenceRooms_SetType", email, false, ticket, errorDetail: "Authorization denied"); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed"); }
                return;
            }

            // Capture old state before mutation (best-effort)
            Dictionary<string, object?>? oldTypeValues = null;
            try
            {
                var existing = await RoomService.GetRoomInfoAsync(email);
                if (existing != null)
                {
                    oldTypeValues = new Dictionary<string, object?>
                    {
                        ["timezone"] = existing.TimeZone
                    };
                }
            }
            catch (Exception ex)
            {
                Logger.LogWarning(ex, "Could not retrieve existing room info for {Room} before type change", email);
            }

            result = await RoomService.SetRoomTypeAsync(email, selectedRoomType, newTimezone);

            var newValues = new Dictionary<string, object?>
            {
                ["roomType"] = selectedRoomType,
                ["timezone"] = newTimezone
            };
            try { Audit.LogConferenceRoomAction(currentUser, clientIpAddress, "ConferenceRooms_SetType", email, result.Success, ticket, errorDetail: result.Success ? null : result.Message, oldValues: oldTypeValues, newValues: newValues); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for ConferenceRooms_SetType"); }
        }
        catch (Exception ex)
        {
            result = PermissionResult.Fail(ex.Message);
            try { Audit.LogConferenceRoomAction(currentUser, clientIpAddress, "ConferenceRooms_SetType", email, false, ticket, errorDetail: ex.Message); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed"); }
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DownloadSampleCsv()
    {
        var content = "PrimarySmtpAddress,City,TimeZone,Building,Capacity,Floor\nroom1@company.com,New York,Eastern Standard Time,HQ,10,3\n";
        var base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(content));
        await JS.InvokeVoidAsync("downloadFile", "conference_rooms_sample.csv", "text/csv", base64);
    }

    private class CsvRoomRow
    {
        public string PrimarySmtpAddress { get; set; } = "";
        public string City { get; set; } = "";
        public string TimeZone { get; set; } = "";
        public string Building { get; set; } = "";
        public int Capacity { get; set; }
        public string Floor { get; set; } = "";
    }

    private class CsvRoomResult
    {
        public string Email { get; set; } = "";
        public bool Success { get; set; }
        public string Message { get; set; } = "";
    }
}
