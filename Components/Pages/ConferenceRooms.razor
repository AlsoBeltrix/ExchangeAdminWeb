            await NotifyRoomAdminAsync("ConferenceRooms_SetType", email, result.Success, ticket, result.Message);
        }
        catch (Exception ex)
        {
            result = new RoomOperationResult { Email = email, Success = false, Message = ex.Message };
            AuditTypeAction(email, false, ticket, ex.Message);
            await NotifyRoomAdminAsync("ConferenceRooms_SetType", email, false, ticket, ex.Message);
        }
        finally { isLoading = false; }
    }

