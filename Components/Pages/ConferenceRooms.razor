    private async Task DownloadTypeSampleCsv()
    {
        var content = "Identity,Type,TimeZone,Site,Arbiter,RemoveExistingPermissions\n"
            + "room1@company.com,Standard,Eastern Standard Time,,,\n"
            + "room2@company.com,Video,Pacific Standard Time,,,\n"
            + "auditorium@company.com,Restricted,Central Standard Time,ADGT,,\n"
            + "boardroom@company.com,Executive,Eastern Standard Time,,,\n"
            + "ceo-conference@company.com,CEO,Eastern Standard Time,,,True\n";
        var base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(content));
        await JS.InvokeVoidAsync("downloadFile", "room_type_sample.csv", "text/csv", base64);
    }
}
