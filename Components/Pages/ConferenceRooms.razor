    private async Task SetSingleRoomType()
    {
        isLoading = true;
        result = null;
        await Task.Yield();

        var email = typeRoomEmail.Trim();
        var ticket = typeTicketNumber.Trim();

        try
        {
            var ticketValidation = await ServiceNow.ValidateTicketAsync(ticket);
            if (!ticketValidation.IsValid)
            {
                result = new RoomOperationResult { Email = email, Success = false, Message = $"Ticket validation failed: {ticketValidation.Message}" };
                AuditTypeAction(email, false, ticket, $"Ticket validation failed: {ticketValidation.Message}");
                return;
            }
            if (!await ReauthorizeAsync()) return;

            if (!Enum.TryParse<RoomType>(selectedRoomType, out var roomType))
            {
                result = new RoomOperationResult { Email = email, Success = false, Message = $"Invalid room type: {selectedRoomType}" };
                return;
            }

            // Protected principal check
            var ppResult = await CheckProtectedPrincipalAsync(email, ticket, "ConferenceRooms_SetType");
            if (ppResult != null) { result = ppResult; return; }

            using var op = OpTrace.BeginOperation("ConferenceRooms", "SetType", currentUser, clientIpAddress, email, ticket);
            result = await RoomService.SetRoomTypeAsync(email, roomType, typeTimezone.Trim(),
                selectedRoomType == "Restricted" ? typeSite : "none",
                string.IsNullOrWhiteSpace(typeArbiter) ? null : typeArbiter.Trim(),
                typeRemovePerms);
            op.Complete(result.Success, result.Message);

            var newValues = new Dictionary<string, object?>
            {
                ["roomType"] = selectedRoomType, ["timezone"] = typeTimezone,
                ["site"] = typeSite, ["removePerms"] = typeRemovePerms
            };
            AuditTypeAction(email, result.Success, ticket, result.Success ? null : result.Message, newValues: newValues);
        }
        catch (Exception ex)
        {
            result = new RoomOperationResult { Email = email, Success = false, Message = ex.Message };
            AuditTypeAction(email, false, ticket, ex.Message);
        }
        finally { isLoading = false; }
    }

