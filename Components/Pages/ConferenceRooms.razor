@page "/conference-rooms"
@using Microsoft.AspNetCore.Authorization
@using ExchangeAdminWeb.Models
@attribute [Authorize(Policy = "ConferenceRooms")]
@rendermode InteractiveServer
@inject ConferenceRoomService RoomService
@inject AuditService Audit
@inject ServiceNowService ServiceNow
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject ClientInfoService ClientInfo
@inject OperationTraceService OpTrace
@inject IJSRuntime JS
@inject ILogger<ConferenceRooms> Logger
@inject ProtectedPrincipalService ProtectedPrincipalService

<PageTitle>Conference Rooms</PageTitle>

@if (!authChecked)
{
    <div class="container-fluid">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Checking authorization...</span>
            </div>
        </div>
    </div>
    return;
}

<div class="container-fluid">
    <div class="alert alert-info py-2 mb-3">
        <small>All conference room operations are logged for audit purposes. CSV operations show a preview before applying changes.</small>
    </div>
    <h1 class="mb-4">Conference Rooms</h1>

    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <button class="nav-link @(activeTab == "finder" ? "active" : "")" @onclick='() => activeTab = "finder"'>Room Finder</button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(activeTab == "type" ? "active" : "")" @onclick='() => activeTab = "type"'>Room Type</button>
        </li>
    </ul>

    @* ===== TAB 1: ROOM FINDER (metadata + room list) ===== *@
    @if (activeTab == "finder")
    {
        <div class="row">
            <div class="col-md-6">
                <div class="card mb-3">
                    <div class="card-header"><strong>Single Room Setup</strong></div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Room Email</label>
                            <RecipientAutocomplete @bind-Value="roomEmail" Placeholder="room@company.com" Disabled="@isLoading" />
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">City</label>
                                <input type="text" class="form-control" @bind="city" placeholder="City" disabled="@isLoading" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Country</label>
                                <input type="text" class="form-control" @bind="countryOrRegion" placeholder="USA" disabled="@isLoading" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">State</label>
                                <input type="text" class="form-control" @bind="state" placeholder="MA" disabled="@isLoading" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Building</label>
                                <input type="text" class="form-control" @bind="building" placeholder="Building name" disabled="@isLoading" />
                                <small class="form-text text-muted">Determines the room list (<em>&lt;Building&gt; Conference Rooms</em>). Leave blank to skip room-list assignment.</small>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold">Capacity</label>
                                <input type="number" class="form-control" @bind="capacity" min="1" disabled="@isLoading" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold">Floor</label>
                                <input type="text" class="form-control" @bind="floor" placeholder="Floor" disabled="@isLoading" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label fw-semibold">Floor Label</label>
                                <input type="text" class="form-control" @bind="floorLabel" placeholder="Second Floor" disabled="@isLoading" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Display Device</label>
                                <input type="text" class="form-control" @bind="displayDevice" placeholder="TV" disabled="@isLoading" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Video Device</label>
                                <input type="text" class="form-control" @bind="videoDevice" placeholder="Polycom" disabled="@isLoading" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Time Zone</label>
                            <TimezonePicker @bind-Value="timezone" Disabled="@isLoading" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Ticket Number</label>
                            <input type="text" class="form-control" @bind="ticketNumber" @bind:event="oninput" placeholder="INC/REQ number" disabled="@isLoading" />
                        </div>
                        <button class="btn btn-primary" @onclick="SetupSingleRoom"
                                disabled="@(isLoading || string.IsNullOrWhiteSpace(roomEmail) || string.IsNullOrWhiteSpace(ticketNumber))">
                            @if (isLoading && !isCsvProcessing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Setup Room
                        </button>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card">
                    <div class="card-header"><strong>CSV Bulk Upload — Room Finder</strong></div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Ticket Number</label>
                            <input type="text" class="form-control" @bind="csvFinderTicket" @bind:event="oninput" placeholder="INC/REQ number" disabled="@isLoading" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">CSV File</label>
                            <InputFile OnChange="HandleFinderCsvUpload" accept=".csv" disabled="@isLoading" />
                            <button type="button" class="btn btn-outline-secondary btn-sm mt-1" @onclick="DownloadFinderSampleCsv">Sample CSV</button>
                        </div>
                        @if (finderPreview.Count > 0 && !finderApplied)
                        {
                            <div class="alert alert-info py-2">
                                <strong>@finderPreview.Count room(s)</strong> parsed. Review the preview below, then click Apply.
                            </div>
                            @if (string.IsNullOrWhiteSpace(csvFinderTicket))
                            {
                                <div class="alert alert-warning py-2">
                                    <small>Enter a <strong>Ticket Number</strong> above to enable Apply Changes.</small>
                                </div>
                            }
                            <button class="btn btn-success" @onclick="ApplyFinderCsv"
                                    disabled="@(isLoading || string.IsNullOrWhiteSpace(csvFinderTicket))">
                                @if (isCsvProcessing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Apply Changes
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Finder CSV Preview *@
        @if (finderPreview.Count > 0 && !finderApplied)
        {
            <div class="card mt-3">
                <div class="card-header"><strong>Preview — Room Finder</strong></div>
                <div class="card-body p-0" style="overflow-x:auto">
                    <table class="table table-sm table-striped mb-0">
                        <thead>
                            <tr>
                                <th>#</th><th>Email</th><th>Name</th><th>City</th><th>Country</th><th>State</th>
                                <th>Building</th><th>Capacity</th><th>Floor</th><th>Floor Label</th>
                                <th>Display</th><th>Video</th><th>TimeZone</th><th>Room List</th><th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in finderPreview)
                            {
                                <tr class="@(!row.RoomResolved ? "table-danger" : row.Warnings.Count > 0 ? "table-warning" : "")">
                                    <td>@row.RowIndex</td>
                                    <td><small>@row.Email</small></td>
                                    <td>@row.DisplayName</td>
                                    <td>@row.City</td>
                                    <td>@row.CountryOrRegion</td>
                                    <td>@row.State</td>
                                    <td>@row.Building</td>
                                    <td>@row.Capacity</td>
                                    <td>@row.Floor</td>
                                    <td>@row.FloorLabel</td>
                                    <td>@row.DisplayDeviceName</td>
                                    <td>@row.VideoDeviceName</td>
                                    <td><small>@row.TimeZone</small></td>
                                    <td>
                                        <small>
                                            @row.RoomListName
                                            @if (row.IsLegacyRoomList) { <span class="badge bg-warning text-dark">legacy</span> }
                                            @if (!row.RoomListExists && row.RoomResolved) { <span class="badge bg-info">new</span> }
                                        </small>
                                    </td>
                                    <td>
                                        @if (!row.RoomResolved) { <span class="text-danger">@row.ResolveError</span> }
                                        else if (row.Warnings.Count > 0)
                                        {
                                            @foreach (var w in row.Warnings) { <small class="text-warning d-block">@w</small> }
                                        }
                                        else { <span class="text-success">Ready</span> }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @* Finder Results *@
        @if (finderResults.Count > 0)
        {
            <div class="card mt-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>Results</strong>
                    <small class="text-muted">@finderResults.Count(r => r.Success) / @finderResults.Count succeeded</small>
                </div>
                <div class="card-body p-0" style="overflow-x:auto">
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Room</th><th>Status</th><th>Steps</th><th>Message</th></tr></thead>
                        <tbody>
                            @foreach (var r in finderResults)
                            {
                                <tr class="@(r.Success ? "" : r.AdAttributeFixRequired ? "table-warning" : "table-danger")">
                                    <td><small>@r.Email</small></td>
                                    <td>
                                        @if (r.AdAttributeFixRequired)
                                        { <span class="badge bg-warning text-dark">AD Fix Required</span> }
                                        else if (r.Success) { <span class="text-success">OK</span> }
                                        else { <span class="text-danger">FAILED</span> }
                                    </td>
                                    <td>
                                        @foreach (var s in r.Steps)
                                        {
                                            <small class="d-block @(s.Success ? "text-muted" : "text-danger")">
                                                @(s.Success ? "+" : "x") @s.Stage @(s.Error != null ? $"— {s.Error}" : "")
                                            </small>
                                        }
                                    </td>
                                    <td>
                                        <small>@r.Message</small>
                                        @if (r.AdAttributeFixRequired)
                                        {
                                            <br /><small class="text-warning">@r.AdAttributeDetail</small>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }

    @* ===== TAB 2: ROOM TYPE ===== *@
    @if (activeTab == "type")
    {
        <div class="row">
            <div class="col-md-6">
                <div class="card mb-3">
                    <div class="card-header"><strong>Set Room Type</strong></div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Room Email</label>
                            <RecipientAutocomplete @bind-Value="typeRoomEmail" Placeholder="room@company.com" Disabled="@isLoading" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Room Type</label>
                            <select class="form-select" @bind="selectedRoomType" disabled="@isLoading">
                                <option value="">-- Select --</option>
                                <option value="Standard">Standard — open booking, visible to all</option>
                                <option value="Video">Video — open booking with video equipment</option>
                                <option value="Restricted">Restricted — limited booking, requires approval</option>
                                <option value="Exception">Exception — specific group access only</option>
                                <option value="CEO">CEO — highest restriction, CEO admins only</option>
                                <option value="Executive">Executive — board rooms, exec staff only</option>
                            </select>
                        </div>
                        @if (selectedRoomType == "Restricted")
                        {
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Site</label>
                                <select class="form-select" @bind="typeSite" disabled="@isLoading">
                                    <option value="none">Default</option>
                                    <option value="ADGT">ADGT</option>
                                </select>
                            </div>
                        }
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Time Zone</label>
                            <TimezonePicker @bind-Value="typeTimezone" Disabled="@isLoading" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Arbiter Group</label>
                            <input type="text" class="form-control" @bind="typeArbiter" placeholder="ConfSiteAdmins (default)" disabled="@isLoading" />
                        </div>
                        <div class="form-check mb-3">
                            <input type="checkbox" class="form-check-input" id="removePerms" @bind="typeRemovePerms" disabled="@isLoading" />
                            <label class="form-check-label" for="removePerms">Remove existing calendar permissions</label>
                        </div>
                        @if (selectedRoomType == "CEO")
                        {
                            <div class="alert alert-warning py-2">
                                <small><strong>CEO type always removes all existing calendar permissions</strong> before applying new ones. This is automatic and cannot be disabled.</small>
                            </div>
                        }
                        @if (typeRemovePerms && selectedRoomType != "CEO")
                        {
                            <div class="alert alert-danger py-2">
                                <small><strong>Warning:</strong> All existing calendar permissions (except Default/Anonymous) will be removed before applying new ones. This is destructive and cannot be undone.</small>
                            </div>
                        }
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Ticket Number</label>
                            <input type="text" class="form-control" @bind="typeTicketNumber" @bind:event="oninput" placeholder="INC/REQ number" disabled="@isLoading" />
                        </div>
                        <button class="btn btn-primary" @onclick="SetSingleRoomType"
                                disabled="@(isLoading || string.IsNullOrWhiteSpace(typeRoomEmail) || string.IsNullOrWhiteSpace(selectedRoomType) || string.IsNullOrWhiteSpace(typeTicketNumber))">
                            @if (isLoading && !isCsvProcessing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Set Type
                        </button>
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card">
                    <div class="card-header"><strong>CSV Bulk Upload — Room Type</strong></div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Ticket Number</label>
                            <input type="text" class="form-control" @bind="csvTypeTicket" @bind:event="oninput" placeholder="INC/REQ number" disabled="@isLoading" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">CSV File</label>
                            <InputFile OnChange="HandleTypeCsvUpload" accept=".csv" disabled="@isLoading" />
                            <button type="button" class="btn btn-outline-secondary btn-sm mt-1" @onclick="DownloadTypeSampleCsv">Sample CSV</button>
                        </div>
                        @if (typePreview.Count > 0 && !typeApplied)
                        {
                            <div class="alert alert-info py-2">
                                <strong>@typePreview.Count room(s)</strong> parsed. Review the preview below, then click Apply.
                            </div>
                            <button class="btn btn-success" @onclick="ApplyTypeCsv"
                                    disabled="@(isLoading || string.IsNullOrWhiteSpace(csvTypeTicket))">
                                @if (isCsvProcessing) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Apply Changes
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Type CSV Preview *@
        @if (typePreview.Count > 0 && !typeApplied)
        {
            <div class="card mt-3">
                <div class="card-header"><strong>Preview — Room Type Configuration</strong></div>
                <div class="card-body p-0" style="overflow-x:auto">
                    <table class="table table-sm table-striped mb-0">
                        <thead>
                            <tr>
                                <th>#</th><th>Email</th><th>Type</th><th>Site</th><th>TimeZone</th>
                                <th>CustomAttribute9</th><th>MailTip</th><th>Default/Anonymous</th>
                                <th>BookInPolicy</th><th>Calendar Permissions</th><th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in typePreview)
                            {
                                <tr class="@(!row.RoomResolved ? "table-danger" : row.Warnings.Count > 0 ? "table-warning" : "")">
                                    <td>@row.RowIndex</td>
                                    <td><small>@row.Email</small></td>
                                    <td><strong>@row.Type</strong></td>
                                    <td>@(row.Site != "none" ? row.Site : "")</td>
                                    <td><small>@row.TimeZone</small></td>
                                    <td><small>@row.CustomAttribute9Tag</small></td>
                                    <td><small class="text-truncate d-inline-block" style="max-width:200px" title="@row.MailTip">@row.MailTip</small></td>
                                    <td><small>@row.DefaultCalPermission / @row.AnonymousCalPermission</small></td>
                                    <td>
                                        @foreach (var g in row.BookInPolicyGroups)
                                        {
                                            <small class="d-block text-muted">@g</small>
                                        }
                                    </td>
                                    <td>
                                        @foreach (var p in row.CalendarPermissions)
                                        {
                                            <small class="d-block">@p.User → @p.AccessRights</small>
                                        }
                                    </td>
                                    <td>
                                        @if (!row.RoomResolved) { <span class="text-danger">@row.ResolveError</span> }
                                        else if (row.Warnings.Count > 0)
                                        {
                                            @foreach (var w in row.Warnings) { <small class="text-warning d-block">@w</small> }
                                        }
                                        else { <span class="text-success">Ready</span> }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        @* Type Results *@
        @if (typeResults.Count > 0)
        {
            <div class="card mt-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>Results</strong>
                    <small class="text-muted">@typeResults.Count(r => r.Success) / @typeResults.Count succeeded</small>
                </div>
                <div class="card-body p-0" style="overflow-x:auto">
                    <table class="table table-sm mb-0">
                        <thead><tr><th>Room</th><th>Status</th><th>Steps</th><th>Message</th></tr></thead>
                        <tbody>
                            @foreach (var r in typeResults)
                            {
                                <tr class="@(r.Success ? "" : "table-danger")">
                                    <td><small>@r.Email</small></td>
                                    <td>@(r.Success ? "OK" : "FAILED")</td>
                                    <td>
                                        @foreach (var s in r.Steps)
                                        {
                                            <small class="d-block @(s.Success ? "text-muted" : "text-danger")">
                                                @(s.Success ? "+" : "x") @s.Stage @(s.Error != null ? $"— {s.Error}" : "")
                                            </small>
                                        }
                                    </td>
                                    <td><small>@r.Message</small></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }

    @* Shared single-operation result *@
    @if (result != null)
    {
        <div class="row mt-3">
            <div class="col-md-8">
                <div class="alert @(result.Success ? "alert-success" : result.AdAttributeFixRequired ? "alert-warning" : "alert-danger") alert-dismissible">
                    @result.Message
                    @if (result.AdAttributeFixRequired)
                    {
                        <br /><small>@result.AdAttributeDetail</small>
                    }
                    @if (result.Steps.Count > 0)
                    {
                        <hr class="my-2" />
                        @foreach (var s in result.Steps)
                        {
                            <small class="d-block @(s.Success ? "text-muted" : "text-danger")">
                                @(s.Success ? "+" : "x") @s.Stage @(s.Error != null ? $"— {s.Error}" : "")
                            </small>
                        }
                    }
                    <button type="button" class="btn-close" @onclick="() => result = null"></button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private string currentUser = "";
    private string clientIpAddress = "Unknown";
    private bool authChecked;
    private bool isLoading;
    private bool isCsvProcessing;
    private string activeTab = "finder";

    // Single room finder fields
    private string roomEmail = "";
    private string city = "";
    private string countryOrRegion = "";
    private string state = "";
    private string building = "";
    private int capacity = 1;
    private string floor = "";
    private string floorLabel = "";
    private string displayDevice = "";
    private string videoDevice = "";
    private string timezone = "";
    private string ticketNumber = "";

    // Finder CSV
    private string csvFinderTicket = "";
    private List<RoomFinderPreviewRow> finderPreview = new();
    private List<RoomOperationResult> finderResults = new();
    private bool finderApplied;
    private List<FinderCsvRow> finderCsvData = new();

    // Single room type fields
    private string typeRoomEmail = "";
    private string selectedRoomType = "";
    private string typeTimezone = "";
    private string typeArbiter = "";
    private string typeSite = "none";
    private bool typeRemovePerms;
    private string typeTicketNumber = "";

    // Type CSV
    private string csvTypeTicket = "";
    private List<RoomTypePreviewRow> typePreview = new();
    private List<RoomOperationResult> typeResults = new();
    private bool typeApplied;
    private List<TypeCsvRow> typeCsvData = new();

    private RoomOperationResult? result;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUser = user.Identity?.Name ?? "Unknown";

        var authResult = await AuthorizationService.AuthorizeAsync(user, "ConferenceRooms");
        if (!authResult.Succeeded)
        {
            Navigation.NavigateTo("access-denied", forceLoad: true);
            return;
        }

        clientIpAddress = ClientInfo.IpAddress != "Unknown"
            ? ClientInfo.IpAddress
            : ClientInfo.GetIpForUser(currentUser);
        authChecked = true;
    }

    // =========================================================================
    // ROOM FINDER — Single Room
    // =========================================================================

    private async Task SetupSingleRoom()
    {
        isLoading = true;
        result = null;
        await Task.Yield();

        var email = roomEmail.Trim();
        var ticket = ticketNumber.Trim();

        try
        {
            var ticketValidation = await ServiceNow.ValidateTicketAsync(ticket);
            if (!ticketValidation.IsValid)
            {
                result = new RoomOperationResult { Email = email, Success = false, Message = $"Ticket validation failed: {ticketValidation.Message}" };
                AuditFinderAction(email, false, ticket, $"Ticket validation failed: {ticketValidation.Message}");
                return;
            }

            if (!await ReauthorizeAsync()) return;

            // Capture old values
            Dictionary<string, object?>? oldValues = null;
            try
            {
                var existing = await RoomService.GetRoomInfoAsync(email);
                if (existing != null)
                    oldValues = new() { ["city"] = existing.City, ["building"] = existing.Building, ["capacity"] = existing.Capacity, ["floor"] = existing.Floor, ["timezone"] = existing.TimeZone };
            }
            catch { }

            using var op = OpTrace.BeginOperation("ConferenceRooms", "SetMetadata", currentUser, clientIpAddress, email, ticket);

            result = await RoomService.SetRoomMetadataAndListAsync(
                email, city.Trim(), building.Trim(), capacity,
                floor.Trim(), floorLabel.Trim(), displayDevice.Trim(), videoDevice.Trim(),
                countryOrRegion.Trim(), state.Trim(), timezone.Trim());

            op.Complete(result.Success, result.Message);

            var newValues = new Dictionary<string, object?>
            {
                ["city"] = city, ["building"] = building, ["capacity"] = capacity,
                ["floor"] = floor, ["floorLabel"] = floorLabel, ["timezone"] = timezone,
                ["countryOrRegion"] = countryOrRegion, ["state"] = state
            };
            AuditFinderAction(email, result.Success, ticket, result.Success ? null : result.Message, oldValues, newValues);
        }
        catch (Exception ex)
        {
            result = new RoomOperationResult { Email = email, Success = false, Message = ex.Message };
            AuditFinderAction(email, false, ticket, ex.Message);
        }
        finally { isLoading = false; }
    }

    // =========================================================================
    // ROOM FINDER — CSV Upload + Preview + Apply
    // =========================================================================

    private async Task HandleFinderCsvUpload(InputFileChangeEventArgs e)
    {
        finderPreview = new();
        finderResults = new();
        finderApplied = false;
        finderCsvData = new();
        result = null;
        isLoading = true;
        await Task.Yield();

        try
        {
            List<FinderCsvParseResult> parsed;
            await using (var stream = e.File.OpenReadStream(maxAllowedSize: 16 * 1024 * 1024))
            {
                parsed = await ConferenceRoomService.ParseFinderCsvAsync(stream);
            }

            // Keep finderCsvData and finderPreview index-aligned (ApplyFinderCsv
            // pairs them by index). Skipped rows get a placeholder data row plus a
            // non-resolved preview row so they're visible and flow through Apply
            // as per-row failures rather than vanishing.
            foreach (var pr in parsed)
            {
                if (pr.Skipped)
                {
                    finderCsvData.Add(new FinderCsvRow { Email = "(row " + pr.RowIndex + ")" });
                    finderPreview.Add(new RoomFinderPreviewRow
                    {
                        RowIndex = pr.RowIndex,
                        Email = "(row " + pr.RowIndex + ")",
                        RoomResolved = false,
                        ResolveError = pr.SkipReason + " | Columns found: " + string.Join(", ", pr.AvailableColumns)
                    });
                    StateHasChanged();
                    continue;
                }

                var row = pr.Row!;
                finderCsvData.Add(row);

                var preview = new RoomFinderPreviewRow
                {
                    RowIndex = pr.RowIndex,
                    Email = row.Email,
                    City = row.City,
                    CountryOrRegion = row.CountryOrRegion,
                    State = row.State,
                    Building = row.Building,
                    Capacity = row.Capacity,
                    Floor = row.Floor,
                    FloorLabel = row.FloorLabel,
                    DisplayDeviceName = row.DisplayDeviceName,
                    VideoDeviceName = row.VideoDeviceName,
                    TimeZone = row.TimeZone
                };

                try
                {
                    var info = await RoomService.GetRoomInfoAsync(row.Email);
                    if (info != null)
                    {
                        preview.RoomResolved = true;
                        preview.DisplayName = info.DisplayName;
                    }
                    else
                    {
                        preview.RoomResolved = false;
                        preview.ResolveError = "Room not found";
                    }
                }
                catch (Exception ex)
                {
                    preview.RoomResolved = false;
                    preview.ResolveError = ex.Message;
                }

                // The room list IS the building (Room Finder groups it under the room's
                // City metadata). Resolve/name the list from Building, not City.
                if (!string.IsNullOrWhiteSpace(row.Building) && preview.RoomResolved)
                {
                    try
                    {
                        var (listName, listExists, isLegacy, strayCityList) = await RoomService.ResolveRoomListAsync(row.Building, row.City);
                        preview.RoomListName = listName ?? ConferenceRoomService.BuildRoomListName(row.Building);
                        preview.RoomListExists = listExists;
                        preview.IsLegacyRoomList = isLegacy;
                        preview.StrayCityRoomListName = strayCityList;
                        if (isLegacy)
                            preview.Warnings.Add($"Using legacy room list '{listName}'. New naming would be '{ConferenceRoomService.BuildRoomListName(row.Building)}'.");
                        if (!string.IsNullOrWhiteSpace(strayCityList))
                            preview.Warnings.Add($"A city-named list '{strayCityList}' also exists. This room will be added to '{preview.RoomListName}' (the building list). Review the stray list manually.");
                    }
                    catch { preview.RoomListName = ConferenceRoomService.BuildRoomListName(row.Building); }
                }

                if (string.IsNullOrWhiteSpace(row.Building))
                    preview.Warnings.Add("Missing Building — will not be added to a room list.");
                if (string.IsNullOrWhiteSpace(row.TimeZone))
                    preview.Warnings.Add("Missing TimeZone — timezone will not be set.");

                finderPreview.Add(preview);
                StateHasChanged();
            }

            if (finderPreview.Count == 0)
                result = new RoomOperationResult { Success = false, Message = "0 rooms parsed. Check that your CSV has a header row with an identity column (PrimarySmtpAddress, Identity, EmailAddress, Mail, or Email)." };
        }
        catch (Exception ex)
        {
            result = new RoomOperationResult { Success = false, Message = $"Failed to parse CSV: {ex.Message}" };
        }
        finally { isLoading = false; }
    }

    private async Task ApplyFinderCsv()
    {
        isLoading = true;
        isCsvProcessing = true;
        finderResults = new();
        await Task.Yield();

        try
        {
            var ticket = csvFinderTicket.Trim();
            var ticketValidation = await ServiceNow.ValidateTicketAsync(ticket);
            if (!ticketValidation.IsValid)
            {
                result = new RoomOperationResult { Success = false, Message = $"Ticket validation failed: {ticketValidation.Message}" };
                AuditFinderAction("(bulk)", false, ticket, $"Ticket validation failed: {ticketValidation.Message}");
                return;
            }
            if (!await ReauthorizeAsync()) return;

            for (int i = 0; i < finderCsvData.Count; i++)
            {
                var row = finderCsvData[i];
                var preview = finderPreview[i];
                if (!preview.RoomResolved)
                {
                    finderResults.Add(new RoomOperationResult { Email = row.Email, Success = false, Message = preview.ResolveError ?? "Not resolved" });
                    continue;
                }

                try
                {
                    using var op = OpTrace.BeginOperation("ConferenceRooms", "SetMetadata_Bulk", currentUser, clientIpAddress, row.Email, ticket);
                    var r = await RoomService.SetRoomMetadataAndListAsync(
                        row.Email, row.City, row.Building, row.Capacity,
                        row.Floor, row.FloorLabel, row.DisplayDeviceName, row.VideoDeviceName,
                        row.CountryOrRegion, row.State, row.TimeZone);
                    op.Complete(r.Success, r.Message);

                    finderResults.Add(r);
                    AuditFinderAction(row.Email, r.Success, ticket, r.Success ? null : r.Message);
                }
                catch (Exception ex)
                {
                    finderResults.Add(new RoomOperationResult { Email = row.Email, Success = false, Message = ex.Message });
                    AuditFinderAction(row.Email, false, ticket, ex.Message);
                }
                StateHasChanged();
            }

            finderApplied = true;
            var success = finderResults.Count(r => r.Success);
            result = new RoomOperationResult
            {
                Success = success == finderResults.Count,
                Message = $"{success}/{finderResults.Count} rooms configured."
            };
        }
        catch (Exception ex)
        {
            result = new RoomOperationResult { Success = false, Message = ex.Message };
        }
        finally { isLoading = false; isCsvProcessing = false; }
    }

