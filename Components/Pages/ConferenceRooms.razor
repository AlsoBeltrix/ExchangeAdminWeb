    // Builds a BulkJob from the captured submission context and enqueues it. Returns the job id.
    private string EnqueueConferenceRoomJob(string jobType, ExchangeAdminWeb.Services.Jobs.ConferenceRoomJobPayload payload, string ticket)
    {
        var job = new ExchangeAdminWeb.Services.Jobs.BulkJob
        {
            Id = Guid.NewGuid().ToString("N"),
            ModuleId = ExchangeAdminWeb.Services.Jobs.ConferenceRoomBulkProcessor.ModuleName,
            JobType = jobType,
            Status = ExchangeAdminWeb.Services.Jobs.BulkJobStatus.Queued,
            SubmittedBy = currentUser,
            SubmittedByDisplay = currentUser,
            SubmittedIp = clientIpAddress,
            Ticket = ticket,
            AuthSnapshotJson = authSnapshot?.ToJson(),
            PayloadJson = System.Text.Json.JsonSerializer.Serialize(payload),
            SubmittedAtUtc = DateTime.UtcNow
        };
        return BulkJobs.Enqueue(job);
    }

