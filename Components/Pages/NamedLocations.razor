@page "/named-locations"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "NamedLocations")]
@rendermode InteractiveServer
@inject NamedLocationsService LocationService
@inject AuditService Audit
@inject EmailService Email
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject ClientInfoService ClientInfo
@inject ILogger<NamedLocations> Logger

<PageTitle>Named Locations</PageTitle>

@if (!authChecked)
{
    <div class="container-fluid">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Checking authorization...</span>
            </div>
        </div>
    </div>
    return;
}

<div class="container-fluid">
    <div class="alert alert-info py-2 mb-3">
        <small>Manage Conditional Access named locations for trusted IP ranges and country/region lists.</small>
    </div>
    <h1 class="mb-4">Named Locations</h1>

    @if (!LocationService.IsAvailable)
    {
        <div class="alert alert-danger">Named Locations module is not configured. Set Graph App Delinea Secret ID in Module Config.</div>
        return;
    }

    @if (operationResult != null)
    {
        <div class="alert @(operationResult.Success ? "alert-success" : "alert-danger") alert-dismissible">
            @operationResult.Message
            <button type="button" class="btn-close" @onclick="() => operationResult = null"></button>
        </div>
    }

    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>Named Locations</strong>
                    <div>
                        <button class="btn btn-outline-primary btn-sm me-1" @onclick="LoadLocations" disabled="@isLoading">
                            @if (isLoading && editingLocation == null) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Refresh
                        </button>
                        <button class="btn btn-primary btn-sm" @onclick="ShowCreateForm" disabled="@isLoading">New Location</button>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (loadError != null)
                    {
                        <div class="alert alert-danger m-3">@loadError</div>
                    }
                    else if (locations.Count > 0)
                    {
                        <div style="max-height: calc(100vh - 260px); overflow-y: auto;">
                            <table class="table table-sm mb-0">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th style="width: 140px;">Type</th>
                                        <th style="width: 90px;">Trusted</th>
                                        <th style="width: 140px;">Details</th>
                                        <th style="width: 80px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var loc in locations)
                                    {
                                        <tr class="@(editingLocation?.Id == loc.Id ? "table-active" : "")">
                                            <td>@loc.DisplayName</td>
                                            <td>@(loc.LocationType == NamedLocationType.Ip ? "IP ranges" : "Countries")</td>
                                            <td>@(loc.IsTrusted ? "Yes" : "No")</td>
                                            <td>
                                                <small class="text-muted">
                                                    @if (loc.LocationType == NamedLocationType.Ip)
                                                    {
                                                        @($"{loc.IpRanges.Count} range(s)")
                                                    }
                                                    else
                                                    {
                                                        @($"{loc.CountryCodes.Count} country/region(s)")
                                                    }
                                                </small>
                                            </td>
                                            <td>
                                                <button class="btn btn-outline-secondary btn-sm" @onclick="() => EditLocation(loc)" disabled="@isOperating">Edit</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else if (!isLoading)
                    {
                        <p class="text-muted p-3 mb-0">No named locations found.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card" style="position: sticky; top: 1rem;">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>@(showForm ? (editingLocation != null ? "Edit Location" : "New Location") : "Location Details")</strong>
                    @if (showForm)
                    {
                        <button class="btn btn-outline-secondary btn-sm" @onclick="CancelForm">Cancel</button>
                    }
                </div>
                <div class="card-body">
                    @if (!showForm)
                    {
                        <p class="text-muted mb-3">Select a named location to edit it, or create a new one.</p>
                        <button class="btn btn-primary btn-sm" @onclick="ShowCreateForm" disabled="@isLoading">New Location</button>
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Display Name</label>
                            <input type="text" class="form-control" @bind="formDisplayName" disabled="@isOperating" />
                        </div>

                        @if (editingLocation == null)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Type</label>
                                <select class="form-select" @bind="formType" disabled="@isOperating">
                                    <option value="ip">IP Ranges</option>
                                    <option value="country">Countries/Regions</option>
                                </select>
                            </div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Type</label>
                                <input type="text" class="form-control" value="@(editingLocation.LocationType == NamedLocationType.Ip ? "IP Ranges" : "Countries/Regions")" disabled />
                            </div>
                        }

                        @if (EffectiveType == "ip")
                        {
                            <div class="mb-3">
                                <label class="form-label fw-semibold">IP Ranges (CIDR, one per line)</label>
                                <textarea class="form-control" rows="5" @bind="formIpRanges" placeholder="10.0.0.0/8&#10;192.168.1.0/24&#10;2001:db8::/32" disabled="@isOperating"></textarea>
                            </div>
                            <div class="mb-3 form-check">
                                <input type="checkbox" class="form-check-input" id="chkTrusted" @bind="formIsTrusted" disabled="@isOperating" />
                                <label class="form-check-label" for="chkTrusted">Mark as trusted</label>
                            </div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Country Codes (ISO 3166-1 alpha-2)</label>
                                <CountryCodePicker @bind-Value="formCountryCodes" Disabled="@isOperating" />
                            </div>
                            <div class="mb-3 form-check">
                                <input type="checkbox" class="form-check-input" id="chkUnknown" @bind="formIncludeUnknown" disabled="@isOperating" />
                                <label class="form-check-label" for="chkUnknown">Include unknown countries/regions</label>
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Ticket Number</label>
                            <input type="text" class="form-control" @bind="formTicketNumber" placeholder="INC/REQ number" disabled="@isOperating" />
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                @if (editingLocation != null)
                                {
                                    @if (confirmDelete == editingLocation.Id)
                                    {
                                        <button class="btn btn-danger btn-sm me-1" @onclick="() => DeleteLocation(editingLocation)" disabled="@(isOperating || string.IsNullOrWhiteSpace(formTicketNumber))">Confirm Delete</button>
                                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => confirmDelete = null" disabled="@isOperating">Cancel</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => confirmDelete = editingLocation.Id" disabled="@isOperating">Delete</button>
                                    }
                                }
                            </div>
                            <button class="btn btn-primary" @onclick="SaveLocation"
                                    disabled="@(isOperating || string.IsNullOrWhiteSpace(formDisplayName) || string.IsNullOrWhiteSpace(formTicketNumber))">
                                @if (isOperating) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                @(editingLocation != null ? "Update" : "Create")
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string currentUser = "";
    private string clientIpAddress = "Unknown";
    private bool authChecked;
    private bool isLoading;
    private bool isOperating;
    private string? loadError;

    private List<NamedLocation> locations = new();
    private NamedLocationResult? operationResult;
    private string? confirmDelete;

    private bool showForm;
    private NamedLocation? editingLocation;
    private string formDisplayName = "";
    private string formType = "ip";
    private string formIpRanges = "";
    private string formCountryCodes = "";
    private string formTicketNumber = "";
    private bool formIsTrusted;
    private bool formIncludeUnknown;

    private string EffectiveType => editingLocation != null
        ? (editingLocation.LocationType == NamedLocationType.Ip ? "ip" : "country")
        : formType;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUser = user.Identity?.Name ?? "Unknown";

        var authResult = await AuthorizationService.AuthorizeAsync(user, "NamedLocations");
        if (!authResult.Succeeded)
        {
            Navigation.NavigateTo("access-denied", forceLoad: true);
            return;
        }

        clientIpAddress = ClientInfo.IpAddress != "Unknown"
            ? ClientInfo.IpAddress
            : ClientInfo.GetIpForUser(currentUser);
        authChecked = true;

        await LoadLocations();
    }

    private async Task LoadLocations()
    {
        isLoading = true;
        loadError = null;
        await Task.Yield();
        try
        {
            locations = await LocationService.GetAllAsync();
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
            Logger.LogError(ex, "Failed to load named locations");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowCreateForm()
    {
        editingLocation = null;
        formDisplayName = "";
        formType = "ip";
        formIpRanges = "";
        formCountryCodes = "";
        formTicketNumber = "";
        formIsTrusted = false;
        formIncludeUnknown = false;
        showForm = true;
    }

    private void EditLocation(NamedLocation loc)
    {
        confirmDelete = null;
        editingLocation = loc;
        formDisplayName = loc.DisplayName;
        formIpRanges = string.Join("\n", loc.IpRanges);
        formCountryCodes = string.Join("\n", loc.CountryCodes);
        formTicketNumber = "";
        formIsTrusted = loc.IsTrusted;
        formIncludeUnknown = loc.IncludeUnknownCountries;
        showForm = true;
    }

    private void CancelForm()
    {
        confirmDelete = null;
        showForm = false;
        editingLocation = null;
    }

    private async Task SaveLocation()
    {
        isOperating = true;
        operationResult = null;
        await Task.Yield();

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var authCheck = await AuthorizationService.AuthorizeAsync(authState.User, "NamedLocations");
            if (!authCheck.Succeeded)
            {
                operationResult = new NamedLocationResult { Success = false, Message = "Authorization denied." };
                var deniedAction = editingLocation != null ? "NamedLocations_Update" : "NamedLocations_Create";
                var deniedTarget = editingLocation != null ? $"{formDisplayName.Trim()} ({editingLocation.Id})" : formDisplayName.Trim();
                try { Audit.LogModuleAction(currentUser, clientIpAddress, deniedAction, "NamedLocations", deniedTarget, false, formTicketNumber.Trim(), "Authorization denied"); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for {Action} auth denial", deniedAction); }
                return;
            }

            var action = editingLocation != null ? "NamedLocations_Update" : "NamedLocations_Create";
            var target = formDisplayName.Trim();

            if (editingLocation != null)
            {
                if (editingLocation.LocationType == NamedLocationType.Ip)
                {
                    var ranges = ParseLines(formIpRanges);
                    if (ranges.Count == 0) { operationResult = new NamedLocationResult { Success = false, Message = "At least one IP range is required." }; return; }
                    operationResult = await LocationService.UpdateIpLocationAsync(editingLocation.Id, target, ranges, formIsTrusted);
                }
                else
                {
                    var codes = ParseLines(formCountryCodes);
                    if (codes.Count == 0) { operationResult = new NamedLocationResult { Success = false, Message = "At least one country code is required." }; return; }
                    operationResult = await LocationService.UpdateCountryLocationAsync(editingLocation.Id, target, codes, formIncludeUnknown);
                }
                target = $"{target} ({editingLocation.Id})";
            }
            else
            {
                if (EffectiveType == "ip")
                {
                    var ranges = ParseLines(formIpRanges);
                    if (ranges.Count == 0) { operationResult = new NamedLocationResult { Success = false, Message = "At least one IP range is required." }; return; }
                    operationResult = await LocationService.CreateIpLocationAsync(target, ranges, formIsTrusted);
                }
                else
                {
                    var codes = ParseLines(formCountryCodes);
                    if (codes.Count == 0) { operationResult = new NamedLocationResult { Success = false, Message = "At least one country code is required." }; return; }
                    operationResult = await LocationService.CreateCountryLocationAsync(target, codes, formIncludeUnknown);
                }
            }

            var ticket = formTicketNumber.Trim();

            try { Audit.LogModuleAction(currentUser, clientIpAddress, action, "NamedLocations", target, operationResult.Success, ticket, operationResult.Success ? null : operationResult.Message); }
            catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for {Action}", action); }

            try { await Email.SendAdminNotificationAsync(currentUser, clientIpAddress, action, operationResult.Success, ticket, new Dictionary<string, string> { ["Location"] = target }, operationResult.Success ? null : operationResult.Message); }
            catch (Exception emailEx) { Logger.LogError(emailEx, "Email notification failed for {Action}", action); }

            if (operationResult.Success)
            {
                showForm = false;
                editingLocation = null;
                confirmDelete = null;
                await LoadLocations();
            }
        }
        catch (Exception ex)
        {
            operationResult = new NamedLocationResult { Success = false, Message = ex.Message };
            Logger.LogError(ex, "Failed to save named location");
            var failAction = editingLocation != null ? "NamedLocations_Update" : "NamedLocations_Create";
            var failTarget = editingLocation != null ? $"{formDisplayName.Trim()} ({editingLocation.Id})" : formDisplayName.Trim();
            try { Audit.LogModuleAction(currentUser, clientIpAddress, failAction, "NamedLocations", failTarget, false, formTicketNumber.Trim(), ex.Message); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for {Action}", failAction); }
            try { await Email.SendAdminNotificationAsync(currentUser, clientIpAddress, failAction, false, formTicketNumber.Trim(), new Dictionary<string, string> { ["Location"] = failTarget }, ex.Message); } catch { }
        }
        finally
        {
            isOperating = false;
        }
    }

    private async Task DeleteLocation(NamedLocation loc)
    {
        isOperating = true;
        operationResult = null;
        confirmDelete = null;
        await Task.Yield();

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var authCheck = await AuthorizationService.AuthorizeAsync(authState.User, "NamedLocations");
            if (!authCheck.Succeeded)
            {
                operationResult = new NamedLocationResult { Success = false, Message = "Authorization denied." };
                try { Audit.LogModuleAction(currentUser, clientIpAddress, "NamedLocations_Delete", "NamedLocations", $"{loc.DisplayName} ({loc.Id})", false, formTicketNumber.Trim(), "Authorization denied"); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for NamedLocations_Delete auth denial"); }
                return;
            }

            var target = $"{loc.DisplayName} ({loc.Id})";
            var ticket = formTicketNumber.Trim();
            operationResult = await LocationService.DeleteAsync(loc.Id, loc.DisplayName);

            try { Audit.LogModuleAction(currentUser, clientIpAddress, "NamedLocations_Delete", "NamedLocations", target, operationResult.Success, ticket, operationResult.Success ? null : operationResult.Message); }
            catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for NamedLocations delete"); }

            try { await Email.SendAdminNotificationAsync(currentUser, clientIpAddress, "NamedLocations_Delete", operationResult.Success, ticket, new Dictionary<string, string> { ["Location"] = target }, operationResult.Success ? null : operationResult.Message); }
            catch (Exception emailEx) { Logger.LogError(emailEx, "Email notification failed for NamedLocations delete"); }

            if (operationResult.Success)
            {
                showForm = false;
                editingLocation = null;
                confirmDelete = null;
                await LoadLocations();
            }
        }
        catch (Exception ex)
        {
            operationResult = new NamedLocationResult { Success = false, Message = ex.Message };
            Logger.LogError(ex, "Failed to delete named location {Id}", loc.Id);
            try { Audit.LogModuleAction(currentUser, clientIpAddress, "NamedLocations_Delete", "NamedLocations", $"{loc.DisplayName} ({loc.Id})", false, formTicketNumber.Trim(), ex.Message); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for NamedLocations delete"); }
            try { await Email.SendAdminNotificationAsync(currentUser, clientIpAddress, "NamedLocations_Delete", false, formTicketNumber.Trim(), new Dictionary<string, string> { ["Location"] = $"{loc.DisplayName} ({loc.Id})" }, ex.Message); } catch { }
        }
        finally
        {
            isOperating = false;
        }
    }

    private static List<string> ParseLines(string input) =>
        (input ?? "").Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(l => !string.IsNullOrWhiteSpace(l))
            .ToList();
}
