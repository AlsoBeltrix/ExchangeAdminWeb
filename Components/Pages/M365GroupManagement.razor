@page "/m365-group-management"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "M365GroupManagement")]
@rendermode InteractiveServer
@inject M365GroupManagementService GroupService
@inject AuditService Audit
@inject EmailService Email
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject ClientInfoService ClientInfo
@inject ILogger<M365GroupManagement> Logger

<PageTitle>M365 Group Management</PageTitle>

@if (!authChecked)
{
    <div class="container-fluid">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Checking authorization...</span>
            </div>
        </div>
    </div>
    return;
}

<div class="container-fluid">
    <div class="alert alert-info py-2 mb-3">
        <small>Create, modify, and delete Microsoft 365 groups via Graph API.</small>
    </div>
    <h1 class="mb-4">M365 Group Management</h1>

    @if (!GroupService.IsAvailable)
    {
        <div class="alert alert-danger">M365 Group Management module is not configured. Set DelineaSecretId in Module Config.</div>
        return;
    }

    @if (operationResult != null)
    {
        <div class="alert @(operationResult.Success ? "alert-success" : "alert-danger") alert-dismissible">
            @operationResult.Message
            <button type="button" class="btn-close" @onclick="() => operationResult = null"></button>
        </div>
    }

    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>M365 Groups</strong>
                    <button class="btn btn-primary btn-sm" @onclick="ShowCreateForm" disabled="@isSearching">New Group</button>
                </div>
                <div class="card-body p-0">
                    <div class="p-3 pb-0">
                        <div class="input-group">
                            <input type="text" class="form-control" placeholder="Search by display name..." @bind="searchTerm"
                                   @bind:event="oninput" @onkeydown="HandleSearchKeyDown" disabled="@isSearching" />
                            <button class="btn btn-outline-primary" @onclick="SearchGroups" disabled="@(isSearching || string.IsNullOrWhiteSpace(searchTerm))">
                                @if (isSearching) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Search
                            </button>
                        </div>
                    </div>

                    @if (searchError != null)
                    {
                        <div class="alert alert-danger m-3">@searchError</div>
                    }
                    else if (hasSearched && groups.Count == 0 && !isSearching)
                    {
                        <p class="text-muted p-3 mb-0">No M365 groups found matching your search.</p>
                    }
                    else if (groups.Count > 0)
                    {
                        <div style="max-height: calc(100vh - 320px); overflow-y: auto;">
                            <table class="table table-sm mb-0">
                                <thead>
                                    <tr>
                                        <th>Name</th>
                                        <th style="width: 220px;">Mail</th>
                                        <th style="width: 90px;">Visibility</th>
                                        <th style="width: 130px;">Created</th>
                                        <th style="width: 80px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var g in groups)
                                    {
                                        <tr class="@(selectedGroup?.Id == g.Id ? "table-active" : "")">
                                            <td>@g.DisplayName</td>
                                            <td><small class="text-muted">@g.Mail</small></td>
                                            <td>@(string.IsNullOrEmpty(g.Visibility) ? "Private" : g.Visibility)</td>
                                            <td><small class="text-muted">@FormatDate(g.CreatedDateTime)</small></td>
                                            <td>
                                                <button class="btn btn-outline-secondary btn-sm" @onclick="() => SelectGroup(g)" disabled="@isOperating">
                                                    @if (isLoadingDetails && selectedGroup?.Id == g.Id) { <span class="spinner-border spinner-border-sm"></span> }
                                                    else { <span>View</span> }
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else if (!hasSearched)
                    {
                        <p class="text-muted p-3 mb-0">Enter a search term and click Search to find M365 groups.</p>
                    }

                    @if (selectedGroup != null && members != null)
                    {
                        <div class="border-top p-3">
                            <h6>Members (@members.Count)</h6>
                            @if (members.Count > 0)
                            {
                                <div style="max-height: 200px; overflow-y: auto;">
                                    <table class="table table-sm mb-0">
                                        <thead><tr><th>Name</th><th>Email</th></tr></thead>
                                        <tbody>
                                            @foreach (var m in members)
                                            {
                                                <tr>
                                                    <td>@m.DisplayName</td>
                                                    <td><small class="text-muted">@(string.IsNullOrEmpty(m.Mail) ? m.UserPrincipalName : m.Mail)</small></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-0"><small>No members.</small></p>
                            }

                            <h6 class="mt-3">Owners (@(owners?.Count ?? 0))</h6>
                            @if (owners != null && owners.Count > 0)
                            {
                                <div style="max-height: 150px; overflow-y: auto;">
                                    <table class="table table-sm mb-0">
                                        <thead><tr><th>Name</th><th>Email</th></tr></thead>
                                        <tbody>
                                            @foreach (var o in owners)
                                            {
                                                <tr>
                                                    <td>@o.DisplayName</td>
                                                    <td><small class="text-muted">@(string.IsNullOrEmpty(o.Mail) ? o.UserPrincipalName : o.Mail)</small></td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted mb-0"><small>No owners.</small></p>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card" style="position: sticky; top: 1rem;">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>@(showForm ? (editingGroup != null ? "Edit Group" : "New Group") : "Group Details")</strong>
                    @if (showForm)
                    {
                        <button class="btn btn-outline-secondary btn-sm" @onclick="CancelForm">Cancel</button>
                    }
                </div>
                <div class="card-body">
                    @if (!showForm)
                    {
                        @if (selectedGroup != null)
                        {
                            <dl class="mb-3">
                                <dt>Display Name</dt><dd>@selectedGroup.DisplayName</dd>
                                <dt>Mail</dt><dd>@selectedGroup.Mail</dd>
                                <dt>Visibility</dt><dd>@(string.IsNullOrEmpty(selectedGroup.Visibility) ? "Private" : selectedGroup.Visibility)</dd>
                                <dt>Description</dt><dd>@(string.IsNullOrEmpty(selectedGroup.Description) ? "(none)" : selectedGroup.Description)</dd>
                                <dt>Created</dt><dd>@FormatDate(selectedGroup.CreatedDateTime)</dd>
                            </dl>
                            <button class="btn btn-primary btn-sm" @onclick="() => EditGroup(selectedGroup)" disabled="@isOperating">Edit</button>
                        }
                        else
                        {
                            <p class="text-muted mb-3">Search and select a group to view its details, or create a new one.</p>
                            <button class="btn btn-primary btn-sm" @onclick="ShowCreateForm" disabled="@isSearching">New Group</button>
                        }
                    }
                    else
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Display Name</label>
                            <input type="text" class="form-control" @bind="formDisplayName" disabled="@isOperating" />
                        </div>

                        @if (editingGroup == null)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Mail Nickname</label>
                                <input type="text" class="form-control" @bind="formMailNickname" placeholder="no spaces or special chars" disabled="@isOperating" />
                                <small class="text-muted">Used for the group email address prefix.</small>
                            </div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Mail</label>
                                <input type="text" class="form-control" value="@editingGroup.Mail" disabled />
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Description</label>
                            <textarea class="form-control" rows="3" @bind="formDescription" disabled="@isOperating"></textarea>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Visibility</label>
                            <select class="form-select" @bind="formVisibility" disabled="@isOperating">
                                <option value="Private">Private</option>
                                <option value="Public">Public</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Ticket Number</label>
                            <input type="text" class="form-control" @bind="formTicketNumber" @bind:event="oninput" placeholder="INC/REQ number" disabled="@isOperating" />
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                @if (editingGroup != null)
                                {
                                    @if (confirmDelete == editingGroup.Id)
                                    {
                                        <button class="btn btn-danger btn-sm me-1" @onclick="() => DeleteGroup(editingGroup)" disabled="@(isOperating || string.IsNullOrWhiteSpace(formTicketNumber))">Confirm Delete</button>
                                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => confirmDelete = null" disabled="@isOperating">Cancel</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => confirmDelete = editingGroup.Id" disabled="@isOperating">Delete</button>
                                    }
                                }
                            </div>
                            <button class="btn btn-primary" @onclick="SaveGroup"
                                    disabled="@(isOperating || string.IsNullOrWhiteSpace(formDisplayName) || string.IsNullOrWhiteSpace(formTicketNumber) || (editingGroup == null && string.IsNullOrWhiteSpace(formMailNickname)))">
                                @if (isOperating) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                @(editingGroup != null ? "Update" : "Create")
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string currentUser = "";
    private string clientIpAddress = "Unknown";
    private bool authChecked;
    private bool isSearching;
    private bool isLoadingDetails;
    private bool isOperating;
    private string? searchError;

    private string searchTerm = "";
    private bool hasSearched;
    private List<M365Group> groups = new();
    private M365Group? selectedGroup;
    private List<M365GroupMember>? members;
    private List<M365GroupMember>? owners;

    private M365GroupResult? operationResult;
    private string? confirmDelete;

    private bool showForm;
    private M365Group? editingGroup;
    private string formDisplayName = "";
    private string formMailNickname = "";
    private string formDescription = "";
    private string formVisibility = "Private";
    private string formTicketNumber = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUser = user.Identity?.Name ?? "Unknown";

        var authResult = await AuthorizationService.AuthorizeAsync(user, "M365GroupManagement");
        if (!authResult.Succeeded)
        {
            Navigation.NavigateTo("access-denied", forceLoad: true);
            return;
        }

        clientIpAddress = ClientInfo.IpAddress != "Unknown"
            ? ClientInfo.IpAddress
            : ClientInfo.GetIpForUser(currentUser);
        authChecked = true;
    }

    private async Task HandleSearchKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(searchTerm))
            await SearchGroups();
    }

    private async Task SearchGroups()
    {
        isSearching = true;
        searchError = null;
        selectedGroup = null;
        members = null;
        owners = null;
        showForm = false;
        await Task.Yield();

        try
        {
            groups = await GroupService.SearchGroupsAsync(searchTerm.Trim());
            hasSearched = true;

            try { Audit.LogLookupAction(currentUser, clientIpAddress, "M365GroupManagement_Search", searchTerm.Trim(), true); }
            catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for M365 group search"); }
        }
        catch (Exception ex)
        {
            searchError = ex.Message;
            Logger.LogError(ex, "Failed to search M365 groups");

            try { Audit.LogLookupAction(currentUser, clientIpAddress, "M365GroupManagement_Search", searchTerm.Trim(), false, ex.Message); }
            catch { }
        }
        finally
        {
            isSearching = false;
        }
    }

    private async Task SelectGroup(M365Group group)
    {
        isLoadingDetails = true;
        selectedGroup = group;
        showForm = false;
        members = null;
        owners = null;
        await Task.Yield();

        try
        {
            var details = await GroupService.GetGroupDetailsAsync(group.Id);
            if (details != null)
                selectedGroup = details;

            members = await GroupService.GetMembersAsync(group.Id);
            owners = await GroupService.GetOwnersAsync(group.Id);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load group details for {GroupId}", group.Id);
            searchError = $"Failed to load details: {ex.Message}";
        }
        finally
        {
            isLoadingDetails = false;
        }
    }

    private void ShowCreateForm()
    {
        editingGroup = null;
        formDisplayName = "";
        formMailNickname = "";
        formDescription = "";
        formVisibility = "Private";
        formTicketNumber = "";
        confirmDelete = null;
        showForm = true;
    }

    private void EditGroup(M365Group group)
    {
        editingGroup = group;
        formDisplayName = group.DisplayName;
        formMailNickname = "";
        formDescription = group.Description;
        formVisibility = string.IsNullOrEmpty(group.Visibility) ? "Private" : group.Visibility;
        formTicketNumber = "";
        confirmDelete = null;
        showForm = true;
    }

    private void CancelForm()
    {
        confirmDelete = null;
        showForm = false;
        editingGroup = null;
    }

    private async Task SaveGroup()
    {
        isOperating = true;
        operationResult = null;
        await Task.Yield();

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var authCheck = await AuthorizationService.AuthorizeAsync(authState.User, "M365GroupManagement");
            if (!authCheck.Succeeded)
            {
                operationResult = new M365GroupResult { Success = false, Message = "Authorization denied." };
                return;
            }

            var action = editingGroup != null ? "M365GroupManagement_Update" : "M365GroupManagement_Create";
            var target = formDisplayName.Trim();

            if (editingGroup != null)
            {
                operationResult = await GroupService.UpdateGroupAsync(editingGroup.Id, target, formDescription.Trim(), formVisibility);
                target = $"{target} ({editingGroup.Id})";
            }
            else
            {
                operationResult = await GroupService.CreateGroupAsync(target, formMailNickname.Trim(), formDescription.Trim(), formVisibility);
            }

            var ticket = formTicketNumber.Trim();

            try { Audit.LogModuleAction(currentUser, clientIpAddress, action, "M365GroupManagement", target, operationResult.Success, ticket, operationResult.Success ? null : operationResult.Message); }
            catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for {Action}", action); }

            try { await Email.SendAdminNotificationAsync(currentUser, clientIpAddress, action, operationResult.Success, ticket, new Dictionary<string, string> { ["Group"] = target }, operationResult.Success ? null : operationResult.Message); }
            catch (Exception emailEx) { Logger.LogError(emailEx, "Email notification failed for {Action}", action); }

            if (operationResult.Success)
            {
                showForm = false;
                editingGroup = null;
                confirmDelete = null;
                if (hasSearched)
                    await SearchGroups();
            }
        }
        catch (Exception ex)
        {
            operationResult = new M365GroupResult { Success = false, Message = ex.Message };
            Logger.LogError(ex, "Failed to save M365 group");
            var failAction = editingGroup != null ? "M365GroupManagement_Update" : "M365GroupManagement_Create";
            var failTarget = editingGroup != null ? $"{formDisplayName.Trim()} ({editingGroup.Id})" : formDisplayName.Trim();
            try { Audit.LogModuleAction(currentUser, clientIpAddress, failAction, "M365GroupManagement", failTarget, false, formTicketNumber.Trim(), ex.Message); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for {Action}", failAction); }
            try { await Email.SendAdminNotificationAsync(currentUser, clientIpAddress, failAction, false, formTicketNumber.Trim(), new Dictionary<string, string> { ["Group"] = failTarget }, ex.Message); } catch (Exception emailEx) { Logger.LogError(emailEx, "Email failed for {Action}", failAction); }
        }
        finally
        {
            isOperating = false;
        }
    }

    private async Task DeleteGroup(M365Group group)
    {
        isOperating = true;
        operationResult = null;
        confirmDelete = null;
        await Task.Yield();

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var authCheck = await AuthorizationService.AuthorizeAsync(authState.User, "M365GroupManagement");
            if (!authCheck.Succeeded)
            {
                operationResult = new M365GroupResult { Success = false, Message = "Authorization denied." };
                return;
            }

            var target = $"{group.DisplayName} ({group.Id})";
            var ticket = formTicketNumber.Trim();
            operationResult = await GroupService.DeleteGroupAsync(group.Id, group.DisplayName);

            try { Audit.LogModuleAction(currentUser, clientIpAddress, "M365GroupManagement_Delete", "M365GroupManagement", target, operationResult.Success, ticket, operationResult.Success ? null : operationResult.Message); }
            catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for M365 group delete"); }

            try { await Email.SendAdminNotificationAsync(currentUser, clientIpAddress, "M365GroupManagement_Delete", operationResult.Success, ticket, new Dictionary<string, string> { ["Group"] = target }, operationResult.Success ? null : operationResult.Message); }
            catch (Exception emailEx) { Logger.LogError(emailEx, "Email notification failed for M365 group delete"); }

            if (operationResult.Success)
            {
                showForm = false;
                editingGroup = null;
                selectedGroup = null;
                members = null;
                owners = null;
                confirmDelete = null;
                if (hasSearched)
                    await SearchGroups();
            }
        }
        catch (Exception ex)
        {
            operationResult = new M365GroupResult { Success = false, Message = ex.Message };
            Logger.LogError(ex, "Failed to delete M365 group {Id}", group.Id);
            try { Audit.LogModuleAction(currentUser, clientIpAddress, "M365GroupManagement_Delete", "M365GroupManagement", $"{group.DisplayName} ({group.Id})", false, formTicketNumber.Trim(), ex.Message); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for M365 group delete"); }
            try { await Email.SendAdminNotificationAsync(currentUser, clientIpAddress, "M365GroupManagement_Delete", false, formTicketNumber.Trim(), new Dictionary<string, string> { ["Group"] = $"{group.DisplayName} ({group.Id})" }, ex.Message); } catch (Exception emailEx) { Logger.LogError(emailEx, "Email failed for M365 group delete"); }
        }
        finally
        {
            isOperating = false;
        }
    }

    private static string FormatDate(string isoDate)
    {
        if (DateTimeOffset.TryParse(isoDate, out var dto))
            return dto.LocalDateTime.ToString("yyyy-MM-dd");
        return isoDate;
    }
}
