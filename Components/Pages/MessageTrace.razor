@page "/message-trace"
@using ExchangeAdminWeb.Models
@using ExchangeAdminWeb.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "GroupPolicy")]
@rendermode InteractiveServer
@inject IExchangeService Exchange
@inject AuditService Audit
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject ClientInfoService ClientInfo
@inject IJSRuntime JS

<PageTitle>Message Trace</PageTitle>

<div class="container-fluid mt-4">
    <h2>Message Trace</h2>
    <p class="text-muted">Search mail flow by sender, recipient, and date range</p>

    <div class="card">
        <div class="card-body">
            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <label class="form-label">Sender</label>
                    <input type="email" class="form-control" @bind="sender" placeholder="sender@analog.com" disabled="@isLoading" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Recipient</label>
                    <input type="email" class="form-control" @bind="recipient" placeholder="recipient@analog.com" disabled="@isLoading" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Start Date</label>
                    <input type="date" class="form-control" @bind="startDate" disabled="@isLoading" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">End Date</label>
                    <input type="date" class="form-control" @bind="endDate" disabled="@isLoading" />
                </div>
            </div>
            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label class="form-label">Subject Contains</label>
                    <input type="text" class="form-control" @bind="subjectFilter" placeholder="(optional)" disabled="@isLoading" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary" @onclick="RunTrace"
                            disabled="@(!IsFormValid || isLoading)">
                        @if (isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Search
                    </button>
                </div>
            </div>

            @if (IsHistoricalRange)
            {
                <div class="alert alert-info">
                    <strong>Note:</strong> Date ranges exceeding 10 days use a historical search.
                    Results will be emailed to <strong>@(string.IsNullOrWhiteSpace(userEmail) ? "(unable to determine — see below)" : userEmail)</strong> when ready (typically 30 minutes to several hours).
                    Subject filtering is not available for historical searches.
                </div>
            }

            @if (validationError != null)
            {
                <div class="alert alert-danger">@validationError</div>
            }

            @if (historicalSubmitted)
            {
                <div class="alert alert-success">
                    Historical search submitted successfully. Results will be emailed to <strong>@userEmail</strong> when processing is complete.
                </div>
            }

            @if (response?.Error != null)
            {
                <div class="alert alert-danger">@response.Error</div>
            }
            else if (response != null)
            {
                @if (response.Truncated)
                {
                    <div class="alert alert-warning">
                        Results limited to @MessageTraceResponse.MaxResults messages. Narrow your search criteria for complete results.
                    </div>
                }

                @if (response.Results.Any())
                {
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <p class="text-muted mb-0">@response.Results.Count result(s)</p>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="ExportCsv">Export CSV</button>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm table-striped">
                            <thead>
                                <tr>
                                    <th>Received</th>
                                    <th>Sender</th>
                                    <th>Recipient</th>
                                    <th>Subject</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var msg in response.Results)
                                {
                                    <tr>
                                        <td>@msg.Received.ToString("yyyy-MM-dd HH:mm")</td>
                                        <td>@msg.SenderAddress</td>
                                        <td>@msg.RecipientAddress</td>
                                        <td>@msg.Subject</td>
                                        <td><span class="badge bg-@GetStatusBadge(msg.Status)">@msg.Status</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-info">No messages found matching your criteria.</div>
                }
            }
        </div>
    </div>
</div>

@code {
    private string sender = "";
    private string recipient = "";
    private DateTime startDate = DateTime.Today.AddDays(-2);
    private DateTime endDate = DateTime.Today;
    private string subjectFilter = "";
    private bool isLoading = false;
    private string? validationError;
    private MessageTraceResponse? response;
    private bool historicalSubmitted = false;
    private string currentUser = "";
    private string userEmail = "";
    private string clientIpAddress = "Unknown";

    private bool IsFormValid => !string.IsNullOrWhiteSpace(sender) || !string.IsNullOrWhiteSpace(recipient);
    private bool IsHistoricalRange => (endDate - startDate).TotalDays > 9;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUser = user.Identity?.Name ?? "Unknown";

        var authResult = await AuthorizationService.AuthorizeAsync(user, "GroupPolicy");
        if (!authResult.Succeeded)
        {
            Navigation.NavigateTo("/access-denied", forceLoad: true);
            return;
        }

        userEmail = user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
            ?? user.FindFirst("email")?.Value
            ?? user.FindFirst(System.Security.Claims.ClaimTypes.Upn)?.Value
            ?? "";

        clientIpAddress = ClientInfo.IpAddress != "Unknown"
            ? ClientInfo.IpAddress
            : ClientInfo.GetIpForUser(currentUser);
    }

    public static string? ValidateDateRange(DateTime start, DateTime end)
    {
        if (end < start)
            return "End date must be after start date.";
        if ((end - start).TotalDays > 89)
            return "Date range cannot exceed 90 days.";
        if (start > DateTime.Today)
            return "Start date cannot be in the future.";
        return null;
    }

    private async Task RunTrace()
    {
        validationError = ValidateDateRange(startDate, endDate);
        if (validationError != null) return;

        historicalSubmitted = false;
        isLoading = true;
        response = null;

        try
        {
            if (IsHistoricalRange)
            {
                await RunHistoricalSearch();
            }
            else
            {
                await RunRealtimeTrace();
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RunRealtimeTrace()
    {
        try
        {
            response = await Exchange.GetMessageTraceAsync(
                string.IsNullOrWhiteSpace(sender) ? null : sender.Trim(),
                string.IsNullOrWhiteSpace(recipient) ? null : recipient.Trim(),
                startDate, endDate.AddDays(1),
                string.IsNullOrWhiteSpace(subjectFilter) ? null : subjectFilter.Trim());

            var target = $"{(string.IsNullOrWhiteSpace(sender) ? "*" : sender.Trim())}->{(string.IsNullOrWhiteSpace(recipient) ? "*" : recipient.Trim())}";
            Audit.LogLookupAction(currentUser, clientIpAddress, "MessageTrace", target, response.Error == null, response.Error);
        }
        catch (Exception ex)
        {
            response = new MessageTraceResponse { Error = ex.Message };
        }
    }

    private async Task RunHistoricalSearch()
    {
        var notifyAddress = userEmail;
        if (string.IsNullOrWhiteSpace(notifyAddress))
        {
            validationError = "Your email address could not be determined. Historical searches require a notification address.";
            return;
        }

        var target = $"{(string.IsNullOrWhiteSpace(sender) ? "*" : sender.Trim())}->{(string.IsNullOrWhiteSpace(recipient) ? "*" : recipient.Trim())}";
        var reportTitle = $"MessageTrace_{currentUser}_{startDate:yyyyMMdd}-{endDate:yyyyMMdd}";

        try
        {
            var result = await Exchange.StartHistoricalSearchAsync(
                string.IsNullOrWhiteSpace(sender) ? null : sender.Trim(),
                string.IsNullOrWhiteSpace(recipient) ? null : recipient.Trim(),
                startDate, endDate.AddDays(1),
                notifyAddress, reportTitle);

            if (result.Success)
            {
                historicalSubmitted = true;
            }
            else
            {
                response = new MessageTraceResponse { Error = result.Error ?? "Failed to submit historical search." };
            }

            Audit.LogLookupAction(currentUser, clientIpAddress, "HistoricalSearch", target, result.Success, result.Error);
        }
        catch (Exception ex)
        {
            response = new MessageTraceResponse { Error = ex.Message };
        }
    }

    private async Task ExportCsv()
    {
        if (response?.Results == null || !response.Results.Any()) return;

        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Origin Date-Time,Sender Address,Recipient Address,Message Subject,Status,Message ID,Message Size,Sender IP,Recipient IP,Message Trace ID");

        foreach (var msg in response.Results)
        {
            sb.Append(msg.Received.ToString("yyyy-MM-ddTHH:mm:ss.fffffffZ"));
            sb.Append(',');
            sb.Append(CsvEscape(msg.SenderAddress));
            sb.Append(',');
            sb.Append(CsvEscape(msg.RecipientAddress));
            sb.Append(',');
            sb.Append(CsvEscape(msg.Subject));
            sb.Append(',');
            sb.Append(CsvEscape(msg.Status));
            sb.Append(',');
            sb.Append(CsvEscape(msg.MessageId));
            sb.Append(',');
            sb.Append(msg.Size);
            sb.Append(',');
            sb.Append(CsvEscape(msg.FromIP));
            sb.Append(',');
            sb.Append(CsvEscape(msg.ToIP));
            sb.Append(',');
            sb.Append(CsvEscape(msg.MessageTraceId));
            sb.AppendLine();
        }

        var bytes = System.Text.Encoding.UTF8.GetBytes(sb.ToString());
        var base64 = Convert.ToBase64String(bytes);
        var filename = $"MessageTrace_{startDate:yyyyMMdd}-{endDate:yyyyMMdd}.csv";
        await JS.InvokeVoidAsync("downloadFile", filename, "text/csv", base64);
    }

    private static string CsvEscape(string value)
    {
        if (string.IsNullOrEmpty(value)) return "";
        if (value.Length > 0 && value[0] is '=' or '+' or '-' or '@' or '\t' or '\r' or '\n')
            value = "'" + value;
        if (value.Contains(',') || value.Contains('"') || value.Contains('\n') || value.Contains('\r'))
            return "\"" + value.Replace("\"", "\"\"") + "\"";
        return value;
    }

    private static string GetStatusBadge(string status) => status switch
    {
        "Delivered" => "success",
        "Failed" => "danger",
        "Pending" => "warning",
        "FilteredAsSpam" => "secondary",
        _ => "info"
    };
}
