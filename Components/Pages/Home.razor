@page "/"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "GroupPolicy")]
@rendermode InteractiveServer
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject IConfiguration Config

<PageTitle>Exchange Admin</PageTitle>

@if (!authChecked)
{
    <div class="container-fluid">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Checking authorization...</span>
            </div>
        </div>
    </div>
    return;
}

<div class="container-fluid">
    <div class="alert alert-info">
        <strong>Logged in as:</strong> @currentUser
    </div>
    <h1 class="mb-4">Exchange Admin</h1>

    <div class="alert alert-warning mb-4">
        <h5><strong>⚠️ Important Notice</strong></h5>
        <ul class="mb-0">
            <li><strong>All actions are logged:</strong> Every permission change is recorded with your username, IP address, timestamp, and ticket number for compliance and audit purposes.</li>
            @if (bool.Parse(Config["Email:NotifyUsersOnPermissionGrant"] ?? "false"))
            {
                <li><strong>End users are notified:</strong> When you grant or remove permissions, the affected user will receive an email notification about the change.</li>
            }
        </ul>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Mailbox Permissions</h5>
                    <p class="card-text text-muted">
                        Grant or revoke <strong>Full Access</strong> and <strong>Send As</strong> permissions on Exchange Online mailboxes.
                    </p>
                    <a href="mailbox-permissions" class="btn btn-primary">Open</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Calendar Permissions</h5>
                    <p class="card-text text-muted">
                        Set or remove calendar sharing permissions on Exchange Online mailboxes.
                    </p>
                    <a href="calendar-permissions" class="btn btn-primary">Open</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Exchange Migration</h5>
                    <p class="card-text text-muted">
                        Check migration eligibility and create migration batches for Exchange Online and on-premises mailboxes.
                    </p>
                    <a href="migration" class="btn btn-primary">Open</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Delegation Report</h5>
                    <p class="card-text text-muted">
                        View current mailbox delegation assignments including Full Access, Send As, and Calendar permissions.
                    </p>
                    <a href="delegation-report" class="btn btn-primary">Open</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Message Trace</h5>
                    <p class="card-text text-muted">
                        Search message delivery logs by sender, recipient, date range, and subject.
                    </p>
                    <a href="message-trace" class="btn btn-primary">Open</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Recipient Lookup</h5>
                    <p class="card-text text-muted">
                        Look up mailbox details including size, quotas, archive status, and recipient type.
                    </p>
                    <a href="recipient-lookup" class="btn btn-primary">Open</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Out of Office</h5>
                    <p class="card-text text-muted">
                        View or configure automatic reply (out of office) settings for Exchange Online mailboxes.
                    </p>
                    <a href="out-of-office" class="btn btn-primary">Open</a>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string currentUser = "Not authenticated";
    private bool authChecked = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUser = user.Identity?.Name ?? "Unknown";

        // CRITICAL: Explicitly check authorization in component
        // The [Authorize] attribute alone is not reliably enforced in Blazor Server
        var authResult = await AuthorizationService.AuthorizeAsync(user, "GroupPolicy");

        if (!authResult.Succeeded)
        {
            // Force redirect to access denied
            Navigation.NavigateTo("access-denied", forceLoad: true);
            return;
        }

        authChecked = true;
    }
}
