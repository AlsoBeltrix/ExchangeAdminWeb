@page "/"
@using Microsoft.AspNetCore.Authorization
@using ExchangeAdminWeb.Modules
@using ExchangeAdminWeb.Services
@attribute [Authorize]
@rendermode InteractiveServer
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject IConfiguration Config
@inject ModuleCatalog Catalog
@inject ModuleEnablementService Enablement

<PageTitle>@(Config["Application:Name"] ?? "Admin Portal")</PageTitle>

@if (!authChecked)
{
    <div class="container-fluid">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Checking authorization...</span>
            </div>
        </div>
    </div>
    return;
}

<div class="container-fluid">
    <div class="alert alert-info">
        <strong>Logged in as:</strong> @currentUser
    </div>
    <h1 class="mb-4">@(Config["Application:Name"] ?? "Admin Portal")</h1>

    <div class="alert alert-warning mb-4">
        <h5><strong>⚠️ Important Notice</strong></h5>
        <ul class="mb-0">
            <li><strong>All actions are logged:</strong> Every permission change is recorded with your username, IP address, timestamp, and ticket number for compliance and audit purposes.</li>
            @if (bool.Parse(Config["Email:NotifyUsersOnPermissionGrant"] ?? "false"))
            {
                <li><strong>End users are notified:</strong> When you grant or remove permissions, the affected user will receive an email notification about the change.</li>
            }
        </ul>
    </div>

    <div class="row g-4">
        @foreach (var module in Catalog.GetOrdered().Where(m => !m.IsSystemModule && Enablement.IsModuleEnabled(m.Id)))
        {
            <AuthorizeView Policy="@module.MainPermission.PolicyAlias">
                <Authorized>
                    <div class="col-md-4">
                        <div class="card h-100">
                            <div class="card-body">
                                <h5 class="card-title">@module.DisplayName</h5>
                                <p class="card-text text-muted">@module.Description</p>
                                <a href="@module.Route" class="btn btn-primary">Open</a>
                            </div>
                        </div>
                    </div>
                </Authorized>
            </AuthorizeView>
        }
        @{ var adminModules = Catalog.GetOrdered().Where(m => m.IsSystemModule).ToList(); }
        @if (adminModules.Any())
        {
            <AuthorizeView Policy="@adminModules.First().MainPermission.PolicyAlias">
                <Authorized>
                    @foreach (var module in adminModules)
                    {
                        <div class="col-md-4">
                            <div class="card h-100 border-warning">
                                <div class="card-body">
                                    <h5 class="card-title">@module.DisplayName</h5>
                                    <p class="card-text text-muted">@module.Description</p>
                                    <a href="@module.Route" class="btn btn-warning">Open</a>
                                </div>
                            </div>
                        </div>
                    }
                </Authorized>
            </AuthorizeView>
        }
    </div>
</div>

@code {
    private string currentUser = "Not authenticated";
    private bool authChecked = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUser = user.Identity?.Name ?? "Unknown";


        authChecked = true;
    }
}
