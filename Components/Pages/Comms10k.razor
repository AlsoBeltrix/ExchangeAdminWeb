@page "/comms-10k"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "Comms10k")]
@rendermode InteractiveServer
@inject Comms10kService Comms10kService
@inject AuditService Audit
@inject ServiceNowService ServiceNow
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject ClientInfoService ClientInfo
@inject EmailService Email
@inject IJSRuntime JS
@inject ILogger<ExchangeAdminWeb.Components.Pages.Comms10k> Logger
@using CsvHelper
@using CsvHelper.Configuration
@using System.Globalization

<PageTitle>Comms-10k</PageTitle>

@if (!authChecked)
{
    <div class="container-fluid">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    </div>
    return;
}

<div class="container-fluid">
    <div class="alert alert-warning py-2 mb-3">
        <small><strong>Caution:</strong> Uploading a CSV will replace ALL members of the broadcast distribution list. This action is logged and admin-notified.</small>
    </div>
    <h1 class="mb-4">Comms-10k Broadcast List</h1>

    @if (!Comms10kService.IsConfigured)
    {
        <div class="alert alert-danger">Module not configured. Set TargetGroupName in Admin Settings.</div>
        return;
    }

    <div class="row">
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>Current Members</strong>
                    <div>
                        <button class="btn btn-outline-primary btn-sm me-2" @onclick="LoadPreview" disabled="@isLoading">Preview</button>
                        <button class="btn btn-outline-secondary btn-sm" @onclick="DownloadFull" disabled="@isLoading">Download CSV</button>
                    </div>
                </div>
                <div class="card-body">
                    @if (preview != null)
                    {
                        <p class="text-muted mb-2"><small>Showing @preview.Members.Count of @preview.TotalCount total members</small></p>
                        <div style="max-height: 300px; overflow-y: auto;">
                            <table class="table table-sm">
                                <thead><tr><th>Name</th><th>Email</th></tr></thead>
                                <tbody>
                                    @foreach (var m in preview.Members)
                                    {
                                        <tr><td>@m.DisplayName</td><td><small>@m.Email</small></td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Click Preview to load current members.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header"><strong>Replace Members</strong></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label">Ticket Number</label>
                        <input type="text" class="form-control" @bind="ticketNumber" placeholder="INC/REQ number" disabled="@isLoading" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">CSV File (Email column required)</label>
                        <InputFile OnChange="HandleFileUpload" accept=".csv" disabled="@isLoading" />
                    </div>
                    @if (parsedEmails.Count > 0 && resolveResult == null)
                    {
                        <p class="text-info">@parsedEmails.Count email(s) parsed. Click Validate to check against AD.</p>
                        <button class="btn btn-primary btn-sm" @onclick="ValidateEmails" disabled="@(isLoading || string.IsNullOrWhiteSpace(ticketNumber))">
                            @if (isLoading) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Validate
                        </button>
                    }

                    @if (resolveResult != null && resolveResult.Success)
                    {
                        <div class="alert alert-info mt-2">
                            <strong>@resolveResult.ResolvedDns.Count</strong> users resolved.
                            @if (resolveResult.SkippedEmails.Count > 0)
                            {
                                <br /><span class="text-danger"><strong>@resolveResult.SkippedEmails.Count not found:</strong> @string.Join(", ", resolveResult.SkippedEmails.Take(10))@(resolveResult.SkippedEmails.Count > 10 ? "..." : "")</span>
                            }
                        </div>

                        @if (confirmPending)
                        {
                            <div class="alert alert-danger">
                                <p><strong>Confirm: Replace all members with @resolveResult.ResolvedDns.Count users?</strong>
                                @if (resolveResult.SkippedEmails.Count > 0)
                                {
                                    <br /><small>@resolveResult.SkippedEmails.Count email(s) will be excluded (not found in AD).</small>
                                }
                                </p>
                                <button class="btn btn-danger btn-sm me-2" @onclick="ExecuteReplace" disabled="@isLoading">
                                    @if (isLoading) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                    Confirm Replace
                                </button>
                                <button class="btn btn-secondary btn-sm" @onclick="() => confirmPending = false">Cancel</button>
                            </div>
                        }
                        else if (resolveResult.ResolvedDns.Count > 0)
                        {
                            <button class="btn btn-warning" @onclick="() => confirmPending = true">
                                Replace All Members (@resolveResult.ResolvedDns.Count users)
                            </button>
                        }
                        else
                        {
                            <div class="alert alert-danger mt-2">No valid users resolved. Cannot proceed.</div>
                        }
                    }
                </div>
            </div>

            @if (result != null)
            {
                <div class="alert @(result.Success ? "alert-success" : "alert-danger") mt-3 alert-dismissible">
                    @result.Message
                    <button type="button" class="btn-close" @onclick="() => result = null"></button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string currentUser = "";
    private string clientIpAddress = "Unknown";
    private bool authChecked;
    private bool isLoading;
    private string ticketNumber = "";
    private string validatedTicket = "";
    private bool confirmPending;
    private Comms10kMemberList? preview;
    private List<string> parsedEmails = new();
    private Comms10kResolveResult? resolveResult;
    private Comms10kUpdateResult? result;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUser = user.Identity?.Name ?? "Unknown";

        var authResult = await AuthorizationService.AuthorizeAsync(user, "Comms10k");
        if (!authResult.Succeeded)
        {
            Navigation.NavigateTo("access-denied", forceLoad: true);
            return;
        }

        clientIpAddress = ClientInfo.IpAddress != "Unknown"
            ? ClientInfo.IpAddress
            : ClientInfo.GetIpForUser(currentUser);
        authChecked = true;
    }

    private async Task LoadPreview()
    {
        isLoading = true;
        try { preview = await Comms10kService.GetMembersAsync(limit: 25); }
        catch (Exception ex) { result = new Comms10kUpdateResult { Success = false, Message = ex.Message }; }
        finally { isLoading = false; }
    }

    private async Task DownloadFull()
    {
        isLoading = true;
        try
        {
            var full = await Comms10kService.GetMembersAsync();
            using var writer = new System.IO.StringWriter();
            using var csvWriter = new CsvWriter(writer, CultureInfo.InvariantCulture);
            csvWriter.WriteRecords(full.Members);
            var bytes = System.Text.Encoding.UTF8.GetBytes(writer.ToString());
            var base64 = Convert.ToBase64String(bytes);
            await JS.InvokeVoidAsync("downloadFile", $"comms10k_members_{DateTime.Now:yyyyMMdd}.csv", "text/csv", base64);
            Audit.LogLookupAction(currentUser, clientIpAddress, "Comms10k_Export", full.GroupName, true);
        }
        catch (Exception ex) { result = new Comms10kUpdateResult { Success = false, Message = ex.Message }; }
        finally { isLoading = false; }
    }

    private void HandleFileUpload(InputFileChangeEventArgs e)
    {
        parsedEmails = new();
        resolveResult = null;
        confirmPending = false;
        result = null;

        try
        {
            using var stream = e.File.OpenReadStream(maxAllowedSize: 16 * 1024 * 1024);
            using var reader = new System.IO.StreamReader(stream);
            var csvConfig = new CsvConfiguration(CultureInfo.InvariantCulture)
            {
                HeaderValidated = null,
                MissingFieldFound = null
            };
            using var csv = new CsvReader(reader, csvConfig);
            csv.Read();
            csv.ReadHeader();

            var matchedHeader = csv.HeaderRecord?.FirstOrDefault(h => h.Trim().Equals("Email", StringComparison.OrdinalIgnoreCase))
                ?? csv.HeaderRecord?.FirstOrDefault(h => h.Trim().Equals("UserPrincipalName", StringComparison.OrdinalIgnoreCase));

            if (matchedHeader == null)
            {
                result = new Comms10kUpdateResult { Success = false, Message = "CSV must have an 'Email' or 'UserPrincipalName' column." };
                return;
            }

            var fieldName = matchedHeader;
            var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
            while (csv.Read())
            {
                var val = csv.GetField(fieldName)?.Trim();
                if (!string.IsNullOrWhiteSpace(val) && val.Contains('@') && seen.Add(val))
                    parsedEmails.Add(val);
            }
        }
        catch (Exception ex)
        {
            result = new Comms10kUpdateResult { Success = false, Message = $"Failed to parse CSV: {ex.Message}" };
        }
    }

    private async Task ValidateEmails()
    {
        isLoading = true;
        try
        {
            var ticketValidation = await ServiceNow.ValidateTicketAsync(ticketNumber.Trim());
            if (!ticketValidation.IsValid)
            {
                result = new Comms10kUpdateResult { Success = false, Message = $"Ticket validation failed: {ticketValidation.Message}" };
                return;
            }
            validatedTicket = ticketNumber.Trim();

            resolveResult = await Comms10kService.ResolveEmailsAsync(parsedEmails);
            if (!resolveResult.Success)
                result = new Comms10kUpdateResult { Success = false, Message = resolveResult.Message };
        }
        catch (Exception ex) { result = new Comms10kUpdateResult { Success = false, Message = ex.Message }; }
        finally { isLoading = false; }
    }

    private async Task ExecuteReplace()
    {
        isLoading = true;
        confirmPending = false;
        var ticket = validatedTicket;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var authCheck = await AuthorizationService.AuthorizeAsync(authState.User, "Comms10k");
            if (!authCheck.Succeeded)
            {
                result = new Comms10kUpdateResult { Success = false, Message = "Authorization denied." };
                return;
            }

            result = await Comms10kService.ExecuteReplaceAsync(resolveResult!.ResolvedDns, currentUser);

            try
            {
                Audit.LogMigrationAction(currentUser, clientIpAddress, "Comms10k_Replace",
                    $"{resolveResult.ResolvedDns.Count} members", result.Success, ticket,
                    result.Success ? null : result.Message);
            }
            catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for Comms10k replace"); }

            try
            {
                await Email.SendAdminNotificationAsync(currentUser, clientIpAddress, "Comms10k_Replace",
                    result.Success, ticket, new Dictionary<string, string>
                    {
                        ["Target Group"] = "Comms-10k",
                        ["Members"] = $"{result.InitialCount} -> {result.FinalCount}"
                    }, result.Success ? null : result.Message);
            }
            catch (Exception emailEx) { Logger.LogError(emailEx, "Email notification failed for Comms10k replace"); }

            parsedEmails = new();
            resolveResult = null;
            preview = null;
        }
        catch (Exception ex)
        {
            result = new Comms10kUpdateResult { Success = false, Message = ex.Message };
            try { Audit.LogMigrationAction(currentUser, clientIpAddress, "Comms10k_Replace", "attempted", false, ticket, ex.Message); } catch { }
            try { await Email.SendAdminNotificationAsync(currentUser, clientIpAddress, "Comms10k_Replace", false, ticket, new Dictionary<string, string> { ["Target Group"] = "Comms-10k" }, ex.Message); } catch { }
        }
        finally { isLoading = false; }
    }
}
