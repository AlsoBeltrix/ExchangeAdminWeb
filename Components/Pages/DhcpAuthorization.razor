@page "/dhcp-authorization"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "DhcpAuthorization")]
@rendermode InteractiveServer
@inject DhcpAuthorizationService DhcpService
@inject AuditService Audit
@inject ServiceNowService ServiceNow
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject ClientInfoService ClientInfo
@inject EmailService Email
@inject ILogger<DhcpAuthorization> Logger

<PageTitle>DHCP Authorization</PageTitle>

@if (!authChecked)
{
    <div class="container-fluid">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Checking authorization...</span>
            </div>
        </div>
    </div>
    return;
}

<div class="container-fluid">
    <div class="alert alert-danger py-2 mb-3">
        <small><strong>High Privilege Operation:</strong> Authorizing or deauthorizing DHCP servers modifies Active Directory at the forest level. All operations require Enterprise Admin credentials and are logged with admin notification.</small>
    </div>
    <h1 class="mb-4">DHCP Authorization</h1>

    @if (operationResult != null)
    {
        <div class="alert @(operationResult.Success ? "alert-success" : "alert-danger") alert-dismissible">
            @operationResult.Message
            <button type="button" class="btn-close" @onclick="() => operationResult = null"></button>
        </div>
    }

    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <strong>Authorized DHCP Servers</strong>
                    <button class="btn btn-outline-primary btn-sm" @onclick="LoadServers" disabled="@isLoading">
                        @if (isLoading && !isOperating) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Refresh
                    </button>
                </div>
                <div class="card-body p-0">
                    @if (loadError != null)
                    {
                        <div class="alert alert-danger m-3">@loadError</div>
                    }
                    else if (servers.Count > 0)
                    {
                        <div style="max-height: calc(100vh - 260px); overflow-y: auto;">
                            <table class="table table-sm mb-0">
                                <thead>
                                    <tr>
                                        <th>DNS Name</th>
                                        <th>IP Address</th>
                                        <th style="width: 120px;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var server in servers)
                                    {
                                        <tr>
                                            <td>@server.DnsName</td>
                                            <td>@server.IpAddress</td>
                                            <td>
                                                @if (confirmRemove == server)
                                                {
                                                    <button class="btn btn-danger btn-sm me-1" @onclick="() => RemoveServer(server)" disabled="@(isOperating || string.IsNullOrWhiteSpace(ticketNumber))">Yes</button>
                                                    <button class="btn btn-secondary btn-sm" @onclick="() => confirmRemove = null">No</button>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => confirmRemove = server" disabled="@isOperating">Remove</button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else if (!isLoading)
                    {
                        <p class="text-muted p-3 mb-0">No authorized DHCP servers found.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card" style="position: sticky; top: 1rem;">
                <div class="card-header"><strong>DHCP Operation Details</strong></div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">DNS Name</label>
                        <input type="text" class="form-control" @bind="newDnsName" @bind:event="oninput" placeholder="dhcp01.contoso.com" disabled="@isOperating" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">IP Address</label>
                        <input type="text" class="form-control" @bind="newIpAddress" @bind:event="oninput" placeholder="10.0.0.1" disabled="@isOperating" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Ticket Number</label>
                        <input type="text" class="form-control" @bind="ticketNumber" @bind:event="oninput" placeholder="INC/REQ number" disabled="@isOperating" />
                        <small class="text-muted">Required for both authorize and deauthorize operations.</small>
                    </div>
                    <button class="btn btn-primary" @onclick="AuthorizeServer"
                            disabled="@(isOperating || string.IsNullOrWhiteSpace(newDnsName) || string.IsNullOrWhiteSpace(newIpAddress) || string.IsNullOrWhiteSpace(ticketNumber))">
                        @if (isOperating) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Authorize
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string currentUser = "";
    private string clientIpAddress = "Unknown";
    private bool authChecked;
    private bool isLoading;
    private bool isOperating;
    private string? loadError;

    private List<DhcpServerEntry> servers = new();
    private DhcpServerEntry? confirmRemove;

    private string newDnsName = "";
    private string newIpAddress = "";
    private string ticketNumber = "";

    private DhcpOperationResult? operationResult;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUser = user.Identity?.Name ?? "Unknown";

        var authResult = await AuthorizationService.AuthorizeAsync(user, "DhcpAuthorization");
        if (!authResult.Succeeded)
        {
            Navigation.NavigateTo("access-denied", forceLoad: true);
            return;
        }

        clientIpAddress = ClientInfo.IpAddress != "Unknown"
            ? ClientInfo.IpAddress
            : ClientInfo.GetIpForUser(currentUser);
        authChecked = true;

        await LoadServers();
    }

    private async Task LoadServers()
    {
        isLoading = true;
        loadError = null;
        await Task.Yield();
        try
        {
            servers = await DhcpService.GetAuthorizedServersAsync();
        }
        catch (Exception ex)
        {
            loadError = ex.Message;
            Logger.LogError(ex, "Failed to load DHCP servers");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task AuthorizeServer()
    {
        isOperating = true;
        operationResult = null;
        await Task.Yield();

        try
        {
            var ticket = ticketNumber.Trim();
            var dns = newDnsName.Trim();
            var ip = newIpAddress.Trim();

            var ticketValidation = await ServiceNow.ValidateTicketAsync(ticket);
            if (!ticketValidation.IsValid)
            {
                operationResult = new DhcpOperationResult { Success = false, Message = $"Ticket validation failed: {ticketValidation.Message}" };
                try { Audit.LogModuleAction(currentUser, clientIpAddress, "DHCP_Authorize", "DhcpAuthorization", $"{dns} ({ip})", false, ticket, $"Ticket validation failed: {ticketValidation.Message}"); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for DHCP authorize ticket validation"); }
                return;
            }

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var authCheck = await AuthorizationService.AuthorizeAsync(authState.User, "DhcpAuthorization");
            if (!authCheck.Succeeded)
            {
                operationResult = new DhcpOperationResult { Success = false, Message = "Authorization denied." };
                try { Audit.LogModuleAction(currentUser, clientIpAddress, "DHCP_Authorize", "DhcpAuthorization", $"{dns} ({ip})", false, ticket, "Authorization denied"); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for DHCP authorize auth denial"); }
                return;
            }

            operationResult = await DhcpService.AuthorizeServerAsync(dns, ip);

            try
            {
                Audit.LogModuleAction(currentUser, clientIpAddress, "DHCP_Authorize",
                    "DhcpAuthorization", $"{dns} ({ip})", operationResult.Success, ticket,
                    operationResult.Success ? null : operationResult.Message);
            }
            catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for DHCP authorize"); }

            try
            {
                await Email.SendAdminNotificationAsync(currentUser, clientIpAddress, "DHCP_Authorize",
                    operationResult.Success, ticket, new Dictionary<string, string>
                    {
                        ["DNS Name"] = dns,
                        ["IP Address"] = ip
                    }, operationResult.Success ? null : operationResult.Message);
            }
            catch (Exception emailEx) { Logger.LogError(emailEx, "Email notification failed for DHCP authorize"); }

            if (operationResult.Success)
            {
                newDnsName = "";
                newIpAddress = "";
                ticketNumber = "";
                await LoadServers();
            }
        }
        catch (Exception ex)
        {
            operationResult = new DhcpOperationResult { Success = false, Message = ex.Message };
            try { Audit.LogModuleAction(currentUser, clientIpAddress, "DHCP_Authorize", "DhcpAuthorization", $"{newDnsName.Trim()} ({newIpAddress.Trim()})", false, ticketNumber.Trim(), ex.Message); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for DHCP authorize"); }
            try { await Email.SendAdminNotificationAsync(currentUser, clientIpAddress, "DHCP_Authorize", false, ticketNumber.Trim(), new Dictionary<string, string> { ["DNS Name"] = newDnsName.Trim(), ["IP Address"] = newIpAddress.Trim() }, ex.Message); } catch { }
        }
        finally
        {
            isOperating = false;
        }
    }

    private async Task RemoveServer(DhcpServerEntry server)
    {
        isOperating = true;
        operationResult = null;
        confirmRemove = null;
        await Task.Yield();

        try
        {
            var ticket = ticketNumber.Trim();
            if (string.IsNullOrWhiteSpace(ticket))
            {
                operationResult = new DhcpOperationResult { Success = false, Message = "A ticket number is required for deauthorization. Enter one in the Authorize form." };
                try { Audit.LogModuleAction(currentUser, clientIpAddress, "DHCP_Deauthorize", "DhcpAuthorization", $"{server.DnsName} ({server.IpAddress})", false, "", "Ticket number not provided"); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for DHCP deauthorize missing ticket"); }
                return;
            }

            var ticketValidation = await ServiceNow.ValidateTicketAsync(ticket);
            if (!ticketValidation.IsValid)
            {
                operationResult = new DhcpOperationResult { Success = false, Message = $"Ticket validation failed: {ticketValidation.Message}" };
                try { Audit.LogModuleAction(currentUser, clientIpAddress, "DHCP_Deauthorize", "DhcpAuthorization", $"{server.DnsName} ({server.IpAddress})", false, ticket, $"Ticket validation failed: {ticketValidation.Message}"); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for DHCP deauthorize ticket validation"); }
                return;
            }

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var authCheck = await AuthorizationService.AuthorizeAsync(authState.User, "DhcpAuthorization");
            if (!authCheck.Succeeded)
            {
                operationResult = new DhcpOperationResult { Success = false, Message = "Authorization denied." };
                try { Audit.LogModuleAction(currentUser, clientIpAddress, "DHCP_Deauthorize", "DhcpAuthorization", $"{server.DnsName} ({server.IpAddress})", false, ticket, "Authorization denied"); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for DHCP deauthorize auth denial"); }
                return;
            }

            operationResult = await DhcpService.DeauthorizeServerAsync(server.DnsName, server.IpAddress);

            try
            {
                Audit.LogModuleAction(currentUser, clientIpAddress, "DHCP_Deauthorize",
                    "DhcpAuthorization", $"{server.DnsName} ({server.IpAddress})", operationResult.Success, ticket,
                    operationResult.Success ? null : operationResult.Message);
            }
            catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for DHCP deauthorize"); }

            try
            {
                await Email.SendAdminNotificationAsync(currentUser, clientIpAddress, "DHCP_Deauthorize",
                    operationResult.Success, ticket, new Dictionary<string, string>
                    {
                        ["DNS Name"] = server.DnsName,
                        ["IP Address"] = server.IpAddress
                    }, operationResult.Success ? null : operationResult.Message);
            }
            catch (Exception emailEx) { Logger.LogError(emailEx, "Email notification failed for DHCP deauthorize"); }

            if (operationResult.Success)
                await LoadServers();
        }
        catch (Exception ex)
        {
            operationResult = new DhcpOperationResult { Success = false, Message = ex.Message };
            try { Audit.LogModuleAction(currentUser, clientIpAddress, "DHCP_Deauthorize", "DhcpAuthorization", $"{server.DnsName} ({server.IpAddress})", false, ticketNumber.Trim(), ex.Message); } catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for DHCP deauthorize"); }
            try { await Email.SendAdminNotificationAsync(currentUser, clientIpAddress, "DHCP_Deauthorize", false, ticketNumber.Trim(), new Dictionary<string, string> { ["DNS Name"] = server.DnsName, ["IP Address"] = server.IpAddress }, ex.Message); } catch { }
        }
        finally
        {
            isOperating = false;
        }
    }
}
