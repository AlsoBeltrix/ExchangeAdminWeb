@page "/protected-principals"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "AdminSettings")]
@rendermode InteractiveServer
@inject ProtectedPrincipalService ProtectedPrincipalService
@inject AuditService Audit
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject ClientInfoService ClientInfo
@inject ILogger<ProtectedPrincipals> Logger

<PageTitle>Protected Principals</PageTitle>

@if (!authChecked)
{
    <div class="container-fluid">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Checking authorization...</span>
            </div>
        </div>
    </div>
    return;
}

<div class="container-fluid">
    <div class="alert alert-warning py-2 mb-3">
        <small><strong>Safety Infrastructure:</strong> Protected principals are blocked from modification across all modules. Changes here take effect immediately.</small>
    </div>
    <h1 class="mb-4">Protected Principals</h1>

    @if (statusMessage != null)
    {
        <div class="alert @(statusIsError ? "alert-danger" : "alert-success") alert-dismissible">
            @statusMessage
            <button type="button" class="btn-close" @onclick="() => statusMessage = null"></button>
        </div>
    }

    @if (loadError != null)
    {
        <div class="alert alert-danger">@loadError</div>
    }

    <div class="row g-3">
        <!-- Users -->
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header"><strong>Protected Users</strong></div>
                <div class="card-body">
                    <p class="text-muted mb-2"><small>UPN, email, sAMAccountName, or DOMAIN\username. One per line.</small></p>
                    <div style="max-height: 200px; overflow-y: auto;" class="mb-2">
                        @if (users.Count > 0)
                        {
                            @foreach (var user in users.ToList())
                            {
                                var captured = user;
                                <div class="d-flex justify-content-between align-items-center border-bottom py-1">
                                    <small>@captured</small>
                                    <button class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="() => users.Remove(captured)" disabled="@saving">×</button>
                                </div>
                            }
                        }
                        else
                        {
                            <small class="text-muted fst-italic">No protected users configured.</small>
                        }
                    </div>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" @bind="newUser" @bind:event="oninput"
                               @onkeydown="OnUserKeyDown" placeholder="user@contoso.com" />
                        <button class="btn btn-outline-success" @onclick="AddUser" disabled="@(saving || string.IsNullOrWhiteSpace(newUser))">Add</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Groups -->
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header"><strong>Protected Groups</strong></div>
                <div class="card-body">
                    <p class="text-muted mb-2"><small>DN, DOMAIN\GroupName, or CN. Members (transitive) are protected.</small></p>
                    <div style="max-height: 200px; overflow-y: auto;" class="mb-2">
                        @if (groups.Count > 0)
                        {
                            @foreach (var group in groups.ToList())
                            {
                                var captured = group;
                                <div class="d-flex justify-content-between align-items-center border-bottom py-1">
                                    <small>@captured</small>
                                    <button class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="() => groups.Remove(captured)" disabled="@saving">×</button>
                                </div>
                            }
                        }
                        else
                        {
                            <small class="text-muted fst-italic">No protected groups configured.</small>
                        }
                    </div>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" @bind="newGroup" @bind:event="oninput"
                               @onkeydown="OnGroupKeyDown" placeholder="DOMAIN\\Domain Admins" />
                        <button class="btn btn-outline-success" @onclick="AddGroup" disabled="@(saving || string.IsNullOrWhiteSpace(newGroup))">Add</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- OUs -->
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header"><strong>Protected OUs</strong></div>
                <div class="card-body">
                    <p class="text-muted mb-2"><small>Distinguished Name of OU. All objects beneath are protected.</small></p>
                    <div style="max-height: 200px; overflow-y: auto;" class="mb-2">
                        @if (ous.Count > 0)
                        {
                            @foreach (var ou in ous.ToList())
                            {
                                var captured = ou;
                                <div class="d-flex justify-content-between align-items-center border-bottom py-1">
                                    <small>@captured</small>
                                    <button class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="() => ous.Remove(captured)" disabled="@saving">×</button>
                                </div>
                            }
                        }
                        else
                        {
                            <small class="text-muted fst-italic">No protected OUs configured.</small>
                        }
                    </div>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" @bind="newOu" @bind:event="oninput"
                               @onkeydown="OnOuKeyDown" placeholder="OU=Tier0,DC=ad,DC=contoso,DC=com" />
                        <button class="btn btn-outline-success" @onclick="AddOu" disabled="@(saving || string.IsNullOrWhiteSpace(newOu))">Add</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Patterns -->
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-header"><strong>sAMAccountName Patterns</strong></div>
                <div class="card-body">
                    <p class="text-muted mb-2"><small>Wildcard patterns matching sAMAccountName (e.g. adm-*, svc-*).</small></p>
                    <div style="max-height: 200px; overflow-y: auto;" class="mb-2">
                        @if (patterns.Count > 0)
                        {
                            @foreach (var pattern in patterns.ToList())
                            {
                                var captured = pattern;
                                <div class="d-flex justify-content-between align-items-center border-bottom py-1">
                                    <small>@captured</small>
                                    <button class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="() => patterns.Remove(captured)" disabled="@saving">×</button>
                                </div>
                            }
                        }
                        else
                        {
                            <small class="text-muted fst-italic">No patterns configured.</small>
                        }
                    </div>
                    <div class="input-group input-group-sm">
                        <input type="text" class="form-control" @bind="newPattern" @bind:event="oninput"
                               @onkeydown="OnPatternKeyDown" placeholder="adm-*" />
                        <button class="btn btn-outline-success" @onclick="AddPattern" disabled="@(saving || string.IsNullOrWhiteSpace(newPattern))">Add</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button class="btn btn-primary" @onclick="SaveConfig" disabled="@saving">
            @if (saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
            Save Protected Principals
        </button>
        <small class="text-muted ms-3">Changes take effect immediately across all modules.</small>
    </div>
</div>

@code {
    private string currentUser = "";
    private string clientIpAddress = "Unknown";
    private bool authChecked;
    private bool saving;
    private string? statusMessage;
    private bool statusIsError;
    private string? loadError;

    private List<string> users = new();
    private List<string> groups = new();
    private List<string> ous = new();
    private List<string> patterns = new();

    private string newUser = "";
    private string newGroup = "";
    private string newOu = "";
    private string newPattern = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUser = user.Identity?.Name ?? "Unknown";

        var authResult = await AuthorizationService.AuthorizeAsync(user, "AdminSettings");
        if (!authResult.Succeeded)
        {
            Navigation.NavigateTo("access-denied", forceLoad: true);
            return;
        }

        clientIpAddress = ClientInfo.IpAddress != "Unknown"
            ? ClientInfo.IpAddress
            : ClientInfo.GetIpForUser(currentUser);

        LoadConfig();
        authChecked = true;
    }

    private void LoadConfig()
    {
        var (cfg, _, error) = ProtectedPrincipalService.LoadEffectiveConfig();
        if (error != null)
        {
            loadError = error;
            return;
        }

        if (cfg != null)
        {
            users = cfg.Users.ToList();
            groups = cfg.Groups.ToList();
            ous = cfg.OrganizationalUnits.ToList();
            patterns = cfg.SamAccountNamePatterns.ToList();
        }
    }

    private void OnUserKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e) { if (e.Key == "Enter") AddUser(); }
    private void OnGroupKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e) { if (e.Key == "Enter") AddGroup(); }
    private void OnOuKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e) { if (e.Key == "Enter") AddOu(); }
    private void OnPatternKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e) { if (e.Key == "Enter") AddPattern(); }

    private void AddUser()
    {
        var val = newUser.Trim();
        if (!string.IsNullOrWhiteSpace(val) && !users.Contains(val, StringComparer.OrdinalIgnoreCase))
            users.Add(val);
        newUser = "";
    }

    private void AddGroup()
    {
        var val = newGroup.Trim();
        if (!string.IsNullOrWhiteSpace(val) && !groups.Contains(val, StringComparer.OrdinalIgnoreCase))
            groups.Add(val);
        newGroup = "";
    }

    private void AddOu()
    {
        var val = newOu.Trim();
        if (!string.IsNullOrWhiteSpace(val) && !ous.Contains(val, StringComparer.OrdinalIgnoreCase))
            ous.Add(val);
        newOu = "";
    }

    private void AddPattern()
    {
        var val = newPattern.Trim();
        if (!string.IsNullOrWhiteSpace(val) && !patterns.Contains(val, StringComparer.OrdinalIgnoreCase))
            patterns.Add(val);
        newPattern = "";
    }

    private async Task SaveConfig()
    {
        saving = true;
        statusMessage = null;
        await Task.Yield();

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var authCheck = await AuthorizationService.AuthorizeAsync(authState.User, "AdminSettings");
            if (!authCheck.Succeeded)
            {
                statusMessage = "Authorization denied.";
                statusIsError = true;
                return;
            }

            var previous = ProtectedPrincipalService.LoadEffectiveConfig().config;

            var newConfig = new ProtectedPrincipalConfig
            {
                Users = users.Where(s => !string.IsNullOrWhiteSpace(s)).ToArray(),
                Groups = groups.Where(s => !string.IsNullOrWhiteSpace(s)).ToArray(),
                OrganizationalUnits = ous.Where(s => !string.IsNullOrWhiteSpace(s)).ToArray(),
                SamAccountNamePatterns = patterns.Where(s => !string.IsNullOrWhiteSpace(s)).ToArray()
            };

            ProtectedPrincipalService.SaveConfig(newConfig);

            try
            {
                var ip = ClientInfo.GetIpForUser(currentUser);
                var prevSummary = previous != null
                    ? $"Users:{previous.Users.Length},Groups:{previous.Groups.Length},OUs:{previous.OrganizationalUnits.Length},Patterns:{previous.SamAccountNamePatterns.Length}"
                    : "(none)";
                var newSummary = $"Users:{newConfig.Users.Length},Groups:{newConfig.Groups.Length},OUs:{newConfig.OrganizationalUnits.Length},Patterns:{newConfig.SamAccountNamePatterns.Length}";
                Audit.LogSettingsChange(currentUser, ip, "ProtectedPrincipals",
                    new[] { prevSummary }, new[] { newSummary });
            }
            catch (Exception auditEx) { Logger.LogError(auditEx, "Audit failed for protected principals change"); }

            statusMessage = "Protected principals saved. Changes are effective immediately.";
            statusIsError = false;
            loadError = null;
        }
        catch (Exception ex)
        {
            statusMessage = $"Failed to save: {ex.Message}";
            statusIsError = true;
            Logger.LogError(ex, "Protected principals save failed");
        }
        finally
        {
            saving = false;
        }
    }
}
