@page "/delegation-report"
@using ExchangeAdminWeb.Models
@using ExchangeAdminWeb.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "DelegationReport")]
@rendermode InteractiveServer
@inject IExchangeService Exchange
@inject AuditService Audit
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject ClientInfoService ClientInfo

<PageTitle>Delegation Report</PageTitle>

<div class="container-fluid mt-4">
    <div class="alert alert-info py-2 mb-3"><small>All lookups are logged for audit purposes.</small></div>
    <h2>Mailbox Delegation Report</h2>
    <p class="text-muted">View Full Access, Send As, and Calendar permissions for a mailbox</p>

    <div class="card">
        <div class="card-body">
            <div class="row g-3 mb-3">
                <div class="col-md-5">
                    <label class="form-label">Email Address</label>
                    <input type="email" class="form-control" @bind="emailAddress" placeholder="user@example.com"
                           disabled="@isLoading" @onkeydown="HandleKeyDown" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary" @onclick="RunReport"
                            disabled="@(string.IsNullOrWhiteSpace(emailAddress) || isLoading)">
                        @if (isLoading)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Check
                    </button>
                </div>
            </div>

            @if (result?.Error != null)
            {
                <div class="alert alert-danger">@result.Error</div>
            }
            else if (result != null)
            {
                <h5 class="mt-4">Full Access</h5>
                @if (result.FullAccess.Any())
                {
                    <table class="table table-sm table-striped">
                        <thead><tr><th>User</th></tr></thead>
                        <tbody>
                            @foreach (var entry in result.FullAccess)
                            {
                                <tr><td>@entry.User</td></tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">No Full Access delegates.</p>
                }

                <h5 class="mt-3">Send As</h5>
                @if (result.SendAs.Any())
                {
                    <table class="table table-sm table-striped">
                        <thead><tr><th>User</th></tr></thead>
                        <tbody>
                            @foreach (var entry in result.SendAs)
                            {
                                <tr><td>@entry.User</td></tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">No Send As delegates.</p>
                }

                <h5 class="mt-3">Calendar</h5>
                @if (result.Calendar.Any())
                {
                    <table class="table table-sm table-striped">
                        <thead><tr><th>User</th><th>Access Rights</th></tr></thead>
                        <tbody>
                            @foreach (var entry in result.Calendar)
                            {
                                <tr><td>@entry.User</td><td>@entry.AccessRights</td></tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">No calendar delegates.</p>
                }
            }
        </div>
    </div>
</div>

@code {
    private string emailAddress = "";
    private bool isLoading = false;
    private DelegationReportResult? result;
    private string currentUser = "";
    private string clientIpAddress = "Unknown";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUser = user.Identity?.Name ?? "Unknown";

        var authResult = await AuthorizationService.AuthorizeAsync(user, "DelegationReport");
        if (!authResult.Succeeded)
        {
            Navigation.NavigateTo("access-denied", forceLoad: true);
            return;
        }

        clientIpAddress = ClientInfo.IpAddress != "Unknown"
            ? ClientInfo.IpAddress
            : ClientInfo.GetIpForUser(currentUser);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(emailAddress))
            await RunReport();
    }

    private async Task RunReport()
    {
        if (string.IsNullOrWhiteSpace(emailAddress)) return;

        isLoading = true;
        result = null;

        try
        {
            result = await Exchange.GetMailboxDelegationAsync(emailAddress.Trim());
            Audit.LogLookupAction(currentUser, clientIpAddress, "DelegationReport", emailAddress.Trim(), result.Error == null, result.Error);
        }
        catch (Exception ex)
        {
            result = new DelegationReportResult { EmailAddress = emailAddress, Error = ex.Message };
        }
        finally
        {
            isLoading = false;
        }
    }
}
