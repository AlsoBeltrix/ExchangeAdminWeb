@page "/admin-event-log"
@using System.Text.Json
@using System.Globalization
@using CsvHelper
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "EventLog")]
@rendermode InteractiveServer
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject IConfiguration Config
@inject IJSRuntime JS
@inject ILogger<AdminEventLog> Logger
@inject ExtendedLogService ExtendedLog
@inject JsonlLogService JsonlLog
@inject UndoRegistry UndoRegistry
@inject ClientInfoService ClientInfo

<PageTitle>Event Log</PageTitle>

@if (!authChecked)
{
    <div class="container-fluid">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Checking authorization...</span>
            </div>
        </div>
    </div>
    return;
}

<div class="container-fluid">
    <h1 class="mb-4">Event Log</h1>

    <div class="row mb-3 g-2 align-items-end">
        <div class="col-auto">
            <label class="form-label mb-0">Start Date</label>
            <input type="date" class="form-control form-control-sm" @bind="startDate" @bind:event="onchange" @bind:after="LoadEvents" />
        </div>
        <div class="col-auto">
            <label class="form-label mb-0">End Date</label>
            <input type="date" class="form-control form-control-sm" @bind="endDate" @bind:event="onchange" @bind:after="LoadEvents" />
        </div>
        <div class="col-auto">
            <label class="form-label mb-0">Category</label>
            <select class="form-select form-select-sm" @bind="selectedCategory" @bind:after="ApplyFilters">
                <option value="">All</option>
                <option value="MailboxPermission">MailboxPermission</option>
                <option value="CalendarPermission">CalendarPermission</option>
                <option value="MigrationCheck">MigrationCheck</option>
                <option value="MigrationBatch">MigrationBatch</option>
                <option value="MigrationAction">MigrationAction</option>
                <option value="Lookup">Lookup</option>
                <option value="AdminSettings">AdminSettings</option>
                <option value="ADAttributeEditor">ADAttributeEditor</option>
                <option value="MfaReset">MfaReset</option>
                <option value="GroupManagement">GroupManagement</option>
                <option value="M365GroupManagement">M365GroupManagement</option>
                <option value="NamedLocations">NamedLocations</option>
                <option value="DhcpAuthorization">DhcpAuthorization</option>
                <option value="OutOfOffice">OutOfOffice</option>
                <option value="ConferenceRooms">ConferenceRooms</option>
            </select>
        </div>
        <div class="col-auto">
            <label class="form-label mb-0">User</label>
            <input type="text" class="form-control form-control-sm" placeholder="Filter by user" @bind="userFilter" @bind:event="oninput" @bind:after="ApplyFilters" />
        </div>
        <div class="col-auto">
            <label class="form-label mb-0">IP</label>
            <input type="text" class="form-control form-control-sm" placeholder="Filter by IP" @bind="ipFilter" @bind:event="oninput" @bind:after="ApplyFilters" />
        </div>
        <div class="col-auto">
            <label class="form-label mb-0">Result</label>
            <select class="form-select form-select-sm" @bind="selectedResult" @bind:after="ApplyFilters">
                <option value="">All</option>
                <option value="Success">Success</option>
                <option value="Failed">Failed</option>
                <option value="Ineligible">Ineligible</option>
            </select>
        </div>
        <div class="col-auto pt-4">
            <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" id="showDiagnosticsToggle" @bind="showDiagnostics" @bind:after="LoadEvents" />
                <label class="form-check-label small" for="showDiagnosticsToggle">Show diagnostics</label>
            </div>
        </div>
        <div class="col-auto pt-4">
            <span class="badge bg-secondary">@filteredEvents.Count events</span>
            <button class="btn btn-outline-secondary btn-sm ms-2" @onclick="DownloadCsv" disabled="@(filteredEvents.Count == 0)">Download CSV</button>
        </div>
    </div>

    @if (loadWarning != null)
    {
        <div class="alert alert-info py-2">@loadWarning</div>
    }
    @if (loadError != null)
    {
        <div class="alert alert-danger">@loadError</div>
    }
    else if (emptyResultMessage != null)
    {
        <p class="text-muted">@emptyResultMessage</p>
    }
    else if (filteredEvents.Count == 0)
    {
        <p class="text-muted">No events found for the selected filters.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover">
                <thead>
                    <tr>
                        <th style="width: 80px;">Time</th>
                        <th>User</th>
                        <th>IP</th>
                        <th>Action</th>
                        <th>Category</th>
                        <th>Target</th>
                        <th>Result</th>
                        @if (hasUndoPermission)
                        {
                            <th style="width: 80px;"></th>
                        }
                        <th style="width: 30px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var evt in GetPage())
                    {
                        var evtId = evt.Index;
                        var rowClass = evt.Source is "Trace" or "Diagnostic" ? "text-muted" : "";
                        var rowStyle = evt.Source is "Trace" or "Diagnostic" ? "cursor: pointer; font-size: 0.85em;" : "cursor: pointer;";
                        <tr @onclick="() => ToggleExpand(evtId)" class="@rowClass" style="@rowStyle">
                            <td>
                                <small>@evt.Time</small>
                            </td>
                            <td>
                                @{
                                    var badgeClass = evt.Source switch
                                    {
                                        "Trace" => "bg-info text-dark",
                                        "Diagnostic" => "bg-secondary",
                                        _ => "bg-primary"
                                    };
                                    var badgeLabel = evt.Source switch
                                    {
                                        "Trace" => "TRACE",
                                        "Diagnostic" => "DIAG",
                                        _ => "AUDIT"
                                    };
                                }
                                <span class="badge @badgeClass me-1" style="font-size: 0.65em; vertical-align: middle;">@badgeLabel</span>
                                @evt.User
                            </td>
                            <td><small>@evt.Ip</small></td>
                            <td>@evt.Action</td>
                            <td>@evt.Category</td>
                            <td style="max-width: 28rem;"><small class="d-inline-block text-truncate align-bottom" style="max-width: 100%;" title="@evt.FullTarget">@evt.Target</small></td>
                            <td>
                                @if (!string.IsNullOrEmpty(evt.Result))
                                {
                                    <span class="badge @(evt.Result == "Success" ? "bg-success" : evt.Result == "Failed" ? "bg-danger" : "bg-warning text-dark")">
                                        @evt.Result
                                    </span>
                                }
                                @if (IsReversed(evt))
                                {
                                    <span class="badge bg-secondary ms-1">Reversed</span>
                                }
                            </td>
                            @if (hasUndoPermission)
                            {
                                <td>
                                    @if (evt.Source == "Audit" && !IsReversed(evt) && evt.IsUndoable)
                                    {
                                        <button class="btn btn-outline-warning btn-sm py-0 px-1"
                                                @onclick="() => ShowUndoPreview(evt)"
                                                @onclick:stopPropagation="true"
                                                title="Undo this action">
                                            Undo
                                        </button>
                                    }
                                </td>
                            }
                            <td>@(expandedRow == evtId ? "▲" : "▼")</td>
                        </tr>
                        @if (expandedRow == evtId)
                        {
                            <tr>
                                <td colspan="@(hasUndoPermission ? 9 : 8)" class="bg-body-tertiary">
                                    @if (evt.Details.Count == 0)
                                    {
                                        <div class="small text-muted p-2">No additional details.</div>
                                    }
                                    else
                                    {
                                        <div class="p-2 small d-grid gap-2" style="grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));">
                                            @foreach (var detail in evt.Details)
                                            {
                                                <div>
                                                    <div class="text-muted">@detail.Key</div>
                                                    <div class="text-break">@detail.Value</div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @if (totalPages > 1)
        {
            <nav>
                <ul class="pagination pagination-sm">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => SetPage(currentPage - 1)">Prev</button>
                    </li>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        var pageNum = i;
                        <li class="page-item @(currentPage == pageNum ? "active" : "")">
                            <button class="page-link" @onclick="() => SetPage(pageNum)">@pageNum</button>
                        </li>
                    }
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => SetPage(currentPage + 1)">Next</button>
                    </li>
                </ul>
            </nav>
        }
    }
</div>

@if (undoPreview != null)
{
    <div class="position-fixed top-0 end-0 bottom-0 bg-dark bg-opacity-50" style="left: 0; z-index: 1040;" @onclick="CloseUndoPanel"></div>
    <div class="position-fixed top-0 end-0 bottom-0 bg-body shadow-lg d-flex flex-column" style="width: min(500px, 90vw); z-index: 1050;">
        <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Undo Preview</h5>
            <button type="button" class="btn-close" @onclick="CloseUndoPanel"></button>
        </div>
        <div class="p-3 flex-grow-1 overflow-auto">
            @if (undoLoading)
            {
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading preview...</span>
                    </div>
                </div>
            }
            else if (undoPreview.Error != null && !undoPreview.CanUndo)
            {
                <div class="alert alert-danger">@undoPreview.Error</div>
            }
            else
            {
                <div class="mb-3">
                    <div class="text-muted small">Module</div>
                    <div>@undoPreview.Module</div>
                </div>
                <div class="mb-3">
                    <div class="text-muted small">Action</div>
                    <div>@undoPreview.Action</div>
                </div>
                <div class="mb-3">
                    <div class="text-muted small">Target</div>
                    <div>@undoPreview.Target</div>
                </div>

                @if (undoPreview.HasConflict)
                {
                    <div class="alert alert-warning">
                        <strong>Conflict detected.</strong> @undoPreview.ConflictDetail
                    </div>
                }

                @if (undoPreview.Changes != null)
                {
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Attribute</th>
                                <th>Current</th>
                                <th>Expected</th>
                                <th>Revert To</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var change in undoPreview.Changes)
                            {
                                <tr class="@(change.IsConflict ? "table-warning" : "")">
                                    <td class="fw-semibold">@change.Field</td>
                                    <td class="small text-break">@(change.CurrentValue ?? "(empty)")</td>
                                    <td class="small text-break">@(change.ExpectedValue ?? "(empty)")</td>
                                    <td class="small text-break">@(change.RevertToValue ?? "(empty)")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                @if (undoPreview.CanUndo)
                {
                    <div class="mb-3">
                        <label class="form-label">Ticket Number <span class="text-danger">*</span></label>
                        <input type="text" class="form-control form-control-sm" @bind="undoTicket" placeholder="Required" />
                    </div>
                }
            }

            @if (undoError != null)
            {
                <div class="alert alert-danger mt-2">@undoError</div>
            }
            @if (undoSuccess != null)
            {
                <div class="alert alert-success mt-2">@undoSuccess</div>
            }
        </div>
        <div class="p-3 border-top d-flex gap-2 justify-content-end">
            <button class="btn btn-secondary btn-sm" @onclick="CloseUndoPanel">
                @(undoSuccess != null ? "Close" : "Cancel")
            </button>
            @if (undoPreview.CanUndo && undoSuccess == null)
            {
                <button class="btn btn-warning btn-sm" @onclick="ExecuteUndo" disabled="@(undoExecuting || string.IsNullOrWhiteSpace(undoTicket))">
                    @if (undoExecuting)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Confirm Undo
                </button>
            }
        </div>
    </div>
}

@code {
    private bool authChecked;
    private bool showDiagnostics;
    private DateOnly startDate = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly endDate = DateOnly.FromDateTime(DateTime.Today);
    private string selectedCategory = "";
    private string userFilter = "";
    private string ipFilter = "";
    private string selectedResult = "";
    private string? loadError;
    private string? loadWarning;
    private string? emptyResultMessage;
    private int currentPage = 1;
    private int expandedRow = -1;
    private const int PageSize = 50;
    private const int MaxTotalEvents = 2000;

    private List<MergedLogEntry> allEvents = new();
    private List<MergedLogEntry> filteredEvents = new();
    private int totalPages => Math.Max(1, (int)Math.Ceiling(filteredEvents.Count / (double)PageSize));

    // Undo state
    private bool hasUndoPermission;
    private UndoPreview? undoPreview;
    private bool undoLoading;
    private bool undoExecuting;
    private string undoTicket = "";
    private string? undoError;
    private string? undoSuccess;
    private MergedLogEntry? undoTargetEvent;
    private HashSet<string> reversedOperationIds = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var authResult = await AuthorizationService.AuthorizeAsync(user, "EventLog");
        if (!authResult.Succeeded)
        {
            Navigation.NavigateTo("access-denied", forceLoad: true);
            return;
        }

        hasUndoPermission = (await AuthorizationService.AuthorizeAsync(user, "UndoAuditedActions")).Succeeded;

        authChecked = true;
        LoadEvents();
    }

    private void LoadEvents()
    {
        loadError = null;
        loadWarning = null;
        emptyResultMessage = null;
        allEvents = new List<MergedLogEntry>();
        expandedRow = -1;
        currentPage = 1;

        var effectiveStart = startDate <= endDate ? startDate : endDate;
        var effectiveEnd = startDate <= endDate ? endDate : startDate;

        var filesLoaded = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var buffer = new Queue<MergedLogEntry>(MaxTotalEvents + 1);
        var filesNotFound = 0;
        var filesFound = 0;
        var rangeStartUtc = effectiveStart.ToDateTime(TimeOnly.MinValue).ToUniversalTime();
        var rangeEndUtc = effectiveEnd.AddDays(1).ToDateTime(TimeOnly.MinValue).ToUniversalTime();
        var totalParsed = 0;

        for (var d = effectiveStart; d <= effectiveEnd; d = d.AddDays(1))
        {
            var date = d.ToDateTime(TimeOnly.MinValue);

            // --- Audit files ---
            var auditPaths = JsonlLog.GetAuditLogPaths(date).ToList();
            var foundFileForDate = false;
            foreach (var filePath in auditPaths)
            {
                if (!filesLoaded.Add(filePath)) continue;
                if (!File.Exists(filePath)) continue;

                foundFileForDate = true;
                filesFound++;
                try
                {
                    foreach (var line in ReadLinesShared(filePath))
                    {
                        if (string.IsNullOrWhiteSpace(line)) continue;
                        var entry = ParseAuditLine(line, rangeStartUtc, rangeEndUtc);
                        if (entry == null) continue;

                        totalParsed++;
                        buffer.Enqueue(entry);
                        if (buffer.Count > MaxTotalEvents)
                            buffer.Dequeue();
                    }
                }
                catch (Exception ex)
                {
                    loadError = $"Error reading log: {ex.Message}";
                    Logger.LogError(ex, "Failed to read audit log file {Path}", filePath);
                }
            }

            // --- Trace files (only when diagnostics enabled) ---
            if (showDiagnostics)
            {
                var tracePaths = JsonlLog.GetTraceLogPaths(date).ToList();
                foreach (var filePath in tracePaths)
                {
                    if (!filesLoaded.Add(filePath)) continue;
                    if (!File.Exists(filePath)) continue;

                    foundFileForDate = true;
                    filesFound++;
                    try
                    {
                        foreach (var line in ReadLinesShared(filePath))
                        {
                            if (string.IsNullOrWhiteSpace(line)) continue;
                            var entry = ParseTraceLine(line, rangeStartUtc, rangeEndUtc);
                            if (entry == null) continue;

                            totalParsed++;
                            buffer.Enqueue(entry);
                            if (buffer.Count > MaxTotalEvents)
                                buffer.Dequeue();
                        }
                    }
                    catch (Exception ex)
                    {
                        Logger.LogError(ex, "Failed to read trace log file {Path}", filePath);
                    }
                }

                // --- Extended diagnostic files ---
                var extEntries = ExtendedLog.GetEntries(date, date, MaxTotalEvents);
                foreach (var line in extEntries)
                {
                    if (string.IsNullOrWhiteSpace(line)) continue;
                    var entry = ParseExtendedLine(line, rangeStartUtc, rangeEndUtc);
                    if (entry == null) continue;

                    totalParsed++;
                    buffer.Enqueue(entry);
                    if (buffer.Count > MaxTotalEvents)
                        buffer.Dequeue();
                }
            }

            if (!foundFileForDate)
                filesNotFound++;
        }

        var anyFileFound = filesFound > 0;
        if (buffer.Count == 0 && loadError == null)
        {
            emptyResultMessage = !anyFileFound
                ? (effectiveStart == effectiveEnd
                    ? $"No events recorded for {effectiveStart:yyyy-MM-dd}."
                    : $"No events recorded for {effectiveStart:yyyy-MM-dd} to {effectiveEnd:yyyy-MM-dd}.")
                : "No events matched the selected date range.";
            filteredEvents = new();
            return;
        }

        if (totalParsed > MaxTotalEvents)
            loadWarning = $"Showing last {MaxTotalEvents} of {totalParsed} events in range.";

        // Sort merged entries by parsed timestamp (descending: newest first)
        allEvents = buffer.OrderByDescending(e => e.Timestamp).ToList();
        for (int i = 0; i < allEvents.Count; i++)
            allEvents[i].Index = i;

        // Build the set of operation IDs that have been reversed (referenced by a later undo event)
        reversedOperationIds = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var evt in allEvents)
        {
            if (!string.IsNullOrEmpty(evt.OriginalOperationId))
                reversedOperationIds.Add(evt.OriginalOperationId);
        }

        ApplyFilters();
    }

    private MergedLogEntry? ParseAuditLine(string line, DateTime rangeStartUtc, DateTime rangeEndUtc)
    {
        try
        {
            using var doc = JsonDocument.Parse(line);
            var root = doc.RootElement;

            var tsStr = TryGetString(root, "ts");
            DateTimeOffset eventTime = default;
            if (tsStr != null && DateTimeOffset.TryParse(tsStr, out eventTime))
            {
                if (eventTime.UtcDateTime < rangeStartUtc || eventTime.UtcDateTime >= rangeEndUtc)
                    return null;
            }

            var eventType = TryGetString(root, "eventType") ?? "audit";
            if (!eventType.Equals("audit", StringComparison.OrdinalIgnoreCase))
                return null;

            var rawTarget = GetAuditTarget(root);

            // Build raw fields dictionary for undo support
            var rawFields = new Dictionary<string, object?>(StringComparer.OrdinalIgnoreCase);
            foreach (var property in root.EnumerateObject())
            {
                rawFields[property.Name] = property.Value.Clone();
            }

            // Check if this event is undoable
            var isUndoable = false;
            if (hasUndoPermission)
            {
                try { isUndoable = UndoRegistry.FindHandler(rawFields) != null; }
                catch { }
            }

            return new MergedLogEntry
            {
                Timestamp = eventTime,
                Source = "Audit",
                Time = tsStr != null ? FormatTimestamp(tsStr) : "",
                User = TryGetString(root, "user") ?? "",
                Ip = TryGetString(root, "ip") ?? "",
                Action = FormatAction(root, eventType),
                Category = FormatCategory(root, eventType),
                Target = FormatTargetSummary(rawTarget),
                FullTarget = rawTarget ?? "",
                Result = TryGetString(root, "result") ?? "",
                Level = "",
                Message = "",
                OperationId = TryGetString(root, "operationId") ?? "",
                OriginalOperationId = TryGetString(root, "originalOperationId"),
                IsUndoable = isUndoable,
                RawFields = rawFields,
                Details = ExtractAuditDetails(root, eventType, rawTarget)
            };
        }
        catch
        {
            return null;
        }
    }

    private MergedLogEntry? ParseTraceLine(string line, DateTime rangeStartUtc, DateTime rangeEndUtc)
    {
        try
        {
            using var doc = JsonDocument.Parse(line);
            var root = doc.RootElement;

            var tsStr = TryGetString(root, "ts");
            DateTimeOffset eventTime = default;
            if (tsStr != null && DateTimeOffset.TryParse(tsStr, out eventTime))
            {
                if (eventTime.UtcDateTime < rangeStartUtc || eventTime.UtcDateTime >= rangeEndUtc)
                    return null;
            }

            var stage = TryGetString(root, "stage") ?? TryGetString(root, "action") ?? "";
            var module = TryGetString(root, "module") ?? "";

            var details = new List<DetailField>();
            foreach (var property in root.EnumerateObject())
            {
                if (property.Name is "ts" or "eventType" or "stage" or "module" or "action" or "user" or "ip" or "operationId")
                    continue;

                if (property.Value.ValueKind == JsonValueKind.Object)
                {
                    foreach (var sub in property.Value.EnumerateObject())
                        AddDetail(details, HumanizePropertyName(sub.Name), FormatJsonValue(sub.Value));
                }
                else
                {
                    AddDetail(details, HumanizePropertyName(property.Name), FormatJsonValue(property.Value));
                }
            }

            return new MergedLogEntry
            {
                Timestamp = eventTime,
                Source = "Trace",
                Time = tsStr != null ? FormatTimestamp(tsStr) : "",
                User = TryGetString(root, "user") ?? "",
                Ip = TryGetString(root, "ip") ?? "",
                Action = stage,
                Category = module,
                Target = "",
                FullTarget = "",
                Result = TryGetString(root, "result") ?? "",
                Level = "",
                Message = "",
                OperationId = TryGetString(root, "operationId") ?? "",
                Details = details
            };
        }
        catch
        {
            return null;
        }
    }

    private MergedLogEntry? ParseExtendedLine(string line, DateTime rangeStartUtc, DateTime rangeEndUtc)
    {
        try
        {
            using var doc = JsonDocument.Parse(line);
            var root = doc.RootElement;

            var tsStr = TryGetString(root, "ts");
            DateTimeOffset eventTime = default;
            if (tsStr != null && DateTimeOffset.TryParse(tsStr, out eventTime))
            {
                if (eventTime.UtcDateTime < rangeStartUtc || eventTime.UtcDateTime >= rangeEndUtc)
                    return null;
            }

            var level = TryGetString(root, "level") ?? "Info";
            var message = TryGetString(root, "message") ?? "";
            var category = TryGetString(root, "category") ?? "";
            var detail = TryGetString(root, "detail") ?? "";

            var details = new List<DetailField>();
            if (!string.IsNullOrWhiteSpace(detail))
            {
                var parsedFields = ParseExtendedDetail(detail);
                if (parsedFields.Count > 0)
                {
                    details.AddRange(parsedFields);
                }
                else
                {
                    AddDetail(details, "Detail", detail);
                }
            }

            return new MergedLogEntry
            {
                Timestamp = eventTime,
                Source = "Diagnostic",
                Time = tsStr != null ? FormatTimestamp(tsStr) : "",
                User = "",
                Ip = "",
                Action = message,
                Category = category,
                Target = "",
                FullTarget = "",
                Result = level,
                Level = level,
                Message = message,
                OperationId = "",
                Details = details
            };
        }
        catch
        {
            return null;
        }
    }

    private void ApplyFilters()
    {
        currentPage = 1;
        expandedRow = -1;
        filteredEvents = allEvents.Where(e =>
            CategoryMatches(e) &&
            (string.IsNullOrEmpty(userFilter) || e.User.Contains(userFilter, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(ipFilter) || e.Ip.Contains(ipFilter, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(selectedResult) || e.Result.Equals(selectedResult, StringComparison.OrdinalIgnoreCase))
        ).ToList();
    }

    private bool CategoryMatches(MergedLogEntry evt) =>
        string.IsNullOrEmpty(selectedCategory)
        || evt.Category.Equals(selectedCategory, StringComparison.OrdinalIgnoreCase)
        || (selectedCategory == "OperationTrace" && evt.Category.StartsWith("OperationTrace", StringComparison.OrdinalIgnoreCase));

    private List<MergedLogEntry> GetPage() =>
        filteredEvents.Skip((currentPage - 1) * PageSize).Take(PageSize).ToList();

    private void SetPage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
            expandedRow = -1;
        }
    }

    private void ToggleExpand(int index) =>
        expandedRow = expandedRow == index ? -1 : index;

    private bool IsReversed(MergedLogEntry evt) =>
        !string.IsNullOrEmpty(evt.OperationId) && reversedOperationIds.Contains(evt.OperationId);

    private async Task ShowUndoPreview(MergedLogEntry evt)
    {
        undoTargetEvent = evt;
        undoLoading = true;
        undoError = null;
        undoSuccess = null;
        undoTicket = "";
        undoPreview = new UndoPreview(false, null, "", "", "", null, null, false, null); // placeholder while loading
        StateHasChanged();

        try
        {
            var handler = UndoRegistry.FindHandler(evt.RawFields);
            if (handler == null)
            {
                undoPreview = new UndoPreview(false, "No undo handler available for this event.", "", "", "", null, null, false, null);
                return;
            }

            undoPreview = await handler.PreviewUndoAsync(evt.RawFields);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load undo preview for operation {OperationId}", evt.OperationId);
            undoPreview = new UndoPreview(false, $"Failed to load undo preview: {ex.Message}", "", "", "", null, null, false, null);
        }
        finally
        {
            undoLoading = false;
            StateHasChanged();
        }
    }

    private void CloseUndoPanel()
    {
        undoPreview = null;
        undoTargetEvent = null;
        undoError = null;
        undoSuccess = null;
        undoTicket = "";
    }

    private async Task ExecuteUndo()
    {
        if (undoTargetEvent == null || undoPreview == null || string.IsNullOrWhiteSpace(undoTicket))
            return;

        undoExecuting = true;
        undoError = null;
        StateHasChanged();

        try
        {
            var handler = UndoRegistry.FindHandler(undoTargetEvent.RawFields);
            if (handler == null)
            {
                undoError = "No undo handler available for this event.";
                return;
            }

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userName = authState.User.Identity?.Name ?? "unknown";
            var clientIp = ClientInfo.IpAddress;

            var fields = new Dictionary<string, object?>(undoTargetEvent.RawFields, StringComparer.OrdinalIgnoreCase);
            if (handler.ModuleId == "ADAttributeEditor")
            {
                var maxLevel = 0;
                for (var lvl = 3; lvl >= 1; lvl--)
                {
                    var levelCheck = await AuthorizationService.AuthorizeAsync(authState.User, $"ADAttributeEditorLevel{lvl}");
                    if (levelCheck.Succeeded) { maxLevel = lvl; break; }
                }
                fields["_undoMaxLevel"] = maxLevel;
            }

            var result = await handler.ExecuteUndoAsync(
                fields,
                userName,
                clientIp,
                undoTicket.Trim());

            if (result.Success)
            {
                undoSuccess = $"Undo completed successfully. Reversal operation ID: {result.ReversalOperationId ?? "N/A"}";
                if (!string.IsNullOrEmpty(undoPreview?.OriginalOperationId))
                    reversedOperationIds.Add(undoPreview.OriginalOperationId);
                LoadEvents();
            }
            else
            {
                undoError = result.Error ?? "Undo failed.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to execute undo for operation {OperationId}", undoTargetEvent.OperationId);
            undoError = $"Unexpected error: {ex.Message}";
        }
        finally
        {
            undoExecuting = false;
            StateHasChanged();
        }
    }

    private static string? TryGetString(JsonElement root, string prop) =>
        root.TryGetProperty(prop, out var val) && val.ValueKind == JsonValueKind.String ? val.GetString() : null;

    private static string? GetAuditTarget(JsonElement root) =>
        TryGetString(root, "target") ?? TryGetString(root, "batchName") ?? TryGetString(root, "section");

    private static string FormatTargetSummary(string? target)
    {
        if (string.IsNullOrWhiteSpace(target))
            return "";

        var messageIdIndex = target.IndexOf(" MessageId=", StringComparison.OrdinalIgnoreCase);
        var summary = messageIdIndex > 0 ? target[..messageIdIndex] : target;
        return summary.Length <= 90 ? summary : $"{summary[..87]}...";
    }

    private static string FormatTimestamp(string iso)
    {
        if (DateTimeOffset.TryParse(iso, out var dt))
            return dt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");
        return iso;
    }

    private static string FormatAction(JsonElement root, string eventType)
    {
        var action = TryGetString(root, "action") ?? eventType;
        if (!eventType.StartsWith("operation.", StringComparison.OrdinalIgnoreCase))
            return action;

        var stage = TryGetString(root, "stage");
        return string.IsNullOrWhiteSpace(stage) ? action : $"{action} / {stage}";
    }

    private static string FormatCategory(JsonElement root, string eventType)
    {
        if (!eventType.StartsWith("operation.", StringComparison.OrdinalIgnoreCase))
            return TryGetString(root, "category") ?? "";

        var module = TryGetString(root, "module");
        return string.IsNullOrWhiteSpace(module) ? "OperationTrace" : $"OperationTrace:{module}";
    }

    private static List<DetailField> ExtractAuditDetails(JsonElement root, string eventType, string? rawTarget)
    {
        var details = new List<DetailField>();
        AddTargetDetails(details, rawTarget);

        foreach (var property in root.EnumerateObject())
        {
            if (IsSummaryField(property.Name, eventType))
                continue;

            if (property.Name.Equals("details", StringComparison.OrdinalIgnoreCase) && property.Value.ValueKind == JsonValueKind.Object)
            {
                foreach (var detailProperty in property.Value.EnumerateObject())
                {
                    AddDetail(details, HumanizePropertyName(detailProperty.Name), FormatJsonValue(detailProperty.Value));
                }
                continue;
            }

            AddDetail(details, HumanizePropertyName(property.Name), FormatJsonValue(property.Value));
        }

        return details;
    }

    private static void AddTargetDetails(List<DetailField> details, string? rawTarget)
    {
        if (string.IsNullOrWhiteSpace(rawTarget))
            return;

        var messageIdIndex = rawTarget.IndexOf(" MessageId=", StringComparison.OrdinalIgnoreCase);
        var route = messageIdIndex > 0 ? rawTarget[..messageIdIndex] : rawTarget;
        var arrow = route.IndexOf("->", StringComparison.Ordinal);
        if (arrow > 0)
        {
            AddDetail(details, "Sender", route[..arrow].Trim());
            AddDetail(details, "Recipient", route[(arrow + 2)..].Trim());
        }

        if (messageIdIndex > 0)
        {
            AddDetail(details, "Message ID", rawTarget[(messageIdIndex + " MessageId=".Length)..].Trim());
        }

        AddDetail(details, "Full Target", rawTarget);
    }

    private static void AddDetail(List<DetailField> details, string key, string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return;

        if (details.Any(d => d.Key.Equals(key, StringComparison.OrdinalIgnoreCase) && d.Value.Equals(value, StringComparison.OrdinalIgnoreCase)))
            return;

        details.Add(new DetailField(key, value));
    }

    private static bool IsSummaryField(string name, string eventType)
    {
        if (name is "ts" or "user" or "ip" or "category" or "result" or "target" or "batchName" or "section")
            return true;

        if (name is "action")
            return true;

        if (eventType.StartsWith("operation.", StringComparison.OrdinalIgnoreCase))
            return name is "module" or "stage";

        return false;
    }

    private static string FormatJsonValue(JsonElement value) => value.ValueKind switch
    {
        JsonValueKind.String => value.GetString() ?? "",
        JsonValueKind.Number => value.GetRawText(),
        JsonValueKind.True => "true",
        JsonValueKind.False => "false",
        JsonValueKind.Array => string.Join(", ", value.EnumerateArray().Select(FormatJsonValue).Where(v => !string.IsNullOrWhiteSpace(v))),
        JsonValueKind.Object => value.GetRawText(),
        _ => ""
    };

    private static string HumanizePropertyName(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return name;

        var chars = new List<char>(name.Length + 8);
        for (var i = 0; i < name.Length; i++)
        {
            var c = name[i] == '_' ? ' ' : name[i];
            if (i > 0 && c != ' ' && char.IsUpper(c) && (char.IsLower(name[i - 1]) || char.IsDigit(name[i - 1])))
                chars.Add(' ');
            chars.Add(c);
        }

        return new string(chars.ToArray());
    }

    private async Task DownloadCsv()
    {
        if (filteredEvents.Count == 0) return;

        // Exclude trace/diagnostic entries from CSV unless diagnostics are on
        var csvEntries = showDiagnostics
            ? filteredEvents
            : filteredEvents.Where(e => e.Source == "Audit").ToList();

        if (csvEntries.Count == 0) return;

        using var writer = new System.IO.StringWriter();
        using var csv = new CsvWriter(writer, CultureInfo.InvariantCulture);

        csv.WriteField("Time");
        csv.WriteField("Source");
        csv.WriteField("User");
        csv.WriteField("IP");
        csv.WriteField("Action");
        csv.WriteField("Category");
        csv.WriteField("Target");
        csv.WriteField("Result");
        await csv.NextRecordAsync();

        foreach (var evt in csvEntries)
        {
            csv.WriteField(evt.Time);
            csv.WriteField(evt.Source);
            csv.WriteField(evt.User);
            csv.WriteField(evt.Ip);
            csv.WriteField(evt.Action);
            csv.WriteField(evt.Category);
            csv.WriteField(evt.FullTarget);
            csv.WriteField(evt.Result);
            await csv.NextRecordAsync();
        }

        await csv.FlushAsync();
        var bytes = System.Text.Encoding.UTF8.GetBytes(writer.ToString());
        var base64 = Convert.ToBase64String(bytes);
        var timestamp = DateTime.Now.ToString("yyyyMMdd_HHmmss");
        await JS.InvokeVoidAsync("downloadFile", $"event_log_{timestamp}.csv", "text/csv", base64);
    }

    private static List<DetailField> ParseExtendedDetail(string detail)
    {
        var fields = new List<DetailField>();
        if (string.IsNullOrWhiteSpace(detail))
            return fields;

        foreach (var part in detail.Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            var separator = part.IndexOf('=');
            if (separator <= 0 || separator == part.Length - 1)
                return new();

            fields.Add(new DetailField(part[..separator].Trim(), part[(separator + 1)..].Trim()));
        }

        return fields;
    }

    private static IEnumerable<string> ReadLinesShared(string path)
    {
        using var stream = new FileStream(path, FileMode.Open, FileAccess.Read, FileShare.ReadWrite | FileShare.Delete);
        using var reader = new StreamReader(stream);
        while (reader.ReadLine() is { } line)
            yield return line;
    }

    private sealed record DetailField(string Key, string Value);

    private sealed record MergedLogEntry
    {
        public int Index { get; set; }
        public DateTimeOffset Timestamp { get; set; }
        public string Source { get; set; } = "Audit";
        public string Time { get; set; } = "";
        public string User { get; set; } = "";
        public string Ip { get; set; } = "";
        public string Action { get; set; } = "";
        public string Category { get; set; } = "";
        public string Target { get; set; } = "";
        public string FullTarget { get; set; } = "";
        public string Result { get; set; } = "";
        public string Level { get; set; } = "";
        public string Message { get; set; } = "";
        public string OperationId { get; set; } = "";
        public string? OriginalOperationId { get; set; }
        public bool IsUndoable { get; set; }
        public Dictionary<string, object?> RawFields { get; set; } = new();
        public List<DetailField> Details { get; set; } = new();
    }
}
