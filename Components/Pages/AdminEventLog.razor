@page "/admin-event-log"
@using System.Text.Json
@using System.Globalization
@using CsvHelper
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Policy = "EventLog")]
@rendermode InteractiveServer
@inject AuthenticationStateProvider AuthStateProvider
@inject IAuthorizationService AuthorizationService
@inject NavigationManager Navigation
@inject IConfiguration Config
@inject IJSRuntime JS
@inject ILogger<AdminEventLog> Logger
@inject ExtendedLogService ExtendedLog

<PageTitle>Event Log</PageTitle>

@if (!authChecked)
{
    <div class="container-fluid">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Checking authorization...</span>
            </div>
        </div>
    </div>
    return;
}

<div class="container-fluid">
    <h1 class="mb-4">Event Log</h1>

    <div class="row mb-3 g-2 align-items-end">
        <div class="col-auto">
            <label class="form-label mb-0">Start Date</label>
            <input type="date" class="form-control form-control-sm" @bind="startDate" @bind:event="onchange" @bind:after="LoadEvents" />
        </div>
        <div class="col-auto">
            <label class="form-label mb-0">End Date</label>
            <input type="date" class="form-control form-control-sm" @bind="endDate" @bind:event="onchange" @bind:after="LoadEvents" />
        </div>
        <div class="col-auto">
            <label class="form-label mb-0">Category</label>
            <select class="form-select form-select-sm" @bind="selectedCategory" @bind:after="ApplyFilters">
                <option value="">All</option>
                <option value="MailboxPermission">MailboxPermission</option>
                <option value="CalendarPermission">CalendarPermission</option>
                <option value="MigrationCheck">MigrationCheck</option>
                <option value="MigrationBatch">MigrationBatch</option>
                <option value="MigrationAction">MigrationAction</option>
                <option value="Lookup">Lookup</option>
                <option value="AdminSettings">AdminSettings</option>
            </select>
        </div>
        <div class="col-auto">
            <label class="form-label mb-0">User</label>
            <input type="text" class="form-control form-control-sm" placeholder="Filter by user" @bind="userFilter" @bind:event="oninput" @bind:after="ApplyFilters" />
        </div>
        <div class="col-auto">
            <label class="form-label mb-0">IP</label>
            <input type="text" class="form-control form-control-sm" placeholder="Filter by IP" @bind="ipFilter" @bind:event="oninput" @bind:after="ApplyFilters" />
        </div>
        <div class="col-auto">
            <label class="form-label mb-0">Result</label>
            <select class="form-select form-select-sm" @bind="selectedResult" @bind:after="ApplyFilters">
                <option value="">All</option>
                <option value="Success">Success</option>
                <option value="Failed">Failed</option>
                <option value="Ineligible">Ineligible</option>
            </select>
        </div>
        <div class="col-auto pt-4">
            <span class="badge bg-secondary">@filteredEvents.Count events</span>
            <button class="btn btn-outline-secondary btn-sm ms-2" @onclick="DownloadCsv" disabled="@(filteredEvents.Count == 0)">Download CSV</button>
        </div>
    </div>

    @if (loadWarning != null)
    {
        <div class="alert alert-info py-2">@loadWarning</div>
    }
    @if (loadError != null)
    {
        <div class="alert alert-danger">@loadError</div>
    }
    else if (filteredEvents.Count == 0)
    {
        <div class="alert alert-info">No events found for the selected filters.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-hover">
                <thead>
                    <tr>
                        <th style="width: 80px;">Time</th>
                        <th>User</th>
                        <th>IP</th>
                        <th>Action</th>
                        <th>Category</th>
                        <th>Target</th>
                        <th>Result</th>
                        <th style="width: 30px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var evt in GetPage())
                    {
                        var evtId = evt.Index;
                        <tr @onclick="() => ToggleExpand(evtId)" style="cursor: pointer;">
                            <td><small>@evt.Time</small></td>
                            <td>@evt.User</td>
                            <td><small>@evt.Ip</small></td>
                            <td>@evt.Action</td>
                            <td>@evt.Category</td>
                            <td style="max-width: 28rem;"><small class="d-inline-block text-truncate align-bottom" style="max-width: 100%;" title="@evt.FullTarget">@evt.Target</small></td>
                            <td>
                                <span class="badge @(evt.Result == "Success" ? "bg-success" : evt.Result == "Failed" ? "bg-danger" : "bg-warning text-dark")">
                                    @evt.Result
                                </span>
                            </td>
                            <td>@(expandedRow == evtId ? "▲" : "▼")</td>
                        </tr>
                        @if (expandedRow == evtId)
                        {
                            <tr>
                                <td colspan="8" class="bg-body-tertiary">
                                    @if (evt.Details.Count == 0)
                                    {
                                        <div class="small text-muted p-2">No additional details.</div>
                                    }
                                    else
                                    {
                                        <div class="p-2 small d-grid gap-2" style="grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));">
                                            @foreach (var detail in evt.Details)
                                            {
                                                <div>
                                                    <div class="text-muted">@detail.Key</div>
                                                    <div class="text-break">@detail.Value</div>
                                                </div>
                                            }
                                        </div>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @if (totalPages > 1)
        {
            <nav>
                <ul class="pagination pagination-sm">
                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                        <button class="page-link" @onclick="() => SetPage(currentPage - 1)">Prev</button>
                    </li>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        var pageNum = i;
                        <li class="page-item @(currentPage == pageNum ? "active" : "")">
                            <button class="page-link" @onclick="() => SetPage(pageNum)">@pageNum</button>
                        </li>
                    }
                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                        <button class="page-link" @onclick="() => SetPage(currentPage + 1)">Next</button>
                    </li>
                </ul>
            </nav>
        }
    }

    @if (ExtendedLog.HasExtendedLogs(startDate.ToDateTime(TimeOnly.MinValue), endDate.ToDateTime(TimeOnly.MaxValue)))
    {
        <div class="mt-4">
            <button class="btn btn-outline-info btn-sm" @onclick="ToggleExtendedLogs">
                @(showExtendedLogs ? "Hide" : "Show") Extended Logs
            </button>
            @if (showExtendedLogs)
            {
                <div class="card mt-2">
                    <div class="card-header"><strong>Extended Diagnostic Logs</strong> <small class="text-muted">(@startDate - @endDate)</small></div>
                    <div class="table-responsive" style="max-height: 480px; overflow-y: auto;">
                        <table class="table table-sm table-dark table-hover mb-0 align-middle">
                            <thead class="sticky-top">
                                <tr>
                                    <th style="width: 150px;">Time</th>
                                    <th style="width: 90px;">Level</th>
                                    <th style="width: 130px;">Category</th>
                                    <th>Event</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in extendedLogEvents)
                                {
                                    <tr>
                                        <td class="text-nowrap small">@entry.Time</td>
                                        <td><span class="badge @GetExtendedLevelBadge(entry.Level)">@entry.Level</span></td>
                                        <td class="small">@entry.Category</td>
                                        <td>
                                            <div>@entry.Message</div>
                                            @if (entry.DetailFields.Count > 0)
                                            {
                                                <div class="small text-muted mt-1 d-flex flex-wrap gap-2">
                                                    @foreach (var field in entry.DetailFields)
                                                    {
                                                        <span><strong>@field.Key:</strong> @field.Value</span>
                                                    }
                                                </div>
                                            }
                                            else if (!string.IsNullOrWhiteSpace(entry.Detail))
                                            {
                                                <div class="small text-muted mt-1">@entry.Detail</div>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private bool authChecked;
    private bool showExtendedLogs;
    private List<ExtendedLogEvent> extendedLogEvents = new();
    private DateOnly startDate = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly endDate = DateOnly.FromDateTime(DateTime.Today);
    private string selectedCategory = "";
    private string userFilter = "";
    private string ipFilter = "";
    private string selectedResult = "";
    private string? loadError;
    private string? loadWarning;
    private int currentPage = 1;
    private int expandedRow = -1;
    private const int PageSize = 50;
    private const int MaxTotalEvents = 2000;

    private List<AuditEvent> allEvents = new();
    private List<AuditEvent> filteredEvents = new();
    private int totalPages => Math.Max(1, (int)Math.Ceiling(filteredEvents.Count / (double)PageSize));

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var authResult = await AuthorizationService.AuthorizeAsync(user, "EventLog");
        if (!authResult.Succeeded)
        {
            Navigation.NavigateTo("access-denied", forceLoad: true);
            return;
        }

        authChecked = true;
        LoadEvents();
    }

    private void LoadEvents()
    {
        loadError = null;
        loadWarning = null;
        allEvents = new List<AuditEvent>();
        expandedRow = -1;
        currentPage = 1;

        var logRoot = Config["Audit:LogRoot"] ?? @"E:\WWWOutput";
        var logFolder = Path.Combine(logRoot, "ExchangeAdminWeb");
        var rotationPeriod = Config["Audit:RotationPeriod"]?.ToLowerInvariant() ?? "daily";

        // Ensure startDate <= endDate
        var effectiveStart = startDate <= endDate ? startDate : endDate;
        var effectiveEnd = startDate <= endDate ? endDate : startDate;

        var filesLoaded = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var buffer = new Queue<AuditEvent>(MaxTotalEvents + 1);
        var filesNotFound = 0;
        var totalDays = effectiveEnd.DayNumber - effectiveStart.DayNumber + 1;
        var rangeStartUtc = effectiveStart.ToDateTime(TimeOnly.MinValue).ToUniversalTime();
        var rangeEndUtc = effectiveEnd.AddDays(1).ToDateTime(TimeOnly.MinValue).ToUniversalTime();
        var totalParsed = 0;

        for (var d = effectiveStart; d <= effectiveEnd; d = d.AddDays(1))
        {
            var date = d.ToDateTime(TimeOnly.MinValue);
            var suffix = rotationPeriod switch
            {
                "weekly" => $"{date.Year}W{System.Globalization.ISOWeek.GetWeekOfYear(date):D2}",
                "monthly" => date.ToString("yyyyMM"),
                _ => date.ToString("yyyyMMdd")
            };

            var filePath = Path.Combine(logFolder, $"exchangeadmin_{suffix}.jsonl");

            if (!filesLoaded.Add(filePath))
                continue;

            if (!File.Exists(filePath))
            {
                filesNotFound++;
                continue;
            }

            try
            {
                foreach (var line in File.ReadLines(filePath))
                {
                    if (string.IsNullOrWhiteSpace(line)) continue;
                    try
                    {
                        using var doc = JsonDocument.Parse(line);
                        var root = doc.RootElement;

                        var tsStr = TryGetString(root, "ts");
                        if (tsStr != null && DateTimeOffset.TryParse(tsStr, out var eventTime))
                        {
                            if (eventTime.UtcDateTime < rangeStartUtc || eventTime.UtcDateTime >= rangeEndUtc)
                                continue;
                        }

                        var eventType = TryGetString(root, "eventType") ?? "audit";
                        if (!eventType.Equals("audit", StringComparison.OrdinalIgnoreCase))
                            continue;

                        var rawTarget = GetAuditTarget(root);
                        totalParsed++;
                        buffer.Enqueue(new AuditEvent
                        {
                            Index = 0,
                            Time = tsStr != null ? FormatTimestamp(tsStr) : "",
                            User = TryGetString(root, "user") ?? "",
                            Ip = TryGetString(root, "ip") ?? "",
                            Action = FormatAction(root, eventType),
                            Category = FormatCategory(root, eventType),
                            Target = FormatTargetSummary(rawTarget),
                            FullTarget = rawTarget ?? "",
                            Result = TryGetString(root, "result") ?? "",
                            Details = ExtractAuditDetails(root, eventType, rawTarget)
                        });
                        if (buffer.Count > MaxTotalEvents)
                            buffer.Dequeue();
                    }
                    catch { }
                }
            }
            catch (Exception ex)
            {
                loadError = $"Error reading log: {ex.Message}";
                Logger.LogError(ex, "Failed to read audit log file {Path}", filePath);
            }
        }

        var anyFileFound = filesLoaded.Count > filesNotFound;
        if (buffer.Count == 0 && loadError == null)
        {
            loadError = !anyFileFound
                ? (effectiveStart == effectiveEnd
                    ? $"No log file found for {effectiveStart:yyyy-MM-dd}"
                    : $"No log files found for {effectiveStart:yyyy-MM-dd} to {effectiveEnd:yyyy-MM-dd}")
                : $"No events matched the selected date range.";
            filteredEvents = new();
            return;
        }

        if (totalParsed > MaxTotalEvents)
            loadWarning = $"Showing last {MaxTotalEvents} of {totalParsed} events in range.";

        allEvents = buffer.Reverse().ToList();
        for (int i = 0; i < allEvents.Count; i++)
            allEvents[i].Index = i;

        ApplyFilters();
        if (showExtendedLogs)
            LoadExtendedLogs();
    }

    private void ApplyFilters()
    {
        currentPage = 1;
        expandedRow = -1;
        filteredEvents = allEvents.Where(e =>
            CategoryMatches(e) &&
            (string.IsNullOrEmpty(userFilter) || e.User.Contains(userFilter, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(ipFilter) || e.Ip.Contains(ipFilter, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(selectedResult) || e.Result.Equals(selectedResult, StringComparison.OrdinalIgnoreCase))
        ).ToList();
    }

    private bool CategoryMatches(AuditEvent evt) =>
        string.IsNullOrEmpty(selectedCategory)
        || evt.Category.Equals(selectedCategory, StringComparison.OrdinalIgnoreCase)
        || (selectedCategory == "OperationTrace" && evt.Category.StartsWith("OperationTrace", StringComparison.OrdinalIgnoreCase));

    private List<AuditEvent> GetPage() =>
        filteredEvents.Skip((currentPage - 1) * PageSize).Take(PageSize).ToList();

    private void SetPage(int page)
    {
        if (page >= 1 && page <= totalPages)
        {
            currentPage = page;
            expandedRow = -1;
        }
    }

    private void ToggleExpand(int index) =>
        expandedRow = expandedRow == index ? -1 : index;

    private static string? TryGetString(JsonElement root, string prop) =>
        root.TryGetProperty(prop, out var val) && val.ValueKind == JsonValueKind.String ? val.GetString() : null;

    private static string? GetAuditTarget(JsonElement root) =>
        TryGetString(root, "target") ?? TryGetString(root, "batchName") ?? TryGetString(root, "section");

    private static string FormatTargetSummary(string? target)
    {
        if (string.IsNullOrWhiteSpace(target))
            return "";

        var messageIdIndex = target.IndexOf(" MessageId=", StringComparison.OrdinalIgnoreCase);
        var summary = messageIdIndex > 0 ? target[..messageIdIndex] : target;
        return summary.Length <= 90 ? summary : $"{summary[..87]}...";
    }

    private static string FormatTimestamp(string iso)
    {
        if (DateTimeOffset.TryParse(iso, out var dt))
            return dt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");
        return iso;
    }

    private static string FormatAction(JsonElement root, string eventType)
    {
        var action = TryGetString(root, "action") ?? eventType;
        if (!eventType.StartsWith("operation.", StringComparison.OrdinalIgnoreCase))
            return action;

        var stage = TryGetString(root, "stage");
        return string.IsNullOrWhiteSpace(stage) ? action : $"{action} / {stage}";
    }

    private static string FormatCategory(JsonElement root, string eventType)
    {
        if (!eventType.StartsWith("operation.", StringComparison.OrdinalIgnoreCase))
            return TryGetString(root, "category") ?? "";

        var module = TryGetString(root, "module");
        return string.IsNullOrWhiteSpace(module) ? "OperationTrace" : $"OperationTrace:{module}";
    }

    private static List<DetailField> ExtractAuditDetails(JsonElement root, string eventType, string? rawTarget)
    {
        var details = new List<DetailField>();
        AddTargetDetails(details, rawTarget);

        foreach (var property in root.EnumerateObject())
        {
            if (IsSummaryField(property.Name, eventType))
                continue;

            if (property.Name.Equals("details", StringComparison.OrdinalIgnoreCase) && property.Value.ValueKind == JsonValueKind.Object)
            {
                foreach (var detailProperty in property.Value.EnumerateObject())
                {
                    AddDetail(details, HumanizePropertyName(detailProperty.Name), FormatJsonValue(detailProperty.Value));
                }
                continue;
            }

            AddDetail(details, HumanizePropertyName(property.Name), FormatJsonValue(property.Value));
        }

        return details;
    }

    private static void AddTargetDetails(List<DetailField> details, string? rawTarget)
    {
        if (string.IsNullOrWhiteSpace(rawTarget))
            return;

        var messageIdIndex = rawTarget.IndexOf(" MessageId=", StringComparison.OrdinalIgnoreCase);
        var route = messageIdIndex > 0 ? rawTarget[..messageIdIndex] : rawTarget;
        var arrow = route.IndexOf("->", StringComparison.Ordinal);
        if (arrow > 0)
        {
            AddDetail(details, "Sender", route[..arrow].Trim());
            AddDetail(details, "Recipient", route[(arrow + 2)..].Trim());
        }

        if (messageIdIndex > 0)
        {
            AddDetail(details, "Message ID", rawTarget[(messageIdIndex + " MessageId=".Length)..].Trim());
        }

        AddDetail(details, "Full Target", rawTarget);
    }

    private static void AddDetail(List<DetailField> details, string key, string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return;

        if (details.Any(d => d.Key.Equals(key, StringComparison.OrdinalIgnoreCase) && d.Value.Equals(value, StringComparison.OrdinalIgnoreCase)))
            return;

        details.Add(new DetailField(key, value));
    }

    private static bool IsSummaryField(string name, string eventType)
    {
        if (name is "ts" or "user" or "ip" or "category" or "result" or "target" or "batchName" or "section")
            return true;

        if (name is "action")
            return true;

        if (eventType.StartsWith("operation.", StringComparison.OrdinalIgnoreCase))
            return name is "module" or "stage";

        return false;
    }

    private static string FormatJsonValue(JsonElement value) => value.ValueKind switch
    {
        JsonValueKind.String => value.GetString() ?? "",
        JsonValueKind.Number => value.GetRawText(),
        JsonValueKind.True => "true",
        JsonValueKind.False => "false",
        JsonValueKind.Array => string.Join(", ", value.EnumerateArray().Select(FormatJsonValue).Where(v => !string.IsNullOrWhiteSpace(v))),
        JsonValueKind.Object => value.GetRawText(),
        _ => ""
    };

    private static string HumanizePropertyName(string name)
    {
        if (string.IsNullOrWhiteSpace(name))
            return name;

        var chars = new List<char>(name.Length + 8);
        for (var i = 0; i < name.Length; i++)
        {
            var c = name[i] == '_' ? ' ' : name[i];
            if (i > 0 && c != ' ' && char.IsUpper(c) && (char.IsLower(name[i - 1]) || char.IsDigit(name[i - 1])))
                chars.Add(' ');
            chars.Add(c);
        }

        return new string(chars.ToArray());
    }

    private async Task DownloadCsv()
    {
        if (filteredEvents.Count == 0) return;

        using var writer = new System.IO.StringWriter();
        using var csv = new CsvWriter(writer, CultureInfo.InvariantCulture);

        csv.WriteField("Time");
        csv.WriteField("User");
        csv.WriteField("IP");
        csv.WriteField("Action");
        csv.WriteField("Category");
        csv.WriteField("Target");
        csv.WriteField("Result");
        await csv.NextRecordAsync();

        foreach (var evt in filteredEvents)
        {
            csv.WriteField(evt.Time);
            csv.WriteField(evt.User);
            csv.WriteField(evt.Ip);
            csv.WriteField(evt.Action);
            csv.WriteField(evt.Category);
            csv.WriteField(evt.FullTarget);
            csv.WriteField(evt.Result);
            await csv.NextRecordAsync();
        }

        await csv.FlushAsync();
        var bytes = System.Text.Encoding.UTF8.GetBytes(writer.ToString());
        var base64 = Convert.ToBase64String(bytes);
        var timestamp = DateTime.Now.ToString("yyyyMMdd_HHmmss");
        await JS.InvokeVoidAsync("downloadFile", $"event_log_{timestamp}.csv", "text/csv", base64);
    }

    private void ToggleExtendedLogs()
    {
        showExtendedLogs = !showExtendedLogs;
        if (showExtendedLogs)
            LoadExtendedLogs();
    }

    private void LoadExtendedLogs()
    {
        extendedLogEvents = ExtendedLog.GetEntries(startDate.ToDateTime(TimeOnly.MinValue), endDate.ToDateTime(TimeOnly.MaxValue))
            .Select(ParseExtendedLogEntry)
            .ToList();
    }

    private static ExtendedLogEvent ParseExtendedLogEntry(string line)
    {
        try
        {
            using var doc = JsonDocument.Parse(line);
            var root = doc.RootElement;
            var ts = TryGetString(root, "ts") ?? "";
            var detail = TryGetString(root, "detail") ?? "";

            return new ExtendedLogEvent
            {
                Time = string.IsNullOrWhiteSpace(ts) ? "" : FormatTimestamp(ts),
                Level = TryGetString(root, "level") ?? "Info",
                Category = TryGetString(root, "category") ?? "",
                Message = TryGetString(root, "message") ?? "",
                Detail = detail,
                DetailFields = ParseExtendedDetail(detail)
            };
        }
        catch
        {
            return new ExtendedLogEvent
            {
                Level = "Raw",
                Message = "Unparsed log line",
                Detail = line
            };
        }
    }

    private static List<DetailField> ParseExtendedDetail(string detail)
    {
        var fields = new List<DetailField>();
        if (string.IsNullOrWhiteSpace(detail))
            return fields;

        foreach (var part in detail.Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
        {
            var separator = part.IndexOf('=');
            if (separator <= 0 || separator == part.Length - 1)
                return new();

            fields.Add(new DetailField(part[..separator].Trim(), part[(separator + 1)..].Trim()));
        }

        return fields;
    }

    private static string GetExtendedLevelBadge(string level) => level.ToLowerInvariant() switch
    {
        "error" or "fatal" => "text-bg-danger",
        "warning" or "warn" => "text-bg-warning",
        "debug" or "verbose" => "text-bg-secondary",
        "raw" => "text-bg-light",
        _ => "text-bg-info"
    };

    private sealed record DetailField(string Key, string Value);

    private class ExtendedLogEvent
    {
        public string Time { get; set; } = "";
        public string Level { get; set; } = "";
        public string Category { get; set; } = "";
        public string Message { get; set; } = "";
        public string Detail { get; set; } = "";
        public List<DetailField> DetailFields { get; set; } = new();
    }

    private class AuditEvent
    {
        public int Index { get; set; }
        public string Time { get; set; } = "";
        public string User { get; set; } = "";
        public string Ip { get; set; } = "";
        public string Action { get; set; } = "";
        public string Category { get; set; } = "";
        public string Target { get; set; } = "";
        public string FullTarget { get; set; } = "";
        public string Result { get; set; } = "";
        public List<DetailField> Details { get; set; } = new();
    }
}
