<div class="position-relative">
    <div class="border rounded p-2" style="max-height: 300px; overflow-y: auto;">
        <div class="mb-2">
            <input type="text" class="form-control form-control-sm" placeholder="Filter countries..."
                   @oninput="OnFilterInput" disabled="@Disabled" />
        </div>

        @foreach (var country in FilteredCountries)
        {
            var code = country.Code;
            <div class="form-check py-0">
                <input class="form-check-input" type="checkbox" id="@($"cc_{code}")"
                       checked="@_selectedCodes.Contains(code)"
                       @onchange="(e) => ToggleCode(code, (bool)(e.Value ?? false))"
                       disabled="@Disabled" />
                <label class="form-check-label small" for="@($"cc_{code}")">
                    @(code) - @country.Name
                </label>
            </div>
        }

        @if (!FilteredCountries.Any())
        {
            <p class="text-muted small mb-0">No matching countries.</p>
        }
    </div>

    @if (_selectedCodes.Count > 0)
    {
        <div class="mt-2">
            <small class="text-muted">@_selectedCodes.Count selected</small>
            <button class="btn btn-primary btn-sm ms-2" @onclick="Apply" disabled="@Disabled">Apply</button>
            <button class="btn btn-outline-secondary btn-sm ms-1" @onclick="ClearAll" disabled="@Disabled">Clear</button>
        </div>
    }
</div>

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }

    private HashSet<string> _selectedCodes = new(StringComparer.OrdinalIgnoreCase);
    private string _filter = "";
    private bool _initialized;

    protected override void OnParametersSet()
    {
        if (!_initialized && !string.IsNullOrEmpty(Value))
        {
            _selectedCodes = Value
                .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                .Where(c => !string.IsNullOrWhiteSpace(c))
                .ToHashSet(StringComparer.OrdinalIgnoreCase);
            _initialized = true;
        }
    }

    private IEnumerable<CountryEntry> FilteredCountries =>
        string.IsNullOrWhiteSpace(_filter)
            ? AllCountries
            : AllCountries.Where(c =>
                c.Code.Contains(_filter, StringComparison.OrdinalIgnoreCase) ||
                c.Name.Contains(_filter, StringComparison.OrdinalIgnoreCase));

    private void OnFilterInput(ChangeEventArgs e)
    {
        _filter = e.Value?.ToString() ?? "";
    }

    private void ToggleCode(string code, bool isChecked)
    {
        if (isChecked)
            _selectedCodes.Add(code);
        else
            _selectedCodes.Remove(code);
    }

    private async Task Apply()
    {
        var sorted = _selectedCodes.OrderBy(c => c).ToList();
        var value = string.Join("\n", sorted);
        Value = value;
        await ValueChanged.InvokeAsync(value);
    }

    private async Task ClearAll()
    {
        _selectedCodes.Clear();
        Value = "";
        await ValueChanged.InvokeAsync("");
    }

    private record CountryEntry(string Code, string Name);

