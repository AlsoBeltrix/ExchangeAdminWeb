@implements IDisposable
@inject ExchangeAdminWeb.Services.ADDirectorySearchService ADSearch

<div class="position-relative">
    <input type="text"
           class="form-control"
           value="@Value"
           @oninput="OnInput"
           @onfocus="OnFocus"
           @onblur="OnBlur"
           @onkeydown="OnKeyDown"
           placeholder="@Placeholder"
           disabled="@Disabled"
           autocomplete="off" />

    @if (_showDropdown && _results.Count > 0)
    {
        <ul class="list-group position-absolute w-100 shadow-sm"
            style="z-index: 1050; max-height: 300px; overflow-y: auto; top: 100%;">
            @for (int i = 0; i < _results.Count; i++)
            {
                var result = _results[i];
                var index = i;
                <li class="list-group-item list-group-item-action py-1 px-2 @(index == _highlightedIndex ? "active" : "")"
                    style="cursor: pointer; font-size: 0.9rem;"
                    @onmousedown="() => SelectResult(result)"
                    @onmousedown:preventDefault>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <span class="fw-semibold">@result.DisplayName</span>
                            <span class="text-muted ms-1" style="font-size: 0.8rem;">
                                @GetSecondaryText(result)
                            </span>
                        </div>
                        <span class="badge @(result.ObjectType == "User" ? "bg-primary" : "bg-secondary") ms-2"
                              style="font-size: 0.7rem;">
                            @result.ObjectType
                        </span>
                    </div>
                </li>
            }
        </ul>
    }

    @if (_isSearching)
    {
        <div class="position-absolute" style="right: 0.5rem; top: 0.5rem;">
            <span class="spinner-border spinner-border-sm text-muted"></span>
        </div>
    }
</div>

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string ObjectKind { get; set; } = "Any";
    [Parameter] public string ReturnValueKind { get; set; } = "SAM";
    [Parameter] public string Placeholder { get; set; } = "";
    [Parameter] public bool Disabled { get; set; }

    private List<ExchangeAdminWeb.Services.ADSearchResult> _results = [];
    private bool _showDropdown;
    private bool _isSearching;
    private int _highlightedIndex = -1;
    private System.Threading.Timer? _debounceTimer;
    private string _lastSearchTerm = "";

    private async Task OnInput(ChangeEventArgs e)
    {
        var newValue = e.Value?.ToString() ?? "";
        Value = newValue;
        await ValueChanged.InvokeAsync(newValue);

        _highlightedIndex = -1;

        // Debounce the search
        _debounceTimer?.Dispose();

        if (!ADSearch.IsAvailable || newValue.Trim().Length < 3)
        {
            _results = [];
            _showDropdown = false;
            StateHasChanged();
            return;
        }

        _debounceTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(() => PerformSearch(newValue.Trim()));
        }, null, 300, Timeout.Infinite);
    }

    private async Task PerformSearch(string term)
    {
        if (term == _lastSearchTerm && _results.Count > 0)
            return;

        _lastSearchTerm = term;
        _isSearching = true;
        StateHasChanged();

        try
        {
            _results = await Task.Run(() => ADSearch.Search(term, ObjectKind));
            _showDropdown = _results.Count > 0;
        }
        catch
        {
            _results = [];
            _showDropdown = false;
        }
        finally
        {
            _isSearching = false;
            StateHasChanged();
        }
    }

    private async Task SelectResult(ExchangeAdminWeb.Services.ADSearchResult result)
    {
        var selectedValue = GetReturnValue(result);
        Value = selectedValue;
        _showDropdown = false;
        _results = [];
        _highlightedIndex = -1;
        await ValueChanged.InvokeAsync(selectedValue);
    }

    private string GetReturnValue(ExchangeAdminWeb.Services.ADSearchResult result)
    {
        return ReturnValueKind switch
        {
            "UPN" => result.UserPrincipalName ?? result.DisplayName,
            "SAM" => result.SamAccountName ?? result.DisplayName,
            "DN" => result.DistinguishedName,
            "DisplayName" => result.DisplayName,
            _ => result.SamAccountName ?? result.DisplayName
        };
    }

    private string GetSecondaryText(ExchangeAdminWeb.Services.ADSearchResult result)
    {
        if (result.ObjectType == "User")
        {
            if (!string.IsNullOrEmpty(result.UserPrincipalName))
                return result.UserPrincipalName;
            if (!string.IsNullOrEmpty(result.SamAccountName))
                return result.SamAccountName;
        }
        else
        {
            if (!string.IsNullOrEmpty(result.SamAccountName))
                return result.SamAccountName;
            if (!string.IsNullOrEmpty(result.Email))
                return result.Email;
        }

        return result.DistinguishedName;
    }

    private void OnFocus()
    {
        if (_results.Count > 0)
            _showDropdown = true;
    }

    private void OnBlur()
    {
        // Delay hiding to allow click events on dropdown items to fire
        _ = Task.Delay(200).ContinueWith(_ => InvokeAsync(() =>
        {
            _showDropdown = false;
            StateHasChanged();
        }));
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (!_showDropdown || _results.Count == 0)
            return;

        switch (e.Key)
        {
            case "ArrowDown":
                _highlightedIndex = (_highlightedIndex + 1) % _results.Count;
                break;
            case "ArrowUp":
                _highlightedIndex = _highlightedIndex <= 0 ? _results.Count - 1 : _highlightedIndex - 1;
                break;
            case "Enter":
                if (_highlightedIndex >= 0 && _highlightedIndex < _results.Count)
                    await SelectResult(_results[_highlightedIndex]);
                break;
            case "Escape":
                _showDropdown = false;
                _highlightedIndex = -1;
                break;
        }
    }

    public void Dispose()
    {
        _debounceTimer?.Dispose();
    }
}
