@implements IDisposable
@inject ExchangeAdminWeb.Services.ExoConnectionPool ExoPool

<div class="position-relative">
    <input type="text"
           class="form-control"
           value="@Value"
           @oninput="OnInput"
           @onfocus="OnFocus"
           @onblur="OnBlur"
           @onkeydown="OnKeyDown"
           placeholder="@Placeholder"
           disabled="@Disabled"
           autocomplete="off" />

    @if (_showDropdown && _results.Count > 0)
    {
        <ul class="list-group position-absolute w-100 shadow-sm"
            style="z-index: 1050; max-height: 300px; overflow-y: auto; top: 100%;">
            @for (int i = 0; i < _results.Count; i++)
            {
                var result = _results[i];
                var index = i;
                <li class="list-group-item list-group-item-action py-1 px-2 @(index == _highlightedIndex ? "active" : "")"
                    style="cursor: pointer; font-size: 0.9rem;"
                    @onmousedown="() => SelectResult(result)"
                    @onmousedown:preventDefault>
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <span class="fw-semibold">@result.DisplayName</span>
                            <span class="text-muted ms-1" style="font-size: 0.8rem;">
                                @result.PrimarySmtpAddress
                            </span>
                        </div>
                        <span class="badge bg-secondary ms-2" style="font-size: 0.7rem;">
                            @result.RecipientTypeDetails
                        </span>
                    </div>
                </li>
            }
        </ul>
    }

    @if (_isSearching)
    {
        <div class="position-absolute" style="right: 0.5rem; top: 0.5rem;">
            <span class="spinner-border spinner-border-sm text-muted"></span>
        </div>
    }
</div>

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public string Placeholder { get; set; } = "Search recipients...";
    [Parameter] public bool Disabled { get; set; }

    private List<RecipientSearchResult> _results = [];
    private bool _showDropdown;
    private bool _isSearching;
    private int _highlightedIndex = -1;
    private System.Threading.Timer? _debounceTimer;
    private string _lastSearchTerm = "";

    private async Task OnInput(ChangeEventArgs e)
    {
        var newValue = e.Value?.ToString() ?? "";
        Value = newValue;
        await ValueChanged.InvokeAsync(newValue);

        _highlightedIndex = -1;

        // Debounce the search
        _debounceTimer?.Dispose();

        if (!ExoPool.IsConfigured || newValue.Trim().Length < 3)
        {
            _results = [];
            _showDropdown = false;
            StateHasChanged();
            return;
        }

        _debounceTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(() => PerformSearch(newValue.Trim()));
        }, null, 300, Timeout.Infinite);
    }

    private async Task PerformSearch(string term)
    {
        if (term == _lastSearchTerm && _results.Count > 0)
            return;

        _lastSearchTerm = term;
        _isSearching = true;
        StateHasChanged();

        try
        {
            var escaped = term.Replace("'", "''");
            var filter = $"Name -like '*{escaped}*' -or PrimarySmtpAddress -like '*{escaped}*'";

            var pooled = await ExoPool.BorrowAsync();
            try
            {
                var tracker = new ExchangeAdminWeb.Services.ExchangeServiceBase.ConnectionErrorTracker();
                _results = await Task.Run(() =>
                {
                    var ps = pooled.PowerShell;
                    ps.Commands.Clear();
                    ps.Streams.ClearStreams();
                    ps.AddCommand("Get-Recipient")
                      .AddParameter("Filter", filter)
                      .AddParameter("ResultSize", 10)
                      .AddParameter("ErrorAction", "Stop");

                    var output = ps.Invoke();

                    if (ps.HadErrors)
                    {
                        var err = ps.Streams.Error.FirstOrDefault();
                        if (err?.Exception != null &&
                            (err.Exception.Message.Contains("connection", StringComparison.OrdinalIgnoreCase) ||
                             err.Exception.Message.Contains("session", StringComparison.OrdinalIgnoreCase) ||
                             err.Exception.Message.Contains("runspace", StringComparison.OrdinalIgnoreCase)))
                            tracker.HasConnectionError = true;
                        ps.Streams.Error.Clear();
                    }

                    ps.Commands.Clear();
                    var list = new List<RecipientSearchResult>();

                    foreach (var item in output)
                    {
                        list.Add(new RecipientSearchResult
                        {
                            DisplayName = item.Properties["DisplayName"]?.Value?.ToString() ?? "",
                            PrimarySmtpAddress = item.Properties["PrimarySmtpAddress"]?.Value?.ToString() ?? "",
                            RecipientTypeDetails = item.Properties["RecipientTypeDetails"]?.Value?.ToString() ?? ""
                        });
                    }

                    return list;
                });

                _showDropdown = _results.Count > 0;

                if (tracker.HasConnectionError)
                    ExoPool.Discard(pooled);
                else
                    ExoPool.Return(pooled);
            }
            catch
            {
                ExoPool.Discard(pooled);
                _results = [];
                _showDropdown = false;
            }
        }
        catch
        {
            _results = [];
            _showDropdown = false;
        }
        finally
        {
            _isSearching = false;
            StateHasChanged();
        }
    }

    private async Task SelectResult(RecipientSearchResult result)
    {
        Value = result.PrimarySmtpAddress;
        _showDropdown = false;
        _results = [];
        _highlightedIndex = -1;
        await ValueChanged.InvokeAsync(result.PrimarySmtpAddress);
    }

    private void OnFocus()
    {
        if (_results.Count > 0)
            _showDropdown = true;
    }

    private void OnBlur()
    {
        // Delay hiding to allow click events on dropdown items to fire
        _ = Task.Delay(200).ContinueWith(_ =>
        {
            if (_disposed) return;
            InvokeAsync(() =>
            {
                if (_disposed) return;
                _showDropdown = false;
                StateHasChanged();
            });
        });
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (!_showDropdown || _results.Count == 0)
            return;

        switch (e.Key)
        {
            case "ArrowDown":
                _highlightedIndex = (_highlightedIndex + 1) % _results.Count;
                break;
            case "ArrowUp":
                _highlightedIndex = _highlightedIndex <= 0 ? _results.Count - 1 : _highlightedIndex - 1;
                break;
            case "Enter":
                if (_highlightedIndex >= 0 && _highlightedIndex < _results.Count)
                    await SelectResult(_results[_highlightedIndex]);
                break;
            case "Escape":
                _showDropdown = false;
                _highlightedIndex = -1;
                break;
        }
    }

    private bool _disposed;

    public void Dispose()
    {
        _disposed = true;
        _debounceTimer?.Dispose();
    }

    private class RecipientSearchResult
    {
        public string DisplayName { get; set; } = "";
        public string PrimarySmtpAddress { get; set; } = "";
        public string RecipientTypeDetails { get; set; } = "";
    }
}
