@inherits LayoutComponentBase
@inject IJSRuntime JS

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-end align-items-center">
            <AuthorizeView>
                <Authorized>
                    <button class="btn btn-sm btn-outline-secondary me-3 theme-toggle" @onclick="ToggleTheme" title="Toggle dark mode">
                        @(isDark ? "☀️" : "🌙")
                    </button>
                    <small class="text-muted">
                        <span class="me-1">&#128100;</span>@context.User.Identity?.Name
                    </small>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">&#x2715;</a>
</div>

@code {
    private bool isDark;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            isDark = await JS.InvokeAsync<bool>("getTheme");
            StateHasChanged();
        }
    }

    private async Task ToggleTheme()
    {
        isDark = await JS.InvokeAsync<bool>("toggleTheme");
    }
}
