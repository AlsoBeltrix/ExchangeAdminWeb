@rendermode InteractiveServer
@inject IJSRuntime JS

<button class="btn btn-sm btn-outline-secondary theme-toggle me-3" @onclick="Toggle" title="Toggle dark/light mode">
    @(isDark ? "☀️" : "🌙")
</button>

@code {
    private bool isDark;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            isDark = await JS.InvokeAsync<bool>("getTheme");
            StateHasChanged();
        }
    }

    private async Task Toggle()
    {
        isDark = await JS.InvokeAsync<bool>("toggleTheme");
    }
}
