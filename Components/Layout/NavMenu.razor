@using Microsoft.AspNetCore.Authorization
@using ExchangeAdminWeb.Modules
@using ExchangeAdminWeb.Services
@inject IConfiguration Config
@inject ModuleCatalog Catalog
@inject ModuleEnablementService Enablement
@inject ModuleAdminService ModuleAdmin
@inject AuthenticationStateProvider AuthStateProvider

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">@(Config["Application:Name"] ?? "Admin Portal")</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        @foreach (var module in Catalog.GetOrdered().Where(m => !m.IsSystemModule && m.SortOrder < 900 && Enablement.IsModuleEnabled(m.Id)))
        {
            <AuthorizeView Policy="@module.MainPermission.PolicyAlias">
                <Authorized>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="@module.Route">
                            <span class="@module.IconCss" aria-hidden="true"></span> @module.DisplayName
                        </NavLink>
                    </div>
                </Authorized>
            </AuthorizeView>
        }
        @{ var systemModules = Catalog.GetOrdered().Where(m => m.IsSystemModule).ToList(); }
        @{ var adminAdjacentModules = Catalog.GetOrdered().Where(m => !m.IsSystemModule && m.SortOrder >= 900 && Enablement.IsModuleEnabled(m.Id)).ToList(); }
        @if (systemModules.Any() || adminAdjacentModules.Any())
        {
            <AuthorizeView Policy="@systemModules.First().MainPermission.PolicyAlias">
                <Authorized>
                    @foreach (var module in systemModules)
                    {
                        <div class="nav-item px-3 @(module == systemModules.First() ? "mt-3 border-top pt-3" : "")">
                            <NavLink class="nav-link" href="@module.Route">
                                <span class="@module.IconCss" aria-hidden="true"></span> @module.DisplayName
                            </NavLink>
                        </div>
                    }
                    <div class="nav-item px-3">
                        <div class="nav-link nav-tree-toggle" style="cursor: pointer;" @onclick="() => configTreeExpanded = !configTreeExpanded" @onclick:stopPropagation="true">
                            <span class="bi bi-gear-fill-nav-menu" aria-hidden="true"></span>
                            Module Config
                            <span class="ms-auto" style="font-size: 0.7em;">@(configTreeExpanded ? "−" : "+")</span>
                        </div>
                        @if (configTreeExpanded)
                        {
                            @foreach (var cfgModule in configModulesForGlobalAdmin)
                            {
                                <div class="nav-item ps-4">
                                    <NavLink class="nav-link py-1" href="@($"module-config/{cfgModule.Id}")" style="font-size: 0.85em;">
                                        @cfgModule.DisplayName
                                    </NavLink>
                                </div>
                            }
                        }
                    </div>
                </Authorized>
            </AuthorizeView>
            @foreach (var module in adminAdjacentModules)
            {
                <AuthorizeView Policy="@module.MainPermission.PolicyAlias">
                    <Authorized>
                        <div class="nav-item px-3">
                            <NavLink class="nav-link" href="@module.Route">
                                <span class="@module.IconCss" aria-hidden="true"></span> @module.DisplayName
                            </NavLink>
                        </div>
                    </Authorized>
                </AuthorizeView>
            }
        }
        @if (moduleAdminModules.Count > 0)
        {
            <AuthorizeView Policy="AdminSettings">
                <NotAuthorized>
                    <div class="nav-item px-3 mt-3 border-top pt-3">
                        <div class="nav-link nav-tree-toggle" style="cursor: pointer;" @onclick="() => moduleAdminTreeExpanded = !moduleAdminTreeExpanded" @onclick:stopPropagation="true">
                            <span class="bi bi-gear-fill-nav-menu" aria-hidden="true"></span>
                            Module Config
                            <span class="ms-auto" style="font-size: 0.7em;">@(moduleAdminTreeExpanded ? "−" : "+")</span>
                        </div>
                        @if (moduleAdminTreeExpanded)
                        {
                            @foreach (var cfgModule in moduleAdminModules)
                            {
                                <div class="nav-item ps-4">
                                    <NavLink class="nav-link py-1" href="@($"module-config/{cfgModule.Id}")" style="font-size: 0.85em;">
                                        @cfgModule.DisplayName
                                    </NavLink>
                                </div>
                            }
                        }
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        }

        <div class="nav-item px-3 mt-auto pt-3 border-top">
            <small class="text-muted d-block" style="font-size: 0.7em; line-height: 1.4;">
                @{ var contactEmail = Config["Application:ContactEmail"]; }
                v1.5.0
                @if (!string.IsNullOrEmpty(contactEmail))
                {
                    <text> | Issues? <a href="mailto:@contactEmail">@contactEmail</a></text>
                }
            </small>
        </div>
    </nav>
</div>

@code {
    private List<AdminModuleDescriptor> configModulesForGlobalAdmin = new();
    private List<AdminModuleDescriptor> moduleAdminModules = new();
    private bool configTreeExpanded;
    private bool moduleAdminTreeExpanded;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        configModulesForGlobalAdmin = Catalog.GetOrdered()
            .Where(m => !m.IsSystemModule)
            .ToList();

        moduleAdminModules = Catalog.GetOrdered()
            .Where(m => !m.IsSystemModule && ModuleAdmin.IsModuleAdmin(m.Id, user))
            .ToList();
    }
}
