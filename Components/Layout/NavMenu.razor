@using Microsoft.AspNetCore.Authorization
@inject IConfiguration Config

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Exchange Admin</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        <AuthorizeView Policy="MailboxPermissions">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="mailbox-permissions">
                        <span class="bi bi-person-fill-nav-menu" aria-hidden="true"></span> Mailbox Permissions
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="CalendarPermissions">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="calendar-permissions">
                        <span class="bi bi-calendar-fill-nav-menu" aria-hidden="true"></span> Calendar Permissions
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="MigrationCheck">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="migration">
                        <span class="bi bi-arrow-left-right-nav-menu" aria-hidden="true"></span> Migration
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="DelegationReport">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="delegation-report">
                        <span class="bi bi-people-fill-nav-menu" aria-hidden="true"></span> Delegation Report
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="MessageTrace">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="message-trace">
                        <span class="bi bi-envelope-fill-nav-menu" aria-hidden="true"></span> Message Trace
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="RecipientLookup">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="recipient-lookup">
                        <span class="bi bi-search-nav-menu" aria-hidden="true"></span> Recipient Lookup
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="OutOfOffice">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="out-of-office">
                        <span class="bi bi-clock-fill-nav-menu" aria-hidden="true"></span> Out of Office
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="AdminSettings">
            <Authorized>
                <div class="nav-item px-3 mt-3 border-top pt-3">
                    <NavLink class="nav-link" href="admin-settings">
                        <span class="bi bi-gear-fill-nav-menu" aria-hidden="true"></span> Admin Settings
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin-event-log">
                        Event Log
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        <div class="nav-item px-3 mt-auto pt-3 border-top">
            <small class="text-muted d-block" style="font-size: 0.7em; line-height: 1.4;">
                @{ var contactEmail = Config["Application:ContactEmail"]; }
                v0.9.16
                @if (!string.IsNullOrEmpty(contactEmail))
                {
                    <text> | Issues? <a href="mailto:@contactEmail">@contactEmail</a></text>
                }
            </small>
        </div>
    </nav>
</div>
