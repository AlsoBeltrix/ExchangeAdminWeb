<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0-windows10.0.17763.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- _not_for_github\ is a git-ignored local scratch tree (session notes, example scripts).
         It holds loose .cs/.razor files that are not part of the app and do not compile on their
         own; exclude it from all default item globs so a local checkout builds cleanly. -->
    <DefaultItemExcludes>$(DefaultItemExcludes);ExchangeAdminWeb.Tests\**;_not_for_github\**</DefaultItemExcludes>
    <VersionPrefix>2.3.24</VersionPrefix>
    <InformationalVersion>$(VersionPrefix)</InformationalVersion>
    <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
    <AssemblyVersion>2.3.24.0</AssemblyVersion>
    <FileVersion>2.3.24.0</FileVersion>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="ExchangeAdminWeb.Tests" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CsvHelper" Version="33.1.0" />
    <PackageReference Include="MailKit" Version="4.16.0" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.Negotiate" Version="10.0.7" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.7" />
    <PackageReference Include="MsgReader" Version="6.0.11" />
    <PackageReference Include="OpenMcdf" Version="3.1.4" />
    <PackageReference Include="Microsoft.PowerShell.SDK" Version="7.6.1" />
    <PackageReference Include="Serilog.AspNetCore" Version="10.0.0" />
    <PackageReference Include="Serilog.Enrichers.Environment" Version="3.0.1" />
    <PackageReference Include="Serilog.Sinks.File" Version="7.0.0" />
  </ItemGroup>

</Project>
